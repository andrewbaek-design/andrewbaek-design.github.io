{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "medme",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "python3 -m http.server $PORT"],
      "port": 8000,
      "autoPort": true
    },
    {
      "name": "medme-astro",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "cd astro && npx astro dev --port $PORT --host"],
      "port": 4321,
      "autoPort": true
    }
  ]
}

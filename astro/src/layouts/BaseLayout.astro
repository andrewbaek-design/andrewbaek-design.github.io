---
import UtilBarUs from '../components/UtilBarUs.astro';
import NavUs from '../components/NavUs.astro';
import FooterUs from '../components/FooterUs.astro';

interface Props {
  title: string;
  description: string;
  lang?: string;
  showAnnouncement?: boolean;
}

const { title, description, lang = 'en', showAnnouncement = true } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
<meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/assets/brand.css" />
<slot name="head" />
</head>
<body>
<a href="#main" class="skip-link">Skip to main content</a>

{showAnnouncement && <UtilBarUs />}

<NavUs />

<main id="main">
<slot />
</main>

<FooterUs />

<slot name="end-of-body" />
<!-- Sticky-nav pill scroll handler + cookie banner + util-bar dismiss
     logic all live here. Loaded site-wide so pages that hide the
     announcement util-bar (showAnnouncement={false}) still get the
     scroll-driven nav effects. -->
<script src="/assets/site.js" is:inline defer></script>
</body>
</html>

---
import LogoMedme from './LogoMedme.astro';
---
<!--
  US navigation, locked to sitemap v11.
  Structure: Pharmacy ▾ / Platform ▾ / Partners ▾ / Resources ▾ / About
-->
<header class="nav" role="banner">
  <div class="wrap">
    <a href="/us" class="nav__logo" aria-label="MedMe Health home">
      <LogoMedme />
    </a>
    <nav aria-label="Primary">
      <ul class="nav__links">

        <!-- PHARMACY -->
        <li class="nav__item-group" aria-expanded="false">
          <button type="button" class="nav__item-trigger" aria-haspopup="true" aria-expanded="false">Pharmacy</button>
          <div class="nav__dropdown" role="menu">
            <a href="/us/pharmacy/independents" class="nav__dropdown-link" role="menuitem">
              <span class="nav__dropdown-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 9l1-4h16l1 4"/><path d="M5 9v11h14V9"/><path d="M9 14h6"/></svg></span>
              <span class="nav__dropdown-content">
                <span class="nav__dropdown-title">Independents</span>
                <span class="nav__dropdown-desc">Single-store and small-group operators</span>
              </span>
            </a>
            <a href="/us/pharmacy/enterprises" class="nav__dropdown-link" role="menuitem">
              <span class="nav__dropdown-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="3" y="9" width="7" height="12" rx="1"/><rect x="14" y="3" width="7" height="18" rx="1"/><line x1="6" y1="13" x2="7" y2="13"/><line x1="17" y1="7" x2="18" y2="7"/><line x1="17" y1="11" x2="18" y2="11"/><line x1="17" y1="15" x2="18" y2="15"/></svg></span>
              <span class="nav__dropdown-content">
                <span class="nav__dropdown-title">Enterprises</span>
                <span class="nav__dropdown-desc">Regional chains, top-100, health systems</span>
              </span>
            </a>
            <a href="/us/pharmacy/networks" class="nav__dropdown-link" role="menuitem">
              <span class="nav__dropdown-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><circle cx="5" cy="5" r="2"/><circle cx="19" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/><line x1="6.5" y1="6.5" x2="10" y2="10"/><line x1="17.5" y1="6.5" x2="14" y2="10"/><line x1="6.5" y1="17.5" x2="10" y2="14"/><line x1="17.5" y1="17.5" x2="14" y2="14"/></svg></span>
              <span class="nav__dropdown-content">
                <span class="nav__dropdown-title">Networks</span>
                <span class="nav__dropdown-desc">Banners, Co-ops &amp; PSAOs</span>
              </span>
            </a>
            <a href="/us/pharmacy/specialty" class="nav__dropdown-link" role="menuitem">
              <span class="nav__dropdown-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="2" y="9" width="20" height="6" rx="3"/><line x1="12" y1="9" x2="12" y2="15"/></svg></span>
              <span class="nav__dropdown-content">
                <span class="nav__dropdown-title">Specialty</span>
                <span class="nav__dropdown-desc">Specialty pharmacies and payvider partners</span>
              </span>
            </a>
          </div>
        </li>

        <!-- PLATFORM -->
        <li class="nav__item-group" aria-expanded="false">
          <button type="button" class="nav__item-trigger" aria-haspopup="true" aria-expanded="false">Platform</button>
          <div class="nav__dropdown nav__dropdown--mega" role="menu">
            <div class="nav__dropdown-group">
              <h4 class="nav__dropdown-group-label">Pharmacy EHR</h4>
              <a href="/us/platform/scheduling-queuing" class="nav__dropdown-tile" role="menuitem">
                <span class="nav__dropdown-tile-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span>
                <span class="nav__dropdown-tile-content">
                  <span class="nav__dropdown-tile-title">Scheduling &amp; Queueing</span>
                  <span class="nav__dropdown-tile-desc">Multi-calendar booking with patient flow visibility</span>
                </span>
              </a>
              <a href="/us/platform/patient-intake" class="nav__dropdown-tile" role="menuitem">
                <span class="nav__dropdown-tile-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="6" y="3" width="12" height="18" rx="2"/><line x1="9" y1="9" x2="15" y2="9"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/><rect x="9" y="1" width="6" height="4" rx="1"/></svg></span>
                <span class="nav__dropdown-tile-content">
                  <span class="nav__dropdown-tile-title">Patient Intake Forms</span>
                  <span class="nav__dropdown-tile-desc">Info, consent, and eligibility before the consult</span>
                </span>
              </a>
              <a href="/us/platform/assisted-documentation" class="nav__dropdown-tile" role="menuitem">
                <span class="nav__dropdown-tile-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="14" y2="13"/><line x1="8" y1="17" x2="14" y2="17"/></svg></span>
                <span class="nav__dropdown-tile-content">
                  <span class="nav__dropdown-tile-title">Assisted Documentation</span>
                  <span class="nav__dropdown-tile-desc">Finish notes during the visit, not after</span>
                </span>
              </a>
              <a href="/us/platform/messaging-follow-ups" class="nav__dropdown-tile" role="menuitem">
                <span class="nav__dropdown-tile-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg></span>
                <span class="nav__dropdown-tile-content">
                  <span class="nav__dropdown-tile-title">Messaging &amp; Follow-Ups</span>
                  <span class="nav__dropdown-tile-desc">Automated SMS and email for reminders and campaigns</span>
                </span>
              </a>
              <a href="/us/platform/ai-clinical-assistant" class="nav__dropdown-tile nav__dropdown-tile--addon" role="menuitem">
                <span class="nav__dropdown-tile-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg></span>
                <span class="nav__dropdown-tile-content">
                  <span class="nav__dropdown-tile-title">AI Clinical Assistant <em class="nav__tag">Add-on</em></span>
                  <span class="nav__dropdown-tile-desc">AI Scribe, real-time notes and care plans</span>
                </span>
              </a>
              <a href="/us/platform/medical-billing" class="nav__dropdown-tile nav__dropdown-tile--addon" role="menuitem">
                <span class="nav__dropdown-tile-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><line x1="12" y1="2" x2="12" y2="22"/><path d="M16 6H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H7"/></svg></span>
                <span class="nav__dropdown-tile-content">
                  <span class="nav__dropdown-tile-title">Medical Billing Suite <em class="nav__tag">Add-on</em></span>
                  <span class="nav__dropdown-tile-desc">Capture revenue tied to clinical services</span>
                </span>
              </a>
            </div>
            <div class="nav__dropdown-group">
              <h4 class="nav__dropdown-group-label">AI Assistants</h4>
              <a href="/us/platform/ai-assistants/patient-concierge" class="nav__dropdown-tile" role="menuitem">
                <span class="nav__dropdown-tile-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3z"/><path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg></span>
                <span class="nav__dropdown-tile-content">
                  <span class="nav__dropdown-tile-title">Patient Concierge</span>
                  <span class="nav__dropdown-tile-desc">Your pharmacy&rsquo;s front desk, automated</span>
                </span>
              </a>
              <a href="/us/platform/ai-assistants/admin-clerk" class="nav__dropdown-tile" role="menuitem">
                <span class="nav__dropdown-tile-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg></span>
                <span class="nav__dropdown-tile-content">
                  <span class="nav__dropdown-tile-title">Admin Clerk <em class="nav__tag nav__tag--new">New</em></span>
                  <span class="nav__dropdown-tile-desc">Repetitive admin tasks, eliminated via RPA</span>
                </span>
              </a>
            </div>
            <div class="nav__dropdown-group">
              <h4 class="nav__dropdown-group-label">Foundation</h4>
              <a href="/us/platform/pms-integrations" class="nav__dropdown-tile" role="menuitem">
                <span class="nav__dropdown-tile-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg></span>
                <span class="nav__dropdown-tile-content">
                  <span class="nav__dropdown-tile-title">PMS Integrations</span>
                  <span class="nav__dropdown-tile-desc">Two-way sync with your pharmacy management system</span>
                </span>
              </a>
            </div>
          </div>
        </li>

        <!-- PARTNERS -->
        <li class="nav__item-group" aria-expanded="false">
          <button type="button" class="nav__item-trigger" aria-haspopup="true" aria-expanded="false">Partners</button>
          <div class="nav__dropdown" role="menu">
            <a href="/us/partners/pharmacy-associations" class="nav__dropdown-link" role="menuitem">
              <span class="nav__dropdown-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
              <span class="nav__dropdown-content">
                <span class="nav__dropdown-title">Pharmacy Associations</span>
                <span class="nav__dropdown-desc">State &amp; national association partnerships</span>
              </span>
            </a>
            <a href="/us/pharmacy/networks" class="nav__dropdown-link" role="menuitem">
              <span class="nav__dropdown-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><circle cx="5" cy="5" r="2"/><circle cx="19" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/><line x1="6.5" y1="6.5" x2="10" y2="10"/><line x1="17.5" y1="6.5" x2="14" y2="10"/><line x1="6.5" y1="17.5" x2="10" y2="14"/><line x1="17.5" y1="17.5" x2="14" y2="14"/></svg></span>
              <span class="nav__dropdown-content">
                <span class="nav__dropdown-title">Networks</span>
                <span class="nav__dropdown-desc">Banners, Co-ops &amp; PSAOs</span>
              </span>
            </a>
          </div>
        </li>

        <!-- RESOURCES -->
        <li class="nav__item-group" aria-expanded="false">
          <button type="button" class="nav__item-trigger" aria-haspopup="true" aria-expanded="false">Resources</button>
          <div class="nav__dropdown" role="menu">
            <a href="/us/resources/blog" class="nav__dropdown-link" role="menuitem">
              <span class="nav__dropdown-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></span>
              <span class="nav__dropdown-content">
                <span class="nav__dropdown-title">Blog</span>
                <span class="nav__dropdown-desc">Stories from clinical pharmacy</span>
              </span>
            </a>
            <a href="/us/resources/events" class="nav__dropdown-link" role="menuitem">
              <span class="nav__dropdown-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><circle cx="12" cy="16" r="1.5" fill="currentColor" stroke="none"/></svg></span>
              <span class="nav__dropdown-content">
                <span class="nav__dropdown-title">Events</span>
                <span class="nav__dropdown-desc">Conferences, dinners, in-person</span>
              </span>
            </a>
            <a href="/us/resources/white-papers" class="nav__dropdown-link" role="menuitem">
              <span class="nav__dropdown-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg></span>
              <span class="nav__dropdown-content">
                <span class="nav__dropdown-title">White Papers</span>
                <span class="nav__dropdown-desc">Research and policy briefs</span>
              </span>
            </a>
            <a href="/us/resources/webinars" class="nav__dropdown-link" role="menuitem">
              <span class="nav__dropdown-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg></span>
              <span class="nav__dropdown-content">
                <span class="nav__dropdown-title">Webinars</span>
                <span class="nav__dropdown-desc">Live + on-demand sessions</span>
              </span>
            </a>
            <a href="/us/resources/roi-calculator" class="nav__dropdown-link" role="menuitem">
              <span class="nav__dropdown-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="4" y="3" width="16" height="18" rx="2"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="9.5" y2="11"/><line x1="12" y1="11" x2="13.5" y2="11"/><line x1="15.5" y1="11" x2="16" y2="11"/><line x1="8" y1="15" x2="9.5" y2="15"/><line x1="12" y1="15" x2="13.5" y2="15"/><line x1="15.5" y1="15" x2="16" y2="15"/><line x1="8" y1="19" x2="12" y2="19"/></svg></span>
              <span class="nav__dropdown-content">
                <span class="nav__dropdown-title">ROI Calculator</span>
                <span class="nav__dropdown-desc">Estimate your annual Part B unlock</span>
              </span>
            </a>
          </div>
        </li>

        <!-- ABOUT (no children) -->
        <li><a href="/us/about">About</a></li>
      </ul>
    </nav>
    <div class="nav__cta">
      <div class="region-switch nav__region" data-open="false">
        <button type="button" class="region-switch__trigger" aria-haspopup="true" aria-expanded="false" aria-label="Switch region (currently United States)">
          <span class="region-flag" aria-hidden="true">🇺🇸</span>
          <span class="region-switch__chev" aria-hidden="true">▾</span>
        </button>
        <div class="region-switch__menu" role="menu">
          <a href="/us" class="region-switch__item region-switch__item--current" role="menuitem" aria-current="page" data-set-region="US">
            <span class="region-flag" aria-hidden="true">🇺🇸</span>
            <span>United States</span>
            <span class="region-switch__check" aria-hidden="true">✓</span>
          </a>
          <a href="/ca" class="region-switch__item" role="menuitem" hreflang="en-ca" data-set-region="CA">
            <span class="region-flag" aria-hidden="true">🇨🇦</span>
            <span>Canada</span>
          </a>
        </div>
      </div>
      <a class="btn btn-primary nav__cta-desktop" href="/us/contact">Book a demo <span class="arrow">→</span></a>
      <button type="button" class="nav__hamburger" aria-label="Open menu" aria-controls="mobile-drawer" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile drawer (collapsible groups; tap a section header to
       expand its sub-pages). Uses native <details>/<summary> so the
       behavior is keyboard-accessible without extra JS. -->
  <nav class="nav-drawer" id="mobile-drawer" aria-hidden="true">
    <ul class="nav-drawer__links">
      <li>
        <details class="nav-drawer__group">
          <summary class="nav-drawer__group-trigger">Pharmacy</summary>
          <ul class="nav-drawer__sublinks">
            <li><a href="/us/pharmacy/independents">Independents</a></li>
            <li><a href="/us/pharmacy/enterprises">Enterprises</a></li>
            <li><a href="/us/pharmacy/networks">Networks</a></li>
            <li><a href="/us/pharmacy/specialty">Specialty</a></li>
          </ul>
        </details>
      </li>
      <li>
        <details class="nav-drawer__group">
          <summary class="nav-drawer__group-trigger">Platform</summary>
          <ul class="nav-drawer__sublinks">
            <li><a href="/us/platform/scheduling-queuing">Scheduling &amp; Queueing</a></li>
            <li><a href="/us/platform/patient-intake">Patient Intake Forms</a></li>
            <li><a href="/us/platform/assisted-documentation">Assisted Documentation</a></li>
            <li><a href="/us/platform/messaging-follow-ups">Messaging &amp; Follow-Ups</a></li>
            <li><a href="/us/platform/ai-clinical-assistant">AI Clinical Assistant</a></li>
            <li><a href="/us/platform/medical-billing">Medical Billing Suite</a></li>
            <li><a href="/us/platform/ai-assistants/patient-concierge">Patient Concierge</a></li>
            <li><a href="/us/platform/ai-assistants/admin-clerk">Admin Clerk</a></li>
            <li><a href="/us/platform/pms-integrations">PMS Integrations</a></li>
          </ul>
        </details>
      </li>
      <li>
        <details class="nav-drawer__group">
          <summary class="nav-drawer__group-trigger">Partners</summary>
          <ul class="nav-drawer__sublinks">
            <li><a href="/us/partners/pharmacy-associations">Pharmacy Associations</a></li>
            <li><a href="/us/pharmacy/networks">Networks</a></li>
          </ul>
        </details>
      </li>
      <li>
        <details class="nav-drawer__group">
          <summary class="nav-drawer__group-trigger">Resources</summary>
          <ul class="nav-drawer__sublinks">
            <li><a href="/us/resources/blog">Blog</a></li>
            <li><a href="/us/resources/events">Events</a></li>
            <li><a href="/us/resources/white-papers">White Papers</a></li>
            <li><a href="/us/resources/webinars">Webinars</a></li>
            <li><a href="/us/resources/roi-calculator">ROI Calculator</a></li>
          </ul>
        </details>
      </li>
      <li><a href="/us/about" class="nav-drawer__top-link">About</a></li>
    </ul>
    <a class="btn btn-primary nav-drawer__cta" href="/us/contact">Book a demo <span class="arrow">→</span></a>
  </nav>
</header>

---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="For Independent Pharmacies, MedMe Health"
  description="MedMe is how an independent pharmacy launches a real clinical services program, from credentialing through to paid claims, without hiring IT, building infrastructure, or assembling a billing operation."
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en-us" href="https://medmehealth.com/us/pharmacy/independents" />
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/" />
  </Fragment>

<style>

  /* ============================================================
     INDEPENDENTS sub-page. Leans on the front-page design system
     (.tile, .tile__head, .h-card, .h-display, .kicker, .hero-pill,
     .pill, .tile--navy, .pulse-rings) for everything except this
     page's two unique pieces: the 2-column hero layout and the
     UI-panel mockup visual on the right side of the hero.
     ============================================================ */

  /* ====== HERO: stacked (mockup as fading BG above, text below) ====
     The UI panel sits at the top of the hero, large and slightly
     bleeding past the container width. Its bottom edge fades to
     transparent via mask-image, and the text content overlaps
     UP into that fade zone via negative margin, so the headline
     appears to rise out of the mockup. ============================ */
  .sub-hero {
    background: var(--seashell);
    /* Side padding-inline matches .tile sections; vertical padding
       reduced at top because the mockup brings its own breathing
       room, and bottom is small so the next section starts close. */
    padding: 2rem 1.5rem 3.5rem;
    position: relative;
    overflow: hidden;
  }
  .sub-hero__inner {
    max-width: var(--container);
    margin: 0 auto;
    padding-inline: var(--tile-pad-x);
    position: relative;
  }
  /* VISUAL on top, fully visible, not a fading bg. Stacked
     normally above the text content. */
  .sub-hero__visual {
    position: relative;
    max-width: 1080px;
    margin: 0 auto;
  }
  /* TEXT sits below the visual with normal spacing, no overlap,
     no negative margin. */
  .sub-hero__text {
    text-align: center;
    max-width: 760px;
    margin: 2.5rem auto 0;
    position: relative;
  }
  .sub-hero__breadcrumb {
    font-size: 13px;
    color: rgba(6, 62, 84, 0.55);
    margin-bottom: 1.25rem;
  }
  .sub-hero__breadcrumb a { color: rgba(6, 62, 84, 0.55); text-decoration: none; transition: color 0.18s; }
  .sub-hero__breadcrumb a:hover { color: var(--indigo); }
  .sub-hero__breadcrumb .sep { margin: 0 0.45rem; opacity: 0.4; }
  .sub-hero h1.h-display {
    /* Match the homepage hero h1 sizing so the two heroes feel
       the same weight. */
    font-size: clamp(28px, 4.4vw, 54px);
    line-height: 1.08;
    letter-spacing: -0.028em;
    margin: 0.75rem auto 1rem;
    text-align: center;
    text-wrap: balance;
  }
  .sub-hero__lede {
    font-size: 1.1rem;
    line-height: 1.55;
    color: rgba(6, 62, 84, 0.72);
    margin: 0 auto 1.75rem;
    max-width: 600px;
  }
  .sub-hero__cta {
    display: inline-flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  @media (max-width: 980px) {
    .sub-hero__text { margin-top: 2rem; }
  }
  @media (max-width: 640px) {
    .sub-hero__text { margin-top: 1.5rem; }
  }

  /* ====== HERO HUB + SPOKES (conceptual motion graphic) =========
     A central "Your Pharmacy" hub with 6 service nodes arranged
     in a hexagon around it (Vaccines, MTM, POCT, Test & Treat,
     Smoking Cessation, CCM). Thin spokes connect each service to
     the hub. Animated matcha pulse dots travel from the hub
     outward along each spoke on staggered loops, reinforcing the
     "MedMe lets your pharmacy power all of these clinical
     services" story. The center hub has a continuous soft pulse
     so it feels alive. =============================================*/
  .hero-hub {
    position: relative;
    width: 100%;
    max-width: 820px;
    margin: 0 auto;
    aspect-ratio: 800 / 440;
    display: block;
  }
  .hero-hub .hub-spoke {
    stroke: rgba(6, 62, 84, 0.16);
    stroke-width: 1.25;
    fill: none;
  }
  .hero-hub .hub-pulse {
    fill: var(--matcha);
  }
  /* Service node: white circle with thin indigo border + label. */
  .hero-hub .hub-node circle {
    fill: var(--white);
    stroke: rgba(6, 62, 84, 0.14);
    stroke-width: 1.5;
  }
  .hero-hub .hub-node text {
    fill: var(--indigo);
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    text-anchor: middle;
    dominant-baseline: central;
    letter-spacing: -0.005em;
  }
  /* Center hub: indigo-filled, larger, matcha label, with the
     existing pulse-ring radar treatment from brand.css repurposed
     via a duplicate ring circle that scales out. */
  .hero-hub .hub-center circle.hub-center__bg {
    fill: var(--indigo);
    stroke: var(--indigo);
    stroke-width: 1;
  }
  .hero-hub .hub-center circle.hub-center__ring {
    fill: none;
    stroke: var(--matcha);
    stroke-width: 1.5;
    transform-origin: 400px 220px;
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
    animation: hub-center-ring 2.6s cubic-bezier(0.22, 0.61, 0.36, 1) infinite;
  }
  .hero-hub .hub-center text {
    fill: var(--seashell);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    text-anchor: middle;
  }
  @keyframes hub-center-ring {
    0%   { opacity: 0.55; transform: scale(1); }
    100% { opacity: 0;    transform: scale(2.3); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-hub .hub-center circle.hub-center__ring,
    .hero-hub .hub-pulse { animation: none; opacity: 0; display: none; }
  }
  /* Mobile/narrow-viewport: bump up the SVG content scale so the
     hub labels stay readable. Break out of the inner padding to
     give the SVG more horizontal room AND increase the in-SVG
     text/stroke sizes so labels don't shrink to 5px when the
     SVG is rendered at ~350px wide. */
  @media (max-width: 980px) {
    .sub-hero__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .sub-hero__visual {
      margin-inline: calc(-1 * var(--tile-pad-x));
    }
    .hero-hub .hub-node text  { font-size: 17px; }
    .hero-hub .hub-center text { font-size: 18px; }
  }
  @media (max-width: 700px) {
    .sub-hero { padding-inline: 0.5rem; }
    .sub-hero__visual { margin-inline: 0; }
    .hero-hub .hub-node text  { font-size: 22px; }
    .hero-hub .hub-center text { font-size: 22px; }
    .hero-hub .hub-node circle { stroke-width: 2; }
  }

  /* ====== HOW IT WORKS: 6-feature card grid ===================== */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }
  @media (max-width: 1000px) { .feature-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .feature-grid { grid-template-columns: 1fr; } }
  .feature {
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    /* Explicitly remove the global .feature box-shadow inherited
       from brand.css (var(--shadow-soft)). Cards on this page are
       flat, only the hairline border + hover lift signal the card
       boundary. */
    box-shadow: none;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .feature:hover {
    /* Slight lift + border-tone darkening, no shadow. */
    transform: translateY(-3px);
    border-color: rgba(6, 62, 84, 0.18);
  }
  /* ====== FEATURE MOTION GRAPHICS: one tailored animation per
     card, in the same visual language as the homepage Platform
     bento (.feat-anim--ehr / --sched / --scribe / --billing-rich
     etc.). Each is a ~120px-tall stage with a couple of animated
     elements that loop infinitely. Reduced-motion respected. ===== */
  .feat-graphic {
    width: 100%;
    height: 130px;
    background: rgba(195, 196, 48, 0.06);
    border-radius: 10px;
    margin-bottom: 1.25rem;
    overflow: hidden;
    padding: 18px 20px;
    display: grid;
    place-items: center;
    position: relative;
  }

  /* 1. Schedule: calendar grid with booked slots + a "new" cell
     that pulses every loop (a new booking landing). */
  .fg-cal {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 5px;
    width: 100%;
    max-width: 200px;
  }
  .fg-cal i {
    display: block;
    aspect-ratio: 1;
    border-radius: 3px;
    background: rgba(6, 62, 84, 0.08);
  }
  .fg-cal i.booked { background: rgba(6, 62, 84, 0.22); }
  .fg-cal i.new {
    background: var(--matcha);
    animation: fg-cal-pulse 2.6s ease-in-out infinite;
  }
  @keyframes fg-cal-pulse {
    0%, 30%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(195, 196, 48, 0.55); }
    55% { transform: scale(1.18); box-shadow: 0 0 0 7px rgba(195, 196, 48, 0); }
  }

  /* 2. Intake: three form rows filling in sequence (label + line
     where the line fills left-to-right with matcha). */
  .fg-form { display: flex; flex-direction: column; gap: 10px; width: 100%; max-width: 220px; }
  .fg-form-row { display: flex; align-items: center; gap: 10px; }
  .fg-form-label {
    font-family: var(--font-body);
    font-size: 9.5px;
    font-weight: 600;
    color: rgba(6, 62, 84, 0.55);
    flex-shrink: 0;
    min-width: 42px;
    text-align: right;
  }
  .fg-form-line {
    flex: 1;
    height: 3px;
    background: rgba(6, 62, 84, 0.10);
    border-radius: 2px;
    overflow: hidden;
    position: relative;
  }
  .fg-form-line::after {
    content: "";
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 0;
    background: var(--matcha);
    animation: fg-form-fill 5.4s cubic-bezier(0.65, 0, 0.35, 1) infinite;
  }
  .feat-graphic--intake .fg-form-row:nth-child(1) .fg-form-line::after { animation-delay: 0s; }
  .feat-graphic--intake .fg-form-row:nth-child(2) .fg-form-line::after { animation-delay: 0.9s; }
  .feat-graphic--intake .fg-form-row:nth-child(3) .fg-form-line::after { animation-delay: 1.8s; }
  @keyframes fg-form-fill {
    0%, 5%   { width: 0; }
    18%, 78% { width: 100%; }
    90%, 100% { width: 0; }
  }

  /* 3. Consult: soundwave / audio bars, height bouncing in a
     wave pattern (suggests AI Scribe listening to a consult). */
  .fg-wave {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    height: 56px;
  }
  .fg-wave i {
    display: block;
    width: 4px;
    height: 100%;
    background: var(--matcha);
    border-radius: 2px;
    transform: scaleY(0.3);
    transform-origin: center;
    animation: fg-wave-bar 1.3s ease-in-out infinite;
  }
  .fg-wave i:nth-child(1)  { animation-delay: 0.00s; }
  .fg-wave i:nth-child(2)  { animation-delay: 0.08s; }
  .fg-wave i:nth-child(3)  { animation-delay: 0.16s; }
  .fg-wave i:nth-child(4)  { animation-delay: 0.24s; }
  .fg-wave i:nth-child(5)  { animation-delay: 0.32s; }
  .fg-wave i:nth-child(6)  { animation-delay: 0.40s; }
  .fg-wave i:nth-child(7)  { animation-delay: 0.32s; }
  .fg-wave i:nth-child(8)  { animation-delay: 0.24s; }
  .fg-wave i:nth-child(9)  { animation-delay: 0.16s; }
  .fg-wave i:nth-child(10) { animation-delay: 0.08s; }
  .fg-wave i:nth-child(11) { animation-delay: 0.00s; }
  @keyframes fg-wave-bar {
    0%, 100% { transform: scaleY(0.25); }
    50%      { transform: scaleY(1); }
  }

  /* 4. Document: 4 SOAP rows. Each row has a small letter chip,
     a bar that fills, and a matcha check that fades in. Cascade. */
  .fg-soap { display: flex; flex-direction: column; gap: 6px; width: 100%; max-width: 220px; }
  .fg-soap-row { display: flex; align-items: center; gap: 8px; }
  .fg-soap-letter {
    display: grid;
    place-items: center;
    width: 16px; height: 16px;
    background: rgba(6, 62, 84, 0.10);
    border-radius: 50%;
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 700;
    color: var(--indigo);
    flex-shrink: 0;
  }
  .fg-soap-bar {
    flex: 1;
    height: 4px;
    background: rgba(6, 62, 84, 0.10);
    border-radius: 2px;
    overflow: hidden;
    position: relative;
  }
  .fg-soap-bar::after {
    content: "";
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 0;
    background: var(--matcha);
    animation: fg-soap-fill 5s ease-in-out infinite;
  }
  .fg-soap-check {
    font-size: 11px;
    color: var(--matcha);
    font-weight: 700;
    line-height: 1;
    opacity: 0;
    animation: fg-soap-check 5s ease-in-out infinite;
  }
  .feat-graphic--doc .fg-soap-row:nth-child(1) .fg-soap-bar::after,
  .feat-graphic--doc .fg-soap-row:nth-child(1) .fg-soap-check { animation-delay: 0s; }
  .feat-graphic--doc .fg-soap-row:nth-child(2) .fg-soap-bar::after,
  .feat-graphic--doc .fg-soap-row:nth-child(2) .fg-soap-check { animation-delay: 0.6s; }
  .feat-graphic--doc .fg-soap-row:nth-child(3) .fg-soap-bar::after,
  .feat-graphic--doc .fg-soap-row:nth-child(3) .fg-soap-check { animation-delay: 1.2s; }
  .feat-graphic--doc .fg-soap-row:nth-child(4) .fg-soap-bar::after,
  .feat-graphic--doc .fg-soap-row:nth-child(4) .fg-soap-check { animation-delay: 1.8s; }
  @keyframes fg-soap-fill {
    0%, 5%   { width: 0; }
    25%, 85% { width: 100%; }
    95%, 100% { width: 0; }
  }
  @keyframes fg-soap-check {
    0%, 25% { opacity: 0; transform: scale(0.7); }
    35%, 85% { opacity: 1; transform: scale(1); }
    95%, 100% { opacity: 0; transform: scale(0.7); }
  }

  /* 5. Follow Up: three chat bubbles (out / in / out) sliding
     up one at a time, like a back-and-forth conversation. */
  .fg-msg { display: flex; flex-direction: column; gap: 7px; width: 100%; max-width: 220px; }
  .fg-bubble {
    height: 14px;
    border-radius: 8px;
    opacity: 0;
    animation: fg-bubble-in 3.6s ease-out infinite;
  }
  .fg-bubble--out { background: rgba(6, 62, 84, 0.14); align-self: flex-start; }
  .fg-bubble--in  { background: var(--matcha);       align-self: flex-end;   }
  .feat-graphic--followup .fg-bubble:nth-child(1) { animation-delay: 0s;   width: 60%; }
  .feat-graphic--followup .fg-bubble:nth-child(2) { animation-delay: 0.9s; width: 45%; }
  .feat-graphic--followup .fg-bubble:nth-child(3) { animation-delay: 1.8s; width: 70%; }
  @keyframes fg-bubble-in {
    0%, 5%    { opacity: 0; transform: translateY(8px); }
    20%, 75%  { opacity: 1; transform: translateY(0); }
    90%, 100% { opacity: 0; transform: translateY(-4px); }
  }

  /* 6. Get Paid: 4 status badges appearing sequentially
     (Eligible → Coded → Submitted → Paid), where the final
     "Paid" badge lights matcha. */
  .fg-flow { display: flex; align-items: center; gap: 5px; flex-wrap: wrap; justify-content: center; }
  .fg-step {
    display: inline-block;
    padding: 3px 8px;
    border-radius: 4px;
    background: rgba(6, 62, 84, 0.08);
    color: var(--indigo);
    font-family: var(--font-body);
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.02em;
    opacity: 0;
    animation: fg-step-in 4.4s cubic-bezier(0.22, 0.61, 0.36, 1) infinite;
  }
  .fg-arrow {
    color: rgba(6, 62, 84, 0.30);
    font-size: 10px;
    opacity: 0;
    animation: fg-step-in 4.4s cubic-bezier(0.22, 0.61, 0.36, 1) infinite;
  }
  .feat-graphic--paid .fg-step:nth-of-type(1) { animation-delay: 0s;   }
  .feat-graphic--paid .fg-arrow:nth-of-type(1) { animation-delay: 0.5s; }
  .feat-graphic--paid .fg-step:nth-of-type(2) { animation-delay: 0.6s; }
  .feat-graphic--paid .fg-arrow:nth-of-type(2) { animation-delay: 1.1s; }
  .feat-graphic--paid .fg-step:nth-of-type(3) { animation-delay: 1.2s; }
  .feat-graphic--paid .fg-arrow:nth-of-type(3) { animation-delay: 1.7s; }
  .feat-graphic--paid .fg-step:nth-of-type(4) {
    animation-delay: 1.8s;
    background: var(--matcha);
  }
  @keyframes fg-step-in {
    0%, 5%    { opacity: 0; transform: translateX(-6px); }
    18%, 78%  { opacity: 1; transform: translateX(0); }
    90%, 100% { opacity: 0; transform: translateX(4px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .fg-cal i.new,
    .fg-form-line::after, .fg-wave i,
    .fg-soap-bar::after, .fg-soap-check,
    .fg-bubble, .fg-step, .fg-arrow {
      animation: none !important;
      opacity: 1;
      width: auto;
      transform: none;
    }
    .fg-form-line::after, .fg-soap-bar::after { width: 100%; }
    .fg-wave i { transform: scaleY(0.6); }
  }

  .feature-num {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--matcha);
    margin-bottom: 0.75rem;
  }
  .feature h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.15rem;
    margin: 0 0 0.6rem;
    color: var(--indigo);
    letter-spacing: -0.005em;
  }
  .feature p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: rgba(6, 62, 84, 0.72);
  }

  /* ====== STORY SECTION BG PATTERN: animated dot grid + scan wave.
     Two layers:
     1) base: faint regular matcha dot grid (always visible)
     2) ::before: a brighter dot grid masked by a diagonal "wave"
        whose mask-position animates across, lighting up dots
        only where the wave currently sits.
     mask-image on the container softens the section's left + right
     edges so the grid doesn't end with a hard cutoff. ============== */
  .story-bg-pattern {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    /* Faint always-visible dot grid */
    background-image: radial-gradient(circle, rgba(195, 196, 48, 0.08) 1.5px, transparent 1.6px);
    background-size: 38px 38px;
    background-position: center;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%);
            mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%);
  }
  .story-bg-pattern::before {
    /* Brighter dot grid (same alignment as base), visible only
       where the diagonal mask-wave currently sits. */
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(195, 196, 48, 0.32) 1.8px, transparent 1.9px);
    background-size: 38px 38px;
    background-position: center;
    /* The mask itself is a narrow diagonal band of opacity; sliding
       its position across the element makes the visible band sweep. */
    -webkit-mask-image: linear-gradient(115deg, transparent 38%, #000 50%, transparent 62%);
            mask-image: linear-gradient(115deg, transparent 38%, #000 50%, transparent 62%);
    -webkit-mask-size: 220% 220%;
            mask-size: 220% 220%;
    -webkit-mask-repeat: no-repeat;
            mask-repeat: no-repeat;
    animation: dot-scan 7s linear infinite;
  }
  @keyframes dot-scan {
    from {
      -webkit-mask-position: 160% 160%;
              mask-position: 160% 160%;
    }
    to {
      -webkit-mask-position: -60% -60%;
              mask-position: -60% -60%;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .story-bg-pattern::before { animation: none; opacity: 0; }
  }

  /* ====== STORY / VALUE-BLOCKS: 2-column (navy theme) =========== */
  .story-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: 3rem;
    align-items: center;
  }
  @media (max-width: 980px) { .story-grid { grid-template-columns: 1fr; gap: 2rem; } }
  .story-quote {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2vw, 1.6rem);
    line-height: 1.4;
    font-weight: 500;
    /* Navy section, so quote reads in seashell. */
    color: var(--seashell);
    letter-spacing: -0.012em;
    /* Reset browser blockquote margins, keep visual rhythm. */
    margin: 1rem 0 1.25rem;
  }
  /* Inner <p> wraps the quote text so text-wrap: pretty applies.
     Reset its margins so it doesn't push the attribution down. */
  .story-quote p { margin: 0; }
  .story-attribution {
    font-size: 0.875rem;
    color: rgba(250, 249, 245, 0.60);
    margin: 0;
  }
  .value-blocks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  @media (max-width: 600px) { .value-blocks { grid-template-columns: 1fr; } }
  /* Value blocks sit on navy. Subtle translucent-seashell fill +
     hairline border. Each block also runs a sequenced light-up
     animation (matcha border + soft halo) that cycles through the
     4 blocks in the order they appear in markup. */
  .value-block {
    background: rgba(250, 249, 245, 0.05);
    border: 1px solid rgba(250, 249, 245, 0.12);
    border-radius: var(--radius-md);
    padding: 1.4rem 1.5rem;
    transition: border-color 0.35s ease, box-shadow 0.35s ease;
    animation: value-block-light 6s ease-in-out infinite;
  }
  /* Stagger so the matcha light walks Credentialing → Claims →
     Honest timelines → Denials worked (matches markup order). */
  .value-block:nth-child(1) { animation-delay: 0s;   }
  .value-block:nth-child(2) { animation-delay: 1.5s; }
  .value-block:nth-child(3) { animation-delay: 3s;   }
  .value-block:nth-child(4) { animation-delay: 4.5s; }
  @keyframes value-block-light {
    0%, 18%, 100% {
      border-color: rgba(250, 249, 245, 0.12);
      box-shadow: none;
    }
    4%, 14% {

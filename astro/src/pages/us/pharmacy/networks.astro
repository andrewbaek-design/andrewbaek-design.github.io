---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="For Pharmacy Networks, MedMe Health"
  description="MedMe gives pharmacy networks a clinical services platform members actually adopt, and gives the central organization the cross-network reporting that strengthens its value to membership."
  showAnnouncement={false}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en-us" href="https://medmehealth.com/us/pharmacy/networks" />
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/pharmacy/networks" />
  </Fragment>

<style>

  /* ============================================================
     NETWORKS sub-page. Leans on the front-page design system
     (.tile, .tile__head, .h-display, .kicker, .pill, .tile--navy).
     Page-specific bits: network rollup hero motion graphic
     (many member nodes consolidating into one), per-card motion
     in the Value to Network grid, navy story band with four
     commercial model value blocks.
     ============================================================ */

  /* ====== HERO: stacked (motion graphic above text) ============= */
  .sub-hero {
    background: var(--seashell);
    padding: 2rem 1.5rem 3.5rem;
    position: relative;
    overflow: hidden;
  }
  .sub-hero__inner {
    max-width: var(--container);
    margin: 0 auto;
    padding-inline: var(--tile-pad-x);
    position: relative;
  }
  .sub-hero__visual {
    position: relative;
    max-width: 1080px;
    margin: 0 auto;
  }
  .sub-hero__text {
    text-align: center;
    max-width: 760px;
    margin: 1rem auto 0;
    position: relative;
  }
  .sub-hero h1.h-display {
    font-size: clamp(28px, 4.4vw, 54px);
    line-height: 1.08;
    letter-spacing: -0.028em;
    margin: 0.75rem auto 1rem;
    text-align: center;
    text-wrap: balance;
  }
  .sub-hero__lede {
    font-size: 1.1rem;
    line-height: 1.55;
    color: rgba(6, 62, 84, 0.72);
    margin: 0 auto 1.75rem;
    max-width: 640px;
  }
  .sub-hero__cta {
    display: inline-flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  @media (max-width: 980px) { .sub-hero__text { margin-top: 0.75rem; } }
  @media (max-width: 640px) { .sub-hero__text { margin-top: 0.5rem; } }

  /* ====== HERO ROLLUP GRAPHIC ====================================
     A 6x4 grid of small member-store dots flowing rightward into
     a single rollup card on the right. Visualises many member
     locations consolidating into one cross-network view. Reduced-
     motion respected. */
  .hero-roll {
    position: relative;
    width: 100%;
    max-width: 820px;
    margin: 0 auto;
    aspect-ratio: 800 / 440;
    display: block;
  }
  .hero-roll .roll-mesh circle {
    fill: var(--white);
    stroke: rgba(6, 62, 84, 0.18);
    stroke-width: 1.25;
  }
  .hero-roll .roll-mesh .roll-active {
    fill: var(--matcha);
    stroke: var(--matcha);
    animation: roll-blink 3.2s ease-in-out infinite;
  }
  @keyframes roll-blink {
    0%, 100% { opacity: 0.25; }
    50%      { opacity: 1; }
  }
  .hero-roll .roll-mesh .roll-a-1 { animation-delay: 0s; }
  .hero-roll .roll-mesh .roll-a-2 { animation-delay: 0.3s; }
  .hero-roll .roll-mesh .roll-a-3 { animation-delay: 0.6s; }
  .hero-roll .roll-mesh .roll-a-4 { animation-delay: 0.9s; }
  .hero-roll .roll-mesh .roll-a-5 { animation-delay: 1.2s; }
  .hero-roll .roll-pulse { fill: var(--matcha); }
  .hero-roll .roll-card {
    fill: var(--white);
    stroke: rgba(6, 62, 84, 0.14);
    stroke-width: 1.5;
  }
  .hero-roll .roll-card-ring {
    fill: none;
    stroke: var(--matcha);
    stroke-width: 1.5;
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
    animation: roll-card-ring 2.8s cubic-bezier(0.22, 0.61, 0.36, 1) infinite;
  }
  @keyframes roll-card-ring {
    0%   { opacity: 0.55; transform: scale(1); }
    100% { opacity: 0;    transform: scale(1.6); }
  }
  .hero-roll .roll-card-label {
    fill: var(--indigo);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    text-anchor: middle;
  }
  .hero-roll .roll-card-stat {
    fill: rgba(6, 62, 84, 0.65);
    font-family: var(--font-display);
    font-size: 11px;
    text-anchor: middle;
  }
  .hero-roll .roll-bar {
    fill: var(--matcha);
    transform-origin: left center;
  }
  .hero-roll .roll-bar-bg {
    fill: rgba(6, 62, 84, 0.08);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-roll .roll-mesh .roll-active,
    .hero-roll .roll-card-ring,
    .hero-roll .roll-pulse { animation: none; opacity: 0; display: none; }
  }
  @media (max-width: 980px) {
    .sub-hero__visual { margin-inline: calc(-1 * var(--tile-pad-x)); }
    .hero-roll .roll-card-label { font-size: 15px; }
    .hero-roll .roll-card-stat { font-size: 13px; }
  }
  @media (max-width: 700px) {
    .sub-hero { padding-inline: 0.5rem; }
    .sub-hero__visual { margin-inline: 0; }
    .hero-roll .roll-card-label { font-size: 17px; }
    .hero-roll .roll-card-stat { font-size: 14px; }
  }

  /* ====== VALUE TO NETWORK: 3-feature card grid w/ motion ======= */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }
  @media (max-width: 1000px) { .feature-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .feature-grid { grid-template-columns: 1fr; } }
  .feature {
    /* Background + border now come from the global .tile--light rules in
       brand.css (warm-tone alternation, no borders). Only the radius,
       padding, and hover transform stay page-local. */
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: none;
    transition: transform 0.25s ease;
  }
  .feature:hover {
    transform: translateY(-3px);
  }
  .feat-graphic {
    width: 100%;
    height: 130px;
    background: rgba(195, 196, 48, 0.06);
    border-radius: 10px;
    margin-bottom: 1.25rem;
    overflow: hidden;
    position: relative;
  }
  /* Variant used by the Member Recruitment and Advocacy sections (no live
     motion graphic in those cards, just a centered icon). Inherits the
     same matcha-tinted tile so the row reads visually consistent with
     the animated Value-to-Network cards below it. */
  .feat-graphic--icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--indigo);
  }
  .feat-graphic--icon svg {
    width: 64px;
    height: 64px;
    display: block;
  }
  /* Scene variant: fills the tile width with a small illustration.
     Each scene is uniquely identified by `data-scene="..."` so the
     animation rules below can target the right inner SVG elements
     without touching the markup. */
  .feat-graphic--scene {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.75rem;
  }
  .feat-graphic--scene svg {
    width: 100%;
    height: auto;
    max-width: 100%;
    display: block;
    overflow: visible;
  }
  .feat-graphic--scene svg * {
    transform-box: fill-box;
  }

  /* ============================================================
     MOTION GRAPHICS (Member Recruitment + Advocacy scenes)
     Six infinite, subtle loops. Each one picks the most expressive
     element in its illustration and animates it.
     ============================================================ */

  /* 1 — Platform consolidation: scattered tool tiles blink in a wave,
        suggesting many tools collapsing into the central MedMe tile. */
  [data-scene="platform"] svg > g:first-of-type rect {
    transform-origin: center;
    animation: pc-tile-blink 3.6s ease-in-out infinite;
  }
  [data-scene="platform"] svg > g:first-of-type rect:nth-child(1) { animation-delay: 0s;   }
  [data-scene="platform"] svg > g:first-of-type rect:nth-child(2) { animation-delay: 0.3s; }
  [data-scene="platform"] svg > g:first-of-type rect:nth-child(3) { animation-delay: 0.6s; }
  [data-scene="platform"] svg > g:first-of-type rect:nth-child(4) { animation-delay: 0.9s; }
  [data-scene="platform"] svg > g:first-of-type rect:nth-child(5) { animation-delay: 1.2s; }
  @keyframes pc-tile-blink {
    0%, 100% { opacity: 0.35; transform: scale(0.92); }
    50%      { opacity: 1;    transform: scale(1); }
  }

  /* 2 — Get paid: claim rows highlight in sequence, then the PAID
        stamp scales up to suggest the payment landing. */
  [data-scene="paid"] svg > g:first-of-type rect {
    animation: pc-claim-flash 2.6s ease-in-out infinite;
    transform-origin: center;
  }
  [data-scene="paid"] svg > g:first-of-type rect:nth-child(1) { animation-delay: 0s;   }
  [data-scene="paid"] svg > g:first-of-type rect:nth-child(2) { animation-delay: 0.3s; }
  [data-scene="paid"] svg > g:first-of-type rect:nth-child(3) { animation-delay: 0.6s; }
  @keyframes pc-claim-flash {
    0%, 80%, 100% { opacity: 1; }
    20%, 40%      { opacity: 0.55; }
  }
  [data-scene="paid"] svg > circle {
    transform-origin: center;
    animation: pc-paid-pulse 2.6s ease-out infinite;
  }
  @keyframes pc-paid-pulse {
    0%, 60% { transform: scale(1); filter: drop-shadow(0 0 0 rgba(195,196,48,0)); }
    70%     { transform: scale(1.12); filter: drop-shadow(0 0 10px rgba(195,196,48,0.5)); }
    100%    { transform: scale(1); filter: drop-shadow(0 0 0 rgba(195,196,48,0)); }
  }

  /* 3 — Scale without hiring: AI agent dots pulse outward with a glow,
        dashed lines flow toward the pharmacist (offset drift). */
  [data-scene="scale"] svg > g:nth-of-type(2) circle {
    transform-origin: center;
    animation: pc-ai-pulse 1.8s ease-in-out infinite;
  }
  [data-scene="scale"] svg > g:nth-of-type(2) circle:nth-child(1) { animation-delay: 0s;   }
  [data-scene="scale"] svg > g:nth-of-type(2) circle:nth-child(2) { animation-delay: 0.3s; }
  [data-scene="scale"] svg > g:nth-of-type(2) circle:nth-child(3) { animation-delay: 0.6s; }
  @keyframes pc-ai-pulse {
    0%, 100% { transform: scale(1);    filter: drop-shadow(0 0 0  rgba(195,196,48,0));   }
    50%      { transform: scale(1.15); filter: drop-shadow(0 0 8px rgba(195,196,48,0.6)); }
  }
  [data-scene="scale"] svg > g:first-of-type path {
    stroke-dasharray: 3 3;
    animation: pc-dash-flow 2s linear infinite;
  }
  @keyframes pc-dash-flow {
    to { stroke-dashoffset: -12; }
  }

  /* 4 — Clinical service evidence: bars grow from baseline in a wave,
        trendline dots breathe. */
  [data-scene="evidence"] svg > g:first-of-type rect {
    transform-origin: bottom;
    animation: pc-bar-grow 3s ease-in-out infinite;
  }
  [data-scene="evidence"] svg > g:first-of-type rect:nth-child(1) { animation-delay: 0s;   }
  [data-scene="evidence"] svg > g:first-of-type rect:nth-child(2) { animation-delay: 0.15s;}
  [data-scene="evidence"] svg > g:first-of-type rect:nth-child(3) { animation-delay: 0.3s; }
  [data-scene="evidence"] svg > g:first-of-type rect:nth-child(4) { animation-delay: 0.45s;}
  [data-scene="evidence"] svg > g:first-of-type rect:nth-child(5) { animation-delay: 0.6s; }
  [data-scene="evidence"] svg > g:first-of-type rect:nth-child(6) { animation-delay: 0.75s;}
  @keyframes pc-bar-grow {
    0%, 100% { transform: scaleY(0.5); opacity: 0.6; }
    50%      { transform: scaleY(1);   opacity: 1;   }
  }
  [data-scene="evidence"] svg > g:nth-of-type(2) circle {
    transform-origin: center;
    animation: pc-dot-pulse 2s ease-in-out infinite;
  }
  @keyframes pc-dot-pulse {
    0%, 100% { transform: scale(1);   }
    50%      { transform: scale(1.5); }
  }

  /* 5 — Payer-ready billing data: mini bars pulse, side badges flash. */
  [data-scene="billing"] svg > g:first-of-type rect {
    transform-origin: bottom;
    animation: pc-mini-bar 2.4s ease-in-out infinite;
  }
  [data-scene="billing"] svg > g:first-of-type rect:nth-child(1) { animation-delay: 0s;    }
  [data-scene="billing"] svg > g:first-of-type rect:nth-child(2) { animation-delay: 0.15s; }
  [data-scene="billing"] svg > g:first-of-type rect:nth-child(3) { animation-delay: 0.3s;  }
  [data-scene="billing"] svg > g:first-of-type rect:nth-child(4) { animation-delay: 0.45s; }
  [data-scene="billing"] svg > g:first-of-type rect:nth-child(5) { animation-delay: 0.6s;  }
  [data-scene="billing"] svg > g:first-of-type rect:nth-child(6) { animation-delay: 0.75s; }
  [data-scene="billing"] svg > g:first-of-type rect:nth-child(7) { animation-delay: 0.9s;  }
  [data-scene="billing"] svg > g:first-of-type rect:nth-child(8) { animation-delay: 1.05s; }
  @keyframes pc-mini-bar {
    0%, 100% { transform: scaleY(0.65); }
    50%      { transform: scaleY(1);    }
  }
  [data-scene="billing"] svg > g:nth-of-type(2) rect {
    animation: pc-badge-flash 3.6s ease-in-out infinite;
  }
  [data-scene="billing"] svg > g:nth-of-type(2) rect:nth-child(1) { animation-delay: 0s; }
  [data-scene="billing"] svg > g:nth-of-type(2) rect:nth-child(2) { animation-delay: 0.4s; }
  [data-scene="billing"] svg > g:nth-of-type(2) rect:nth-child(3) { animation-delay: 0.8s; }
  @keyframes pc-badge-flash {
    0%, 100% { fill: rgba(195,196,48,0.16); }
    50%      { fill: rgba(195,196,48,0.45); }
  }

  /* 6 — De-identified: shield checkmark pulses, mask dots shimmer in
        a left-to-right wave, aggregate badges fade. */
  [data-scene="shield"] svg > path:nth-of-type(2) {
    transform-origin: center;
    animation: pc-check-pulse 2.2s ease-in-out infinite;
  }
  @keyframes pc-check-pulse {
    0%, 100% { transform: scale(1);    opacity: 0.85; }
    50%      { transform: scale(1.12); opacity: 1;    }
  }
  [data-scene="shield"] svg > g:nth-of-type(2) circle {
    animation: pc-mask-shimmer 2.8s ease-in-out infinite;
  }
  [data-scene="shield"] svg > g:nth-of-type(2) circle:nth-child(4n+1) { animation-delay: 0s; }
  [data-scene="shield"] svg > g:nth-of-type(2) circle:nth-child(4n+2) { animation-delay: 0.2s; }
  [data-scene="shield"] svg > g:nth-of-type(2) circle:nth-child(4n+3) { animation-delay: 0.4s; }
  [data-scene="shield"] svg > g:nth-of-type(2) circle:nth-child(4n)   { animation-delay: 0.6s; }
  @keyframes pc-mask-shimmer {
    0%, 100% { opacity: 0.25; }
    50%      { opacity: 0.7;  }
  }
  [data-scene="shield"] svg > g:nth-of-type(3) rect {
    animation: pc-badge-flash 3s ease-in-out infinite;
  }
  [data-scene="shield"] svg > g:nth-of-type(3) rect:nth-child(1) { animation-delay: 0s;   }
  [data-scene="shield"] svg > g:nth-of-type(3) rect:nth-child(2) { animation-delay: 0.3s; }
  [data-scene="shield"] svg > g:nth-of-type(3) rect:nth-child(3) { animation-delay: 0.6s; }

  /* Reduced-motion: kill all scene animations. */
  @media (prefers-reduced-motion: reduce) {
    [data-scene] svg * {
      animation: none !important;
    }
  }

  /* Warm-tone alternation now lives in brand.css and applies site-wide
     to every `.tile--light` card (no border, var(--tile-card-bg) fill).
     This page just opts specific sections in via the `tile--alt` class. */
  .feature h3 {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--indigo);
    letter-spacing: -0.012em;
  }
  .feature p { margin: 0; color: rgba(6, 62, 84, 0.72); line-height: 1.55; }

  /* 1. Visibility: dashboard with chart bars + sweep line */
  .feat-vis {
    padding: 18px 22px;
    display: flex;
    align-items: flex-end;
    gap: 6px;
    position: relative;
  }
  .feat-vis .vis-bar {
    flex: 1;
    background: rgba(195, 196, 48, 0.25);
    border-radius: 2px 2px 0 0;
    animation: vis-grow 4s ease-in-out infinite;
  }
  .feat-vis .vis-bar:nth-child(1) { height: 30%; animation-delay: 0s; }
  .feat-vis .vis-bar:nth-child(2) { height: 55%; animation-delay: 0.15s; }
  .feat-vis .vis-bar:nth-child(3) { height: 40%; animation-delay: 0.3s; }
  .feat-vis .vis-bar:nth-child(4) { height: 70%; animation-delay: 0.45s; }
  .feat-vis .vis-bar:nth-child(5) { height: 50%; animation-delay: 0.6s; }
  .feat-vis .vis-bar:nth-child(6) { height: 80%; animation-delay: 0.75s; }
  .feat-vis .vis-bar:nth-child(7) { height: 65%; animation-delay: 0.9s; }
  .feat-vis .vis-bar:nth-child(8) { height: 90%; animation-delay: 1.05s; }
  @keyframes vis-grow {
    0%, 100% { background: rgba(195, 196, 48, 0.25); transform: scaleY(0.9); }
    50%      { background: var(--matcha);             transform: scaleY(1); }
  }

  /* 2. Standardization: 3 row blueprints aligning identically */
  .feat-std {
    padding: 16px 22px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
  }
  .feat-std .std-row {
    display: flex;
    gap: 6px;
    align-items: center;
  }
  .feat-std .std-step {
    height: 10px;
    background: rgba(195, 196, 48, 0.3);
    border-radius: 2px;
    animation: std-align 3.6s ease-in-out infinite;
  }
  .feat-std .std-row:nth-child(1) .std-step:nth-child(1) { width: 20px; animation-delay: 0s; }
  .feat-std .std-row:nth-child(1) .std-step:nth-child(2) { width: 30px; animation-delay: 0.1s; }
  .feat-std .std-row:nth-child(1) .std-step:nth-child(3) { width: 24px; animation-delay: 0.2s; }
  .feat-std .std-row:nth-child(2) .std-step:nth-child(1) { width: 20px; animation-delay: 0.4s; }
  .feat-std .std-row:nth-child(2) .std-step:nth-child(2) { width: 30px; animation-delay: 0.5s; }
  .feat-std .std-row:nth-child(2) .std-step:nth-child(3) { width: 24px; animation-delay: 0.6s; }
  .feat-std .std-row:nth-child(3) .std-step:nth-child(1) { width: 20px; animation-delay: 0.8s; }
  .feat-std .std-row:nth-child(3) .std-step:nth-child(2) { width: 30px; animation-delay: 0.9s; }
  .feat-std .std-row:nth-child(3) .std-step:nth-child(3) { width: 24px; animation-delay: 1.0s; }
  @keyframes std-align {
    0%, 100% { background: rgba(195, 196, 48, 0.3); }
    50%      { background: var(--matcha); }
  }

  /* 3. Commercial: stacked dollar/value tags cycling */
  .feat-comm {
    padding: 14px 22px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
  .feat-comm .comm-tag {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--white);
    border: 1px solid rgba(195, 196, 48, 0.3);
    padding: 4px 12px;
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    color: var(--indigo);
    opacity: 0;
    transform: translateY(8px);
    animation: comm-show 4s ease-in-out infinite;
  }
  .feat-comm .comm-tag:nth-child(1) { animation-delay: 0s; }
  .feat-comm .comm-tag:nth-child(2) { animation-delay: 1.3s; }
  .feat-comm .comm-tag:nth-child(3) { animation-delay: 2.6s; }
  .feat-comm .comm-tag .comm-dot {
    width: 6px;
    height: 6px;
    background: var(--matcha);
    border-radius: 50%;
  }
  @keyframes comm-show {
    0%, 70%, 100% { opacity: 0; transform: translateY(8px); }
    10%, 30%      { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .feat-vis .vis-bar,
    .feat-std .std-step,
    .feat-comm .comm-tag { animation: none; opacity: 1; transform: none; }
  }

  /* ====== NCAP PARTNER CASE STUDY =============================== */
  .case-banner {
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.75rem;
    margin: 2rem 0 1.5rem;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 2fr);
    gap: 2rem;
    align-items: center;
  }
  @media (max-width: 800px) {
    .case-banner { grid-template-columns: 1fr; gap: 1.5rem; }
  }
  .case-banner__brand { display: flex; flex-direction: column; gap: 4px; }
  .case-banner__brand-label {
    font-size: 11px;
    font-weight: 600;
    color: rgba(6, 62, 84, 0.5);
    letter-spacing: 0.06em;
    text-transform: none;
  }
  .case-banner__brand-pair {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--indigo);
    letter-spacing: -0.012em;
  }
  .case-banner__brand-pair .x {
    color: var(--matcha);
    margin: 0 0.25rem;
    font-weight: 400;
  }
  .case-banner__brand-sub {
    font-size: 0.85rem;
    color: rgba(6, 62, 84, 0.62);
  }
  .case-banner__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    padding-left: 1.5rem;
    border-left: 1px solid rgba(6, 62, 84, 0.08);
  }
  @media (max-width: 800px) {

---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TrustBandUs from '../../../components/TrustBandUs.astro';
---
<BaseLayout
  title="Patient Intake Forms, MedMe Health"
  description="Save time during the consult by capturing patient info, consent, and eligibility before or after the consult, auto-mapped to state-specific PDF forms."
  showAnnouncement={false}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en-us" href="https://medmehealth.com/us/platform/patient-intake" />
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/" />
  </Fragment>

<style>

  /* ============================================================
     PATIENT INTAKE FORMS product page. Each of the four core
     features gets its own section, but the layout style varies
     so the page reads as a dynamic walk through capabilities
     instead of four identical card grids:
       - Digital Intake : 3 light cards (icons)
       - Eligibility     : 3 dark cards (matcha tag)
       - State PDFs      : compact state-code chip grid
       - Patient Records : 3 numbered-step cards
     The matcha PDF callout band sits right before the closing
     CTA as a final emphasis on the state-specific differentiator.
     ============================================================ */

  /* ====== SUB-HERO ============================================= */
  .sub-hero { background: var(--seashell); padding: 2rem 1.5rem 3.5rem; position: relative; overflow: hidden; }
  .sub-hero__inner { max-width: var(--container); margin: 0 auto; padding-inline: var(--tile-pad-x); position: relative; }
  .sub-hero__bg {
    position: relative; max-width: 1120px; margin: 0 auto;
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 45%, rgba(0,0,0,0) 95%);
            mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 45%, rgba(0,0,0,0) 95%);
    pointer-events: none;
  }
  .sub-hero__bg img { display: block; width: 100%; max-width: 1080px; height: auto; margin: 0 auto; }
  .sub-hero__text { text-align: center; max-width: 820px; margin: -140px auto 0; position: relative; z-index: 2; }
  .sub-hero h1.h-display { font-size: clamp(28px, 4.4vw, 54px); line-height: 1.08; letter-spacing: -0.028em; margin: 0.75rem auto 1rem; text-align: center; text-wrap: balance; }
  .sub-hero h1.h-display .accent { color: var(--matcha); }
  .sub-hero__lede { font-size: 1.1rem; line-height: 1.55; color: rgba(6, 62, 84, 0.72); margin: 0 auto 1.75rem; max-width: 720px; }
  .sub-hero__cta { display: inline-flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
  @media (max-width: 980px) { .sub-hero__text { margin-top: -90px; } }
  @media (max-width: 640px) { .sub-hero__text { margin-top: -60px; } }

  /* ====== LIGHT CARD GRID (Digital Intake) ===================== */
  .light-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 1000px) { .light-grid { grid-template-columns: 1fr; } }
  .light-card { background: var(--white); border: 1px solid rgba(6,62,84,0.08); border-radius: var(--radius-lg); padding: 1.75rem; transition: transform 0.25s ease, border-color 0.25s ease; }
  .light-card:hover { transform: translateY(-3px); border-color: rgba(6,62,84,0.18); }
  .light-card__icon { display: inline-flex; width: 44px; height: 44px; align-items: center; justify-content: center; background: rgba(195, 196, 48, 0.14); border-radius: 10px; margin-bottom: 1rem; }
  .light-card__icon svg { width: 22px; height: 22px; stroke: var(--matcha); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .light-card h3 { margin: 0 0 0.5rem; font-size: 1.1rem; font-weight: 600; color: var(--indigo); letter-spacing: -0.012em; }
  .light-card p { margin: 0; color: rgba(6,62,84,0.72); line-height: 1.55; font-size: 0.95rem; }

  /* ====== DARK CARD GRID (Eligibility Screening) =============== */
  .dark-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 1000px) { .dark-grid { grid-template-columns: 1fr; } }
  .dark-card { background: var(--indigo); color: var(--seashell); border: 1px solid rgba(195,196,48,0.18); border-radius: var(--radius-lg); padding: 1.75rem; transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease; box-shadow: 0 12px 32px rgba(6,62,84,0.08); }
  .dark-card:hover { transform: translateY(-3px); border-color: var(--matcha); box-shadow: 0 16px 38px rgba(6,62,84,0.16); }
  .dark-card__tag { font-size: 11px; color: var(--matcha); font-weight: 700; letter-spacing: 0.06em; margin-bottom: 0.6rem; display: inline-block; }
  .dark-card h3 { margin: 0 0 0.5rem; font-size: 1.1rem; font-weight: 600; color: var(--seashell); letter-spacing: -0.012em; }
  .dark-card p { margin: 0; color: rgba(250,249,245,0.78); line-height: 1.55; font-size: 0.95rem; }

  /* ====== STATE CHIPS GRID (State-Specific PDFs) =============== */
  .chip-row { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; max-width: 880px; margin: 0 auto; }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.1);
    border-radius: 999px;
    padding: 10px 18px;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--indigo);
    letter-spacing: 0.01em;
    transition: background 0.4s ease, border-color 0.4s ease, transform 0.25s ease;
    animation: chip-cycle 12s ease-in-out infinite;
  }
  .chip::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--matcha);
    flex-shrink: 0;
  }
  .chip:nth-child(1)  { animation-delay: 0s; }
  .chip:nth-child(2)  { animation-delay: 0.4s; }
  .chip:nth-child(3)  { animation-delay: 0.8s; }
  .chip:nth-child(4)  { animation-delay: 1.2s; }
  .chip:nth-child(5)  { animation-delay: 1.6s; }
  .chip:nth-child(6)  { animation-delay: 2.0s; }
  .chip:nth-child(7)  { animation-delay: 2.4s; }
  .chip:nth-child(8)  { animation-delay: 2.8s; }
  .chip:nth-child(9)  { animation-delay: 3.2s; }
  .chip:nth-child(10) { animation-delay: 3.6s; }
  .chip:nth-child(11) { animation-delay: 4.0s; }
  .chip:nth-child(12) { animation-delay: 4.4s; }
  @keyframes chip-cycle {
    0%, 8%, 100% { background: var(--white); border-color: rgba(6, 62, 84, 0.1); transform: scale(1); }
    3%           { background: rgba(195, 196, 48, 0.15); border-color: var(--matcha); transform: scale(1.04); }
  }
  @media (prefers-reduced-motion: reduce) { .chip { animation: none; } }
  .chip-foot {
    margin: 1.75rem auto 0;
    text-align: center;
    font-size: 0.95rem;
    color: rgba(6, 62, 84, 0.6);
    max-width: 640px;
    text-wrap: pretty;
  }

  /* ====== MATCHA PDF CALLOUT BAND (final emphasis above CTA) === */
  .pdf-band { background: rgba(195, 196, 48, 0.06); border: 1px solid rgba(195, 196, 48, 0.22); border-radius: 24px; padding: 2.5rem; display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: center; position: relative; overflow: hidden; }
  .pdf-band::before {
    content: "";
    position: absolute;
    top: -60px; right: -60px;
    width: 220px; height: 220px;
    background: var(--matcha);
    opacity: 0.1;
    border-radius: 50%;
    pointer-events: none;
  }
  @media (max-width: 800px) {
    .pdf-band { grid-template-columns: 1fr; padding: 1.75rem; text-align: left; }
  }
  .pdf-band__text { max-width: 640px; position: relative; z-index: 1; }
  .pdf-band__kicker { font-size: 11px; color: var(--matcha); font-weight: 700; letter-spacing: 0.08em; margin-bottom: 0.5rem; display: inline-block; }
  .pdf-band h3 { margin: 0 0 0.5rem; font-size: 1.4rem; font-weight: 700; color: var(--indigo); letter-spacing: -0.018em; }
  .pdf-band p { margin: 0; font-size: 1rem; line-height: 1.55; color: rgba(6,62,84,0.78); text-wrap: pretty; }
  .pdf-band__cta { position: relative; z-index: 1; }
</style>

<!-- ============= 1. SUB-HERO (real Patient Intake SVG mockup as BG) ============= -->
<section class="sub-hero" aria-label="Hero">
  <div class="sub-hero__inner">
    <div class="sub-hero__bg" aria-hidden="true">
      <img src="/assets/patient-intake-mockup.svg" alt="" />
    </div>
    <div class="sub-hero__text">
      <h1 class="h-display">Collect patient info,<br><span class="accent">asynchronously.</span></h1>
      <p class="sub-hero__lede">Save time during the consult by capturing patient info, consent, and eligibility before or after the consult, auto-mapped to state-specific PDF forms.</p>
      <div class="sub-hero__cta">
        <a class="pill pill--solid" href="/us/contact">Book a demo <span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>

<TrustBandUs />

<!-- ============= 2. DIGITAL INTAKE (light cards with icons) ============= -->
<section class="tile tile--light" aria-label="Digital intake">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">Digital Intake</span>
      <h2 class="h-display">Digital intake<br>made easy.</h2>
      <p class="lead">Replace manual paper forms with digital intake that streamlines data capture. Patients complete forms online, reducing delays and ensuring your team gets the information they need before the consult starts.</p>
    </div>
    <div class="light-grid">
      <article class="light-card">
        <span class="light-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>
        </span>
        <h3>Mobile-first forms</h3>
        <p>Forms open on any phone, no app install required. SMS-delivered link, completion in under 60 seconds.</p>
      </article>
      <article class="light-card">
        <span class="light-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>
        </span>
        <h3>Service-specific templates</h3>
        <p>Pre-built intake templates for each service your pharmacy offers, configured to your protocols and state requirements.</p>
      </article>
      <article class="light-card">
        <span class="light-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M3 12a9 9 0 1 0 9-9"/><polyline points="3 5 3 12 10 12"/></svg>
        </span>
        <h3>Pre-fill for returning patients</h3>
        <p>Returning patients see fields auto-filled from their prior submissions. No repetitive data entry, faster check-in.</p>
      </article>
    </div>
  </div>
</section>

<!-- ============= 3. ELIGIBILITY SCREENING (dark cards) ============= -->
<section class="tile tile--light" aria-label="Eligibility screening">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">Eligibility Screening</span>
      <h2 class="h-display">Keep your focus<br>on eligible patients.</h2>
      <p class="lead">Eligibility screening filters at the form level. Only patients who meet the criteria for the service can complete the intake, so your team avoids unnecessary visits and stays focused on the patients your scope and expertise are designed for.</p>
    </div>
    <div class="dark-grid">
      <article class="dark-card">
        <span class="dark-card__tag">State Scope</span>
        <h3>State scope of practice</h3>
        <p>Form rules respect your state's pharmacist scope of practice. Services patients are not eligible for in your state never show up as bookable.</p>
      </article>
      <article class="dark-card">
        <span class="dark-card__tag">Coverage Checks</span>
        <h3>Coverage and condition checks</h3>
        <p>Insurance type, age, and qualifying conditions verified in the form itself. The patient only sees the services they qualify for.</p>
      </article>
      <article class="dark-card">
        <span class="dark-card__tag">Routing</span>
        <h3>Ineligible patients routed</h3>
        <p>Patients outside the eligibility window are routed to the right next step. Cash-pay flow, provider referral, or a different program.</p>
      </article>
    </div>
  </div>
</section>

<!-- ============= 4. STATE-SPECIFIC PDFs (chips grid) ============= -->
<section class="tile tile--light" aria-label="State-specific PDFs">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">State-Specific PDFs</span>
      <h2 class="h-display">One intake.<br>The right PDF for every state.</h2>
      <p class="lead">State scope-of-practice rules dictate the form. MedMe ships with state-specific PDF templates pharmacy programs actually require, and auto-maps every submission to the right one. Standardized output, audit-ready documentation, no manual transcription, no copy-paste between systems.</p>
    </div>
    <div class="chip-row" aria-hidden="true">
      <span class="chip">California</span>
      <span class="chip">New York</span>
      <span class="chip">Texas</span>
      <span class="chip">Florida</span>
      <span class="chip">North Carolina</span>
      <span class="chip">Ohio</span>
      <span class="chip">Illinois</span>
      <span class="chip">Georgia</span>
      <span class="chip">Pennsylvania</span>
      <span class="chip">Michigan</span>
      <span class="chip">Arizona</span>
      <span class="chip">Tennessee</span>
    </div>
    <p class="chip-foot">Plus the rest of the states where MedMe customers operate. New templates ship as state boards update their protocols.</p>
  </div>
</section>

<!-- ============= 5. PATIENT RECORDS (light cards with icons, same as Digital Intake) ============= -->
<section class="tile tile--light" aria-label="Patient records">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">Patient Records</span>
      <h2 class="h-display">Forms become<br>patient records.</h2>
      <p class="lead">Every submitted form automatically creates a new patient record or updates an existing one. No re-keying, no separate import step. The chart stays current, the record stays accurate, and the next visit picks up where this one left off.</p>
    </div>
    <div class="light-grid">
      <article class="light-card">
        <span class="light-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
        </span>
        <h3>Auto-create and auto-update</h3>
        <p>First-time submissions create a new patient record. Returning submissions update the existing one. No manual record management, no duplicate entries.</p>
      </article>
      <article class="light-card">
        <span class="light-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
        </span>
        <h3>Centralized across the network</h3>
        <p>Patient records sit in one place, accessible from any store in your network. Multi-store operators see the same patient regardless of where the visit happens.</p>
      </article>
      <article class="light-card">
        <span class="light-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        </span>
        <h3>Pre-fill saves time on every visit</h3>
        <p>Pre-fill flows shorten every subsequent intake. Each visit takes less time than the last, because nothing the patient already gave you gets asked twice.</p>
      </article>
    </div>
  </div>
</section>

<!-- ============= 6. PDF MAPPING CALLOUT (matcha band above CTA) ============= -->
<section class="tile tile--light" aria-label="State-specific PDF mapping callout">
  <div class="tile__inner">
    <div class="pdf-band">
      <div class="pdf-band__text">
        <span class="pdf-band__kicker">Audit-Ready, Every State</span>
        <h3>The state-specific PDF, every time.</h3>
        <p>Whatever state your pharmacy operates in, MedMe auto-maps each completed intake to the exact PDF your state board, payer, or program expects. Audit-ready on day one, refreshed when the spec changes.</p>
      </div>
      <div class="pdf-band__cta">
        <a class="pill pill--solid" href="/us/contact">Talk to us <span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>

<!-- ============= 7. CLOSING CTA ============= -->
<section class="tile tile--navy tile--prominent" aria-label="Walk into every visit ready">
  <div class="tile__inner tile__inner--narrow">
    <div class="tile__head tile__head--centered">
      <span class="kicker">Walk Into Every Visit Ready</span>
      <h2 class="h-display">Start the encounter<br>with the chart already filled in.</h2>
      <p class="lead">A 20-minute walkthrough showing intake from SMS link to a populated chart on your state's PDF form. Bring your service mix; we will configure a real-world intake live.</p>
    </div>
    <div class="pill-cta-row pill-cta-row--center">
      <span class="pulse-rings" aria-hidden="true">
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
      </span>
      <a class="pill pill--solid" href="/us/contact">Book a demo <span class="arrow">→</span></a>
    </div>
  </div>
</section>

</BaseLayout>

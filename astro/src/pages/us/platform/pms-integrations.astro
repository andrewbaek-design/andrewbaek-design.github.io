---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LogoMedme from '../../../components/LogoMedme.astro';
---
<BaseLayout
  title="PMS Integrations, MedMe Health"
  description="MedMe works with the systems your pharmacy already runs. Bidirectional integrations with PMS systems, clearinghouses, wholesalers, and payers, BAA-protected and built for real-time sync."
  showAnnouncement={false}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en-us" href="https://medmehealth.com/us/platform/pms-integrations" />
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/" />
  </Fragment>

<style>

  /* PMS INTEGRATIONS. Hero with hub-and-spokes diagram (MedMe
     center + connected systems orbiting). 3-section workflow
     (Rx systems, Clearinghouses, Wholesalers/Payers). Three
     dark cards (real-time, security, developer API). Stat band.
     Navy closing CTA. */

  .sub-hero { background: var(--seashell); padding: 2rem 1.5rem 3.5rem; position: relative; overflow: hidden; }
  .sub-hero__inner { max-width: var(--container); margin: 0 auto; padding-inline: var(--tile-pad-x); position: relative; }
  .sub-hero__bg {
    position: relative; max-width: 1120px; margin: 0 auto;
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 45%, rgba(0,0,0,0) 95%);
            mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 45%, rgba(0,0,0,0) 95%);
    pointer-events: none;
  }
  .sub-hero__text { text-align: center; max-width: 820px; margin: -140px auto 0; position: relative; z-index: 2; }
  .sub-hero h1.h-display { font-size: clamp(28px, 4.4vw, 54px); line-height: 1.08; letter-spacing: -0.028em; margin: 0.75rem auto 1rem; text-align: center; text-wrap: balance; }
  .sub-hero h1.h-display .accent { color: var(--matcha); }
  .sub-hero__lede { font-size: 1.1rem; line-height: 1.55; color: rgba(6, 62, 84, 0.72); margin: 0 auto 1.75rem; max-width: 680px; }
  .sub-hero__cta { display: inline-flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
  @media (max-width: 980px) { .sub-hero__text { margin-top: -90px; } }
  @media (max-width: 640px) { .sub-hero__text { margin-top: -60px; } }

  /* Integrations hub mockup */
  .inthub { background: var(--white); border: 1px solid rgba(6,62,84,0.08); border-radius: 16px; padding: 22px 24px; box-shadow: 0 12px 40px rgba(6,62,84,0.06); font-family: var(--font-display); color: var(--indigo); }
  .inthub__head { display: flex; justify-content: space-between; align-items: center; padding-bottom: 14px; margin-bottom: 16px; border-bottom: 1px solid rgba(6,62,84,0.08); }
  .inthub__title { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; }
  .inthub__brand { display: inline-flex; align-items: center; color: var(--indigo); height: 22px; }
  .inthub__brand svg { height: 22px; width: auto; display: block; }
  .inthub__rows { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }
  @media (max-width: 800px) { .inthub__rows { grid-template-columns: 1fr; } }
  .inthub__col { background: rgba(6,62,84,0.04); border-radius: 10px; padding: 14px 16px; }
  .inthub__col-lbl { font-size: 10px; color: rgba(6,62,84,0.55); font-weight: 600; letter-spacing: 0.04em; margin-bottom: 10px; }
  .inthub__system { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid rgba(6,62,84,0.06); font-size: 12px; }
  .inthub__system:last-child { border-bottom: 0; }
  .inthub__system-name { color: var(--indigo); font-weight: 500; }
  .inthub__system-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--matcha); animation: inthub-pulse 2.4s ease-in-out infinite; }
  .inthub__system:nth-child(2) .inthub__system-dot { animation-delay: 0.3s; }
  .inthub__system:nth-child(3) .inthub__system-dot { animation-delay: 0.6s; }
  .inthub__system:nth-child(4) .inthub__system-dot { animation-delay: 0.9s; }
  .inthub__system:nth-child(5) .inthub__system-dot { animation-delay: 1.2s; }
  @keyframes inthub-pulse {
    0%, 100% { background: var(--matcha); transform: scale(1); }
    50%      { background: rgba(195,196,48,0.4); transform: scale(1.4); }
  }
  @media (prefers-reduced-motion: reduce) { .inthub__system-dot { animation: none; } }

  /* Workflow sections */
  .wf-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 1000px) { .wf-grid { grid-template-columns: 1fr; } }
  .wf-card { background: var(--white); border: 1px solid rgba(6,62,84,0.08); border-radius: var(--radius-lg); padding: 1.75rem; transition: transform 0.25s ease, border-color 0.25s ease; }
  .wf-card:hover { transform: translateY(-3px); border-color: rgba(6,62,84,0.18); }
  .wf-card__icon { display: inline-flex; width: 44px; height: 44px; align-items: center; justify-content: center; background: rgba(195, 196, 48, 0.14); border-radius: 10px; margin-bottom: 1rem; }
  .wf-card__icon svg { width: 22px; height: 22px; stroke: var(--matcha); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .wf-card h3 { margin: 0 0 0.5rem; font-size: 1.1rem; font-weight: 600; color: var(--indigo); letter-spacing: -0.012em; }
  .wf-card p { margin: 0 0 0.75rem; color: rgba(6,62,84,0.72); line-height: 1.5; font-size: 0.95rem; }
  .wf-card__list { list-style: none; padding: 0; margin: 0; font-size: 0.85rem; color: rgba(6,62,84,0.65); }
  .wf-card__list li { padding: 3px 0; }
  .wf-card__list li::before { content: "·"; color: var(--matcha); font-weight: 700; margin-right: 6px; }

  /* Dark winner cards */
  .winners-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 1000px) { .winners-grid { grid-template-columns: 1fr; } }
  .winner-card { background: var(--indigo); color: var(--seashell); border: 1px solid rgba(195,196,48,0.18); border-radius: var(--radius-lg); padding: 1.75rem; transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease; box-shadow: 0 12px 32px rgba(6,62,84,0.08); }
  .winner-card:hover { transform: translateY(-3px); border-color: var(--matcha); box-shadow: 0 16px 38px rgba(6,62,84,0.16); }
  .winner-card__tag { font-size: 11px; color: var(--matcha); font-weight: 700; letter-spacing: 0.06em; margin-bottom: 0.6rem; display: inline-block; }
  .winner-card h3 { margin: 0 0 0.5rem; font-size: 1.1rem; font-weight: 600; color: var(--seashell); }
  .winner-card p { margin: 0; color: rgba(250,249,245,0.78); line-height: 1.55; font-size: 0.95rem; }

  /* Stat band */
  .stats-band { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  @media (max-width: 900px) { .stats-band { grid-template-columns: 1fr; } }
  .stats-band__cell { text-align: center; }
  .stats-band__num { font-family: var(--font-display); font-size: clamp(2rem, 3.4vw, 2.8rem); font-weight: 600; color: var(--indigo); letter-spacing: -0.022em; line-height: 1.05; margin-bottom: 0.5rem; }
  .stats-band__label { font-size: 0.875rem; color: rgba(6,62,84,0.72); line-height: 1.4; max-width: 260px; margin: 0 auto; }
</style>

<!-- 1. SUB-HERO (integrations hub mockup as BG) -->
<section class="sub-hero" aria-label="Hero">
  <div class="sub-hero__inner">
    <div class="sub-hero__bg" aria-hidden="true">
      <div class="inthub">
        <div class="inthub__head">
          <span class="inthub__title">Integrations &middot; Connected Systems</span>
          <span class="inthub__brand"><LogoMedme /></span>
        </div>
        <div class="inthub__rows">
          <div class="inthub__col">
            <div class="inthub__col-lbl">Rx Systems</div>
            <div class="inthub__system"><span class="inthub__system-name">PioneerRx</span><span class="inthub__system-dot"></span></div>
            <div class="inthub__system"><span class="inthub__system-name">BestRx</span><span class="inthub__system-dot"></span></div>
            <div class="inthub__system"><span class="inthub__system-name">McKesson EM</span><span class="inthub__system-dot"></span></div>
            <div class="inthub__system"><span class="inthub__system-name">Liberty</span><span class="inthub__system-dot"></span></div>
            <div class="inthub__system"><span class="inthub__system-name">RxConnect</span><span class="inthub__system-dot"></span></div>
          </div>
          <div class="inthub__col">
            <div class="inthub__col-lbl">Clearinghouses</div>
            <div class="inthub__system"><span class="inthub__system-name">Change Healthcare</span><span class="inthub__system-dot"></span></div>
            <div class="inthub__system"><span class="inthub__system-name">Availity</span><span class="inthub__system-dot"></span></div>
            <div class="inthub__system"><span class="inthub__system-name">Office Ally</span><span class="inthub__system-dot"></span></div>
            <div class="inthub__system"><span class="inthub__system-name">Waystar</span><span class="inthub__system-dot"></span></div>
            <div class="inthub__system"><span class="inthub__system-name">Trizetto</span><span class="inthub__system-dot"></span></div>
          </div>
          <div class="inthub__col">
            <div class="inthub__col-lbl">Payers &amp; Wholesalers</div>
            <div class="inthub__system"><span class="inthub__system-name">Medicare Part B</span><span class="inthub__system-dot"></span></div>
            <div class="inthub__system"><span class="inthub__system-name">BCBS</span><span class="inthub__system-dot"></span></div>
            <div class="inthub__system"><span class="inthub__system-name">UnitedHealthcare</span><span class="inthub__system-dot"></span></div>
            <div class="inthub__system"><span class="inthub__system-name">AmerisourceBergen</span><span class="inthub__system-dot"></span></div>
            <div class="inthub__system"><span class="inthub__system-name">Cardinal Health</span><span class="inthub__system-dot"></span></div>
          </div>
        </div>
      </div>
    </div>
    <div class="sub-hero__text">
      <h1 class="h-display">Works with the systems<br>your pharmacy <span class="accent">already runs.</span></h1>
      <p class="sub-hero__lede">MedMe functions as a clinical and billing layer, not a replacement. Bidirectional integrations with Rx systems, clearinghouses, wholesalers, and payers, in real time, BAA-protected end to end.</p>
      <div class="sub-hero__cta">
        <a class="pill pill--solid" href="/us/contact">Book a demo <span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>


<!-- 2. 3-SECTION WORKFLOW -->
<section class="tile tile--light" aria-label="What we connect to">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">What We Connect To</span>
      <h2 class="h-display">Three integration layers,<br>each bidirectional.</h2>
    </div>
    <div class="wf-grid">
      <article class="wf-card">
        <span class="wf-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 10h10M7 14h10M7 18h6"/></svg>
        </span>
        <h3>Rx Dispensing Systems</h3>
        <p>Two-way sync with your PMS means patient data and updated medication lists flow back automatically. Demographics, allergies, history, and prescriber relationships stay current via real-time webhooks or hourly batches.</p>
        <ul class="wf-card__list">
          <li>PioneerRx</li>
          <li>BestRx</li>
          <li>McKesson EnterpriseRx</li>
          <li>Liberty</li>
          <li>RxConnect</li>
        </ul>
      </article>
      <article class="wf-card">
        <span class="wf-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M20 7h-3V4a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v3H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1z"/><path d="M7 12h10M7 16h6"/></svg>
        </span>
        <h3>Clearinghouses</h3>
        <p>Eligibility, claims, remittance, and status flow through major US clearinghouses, with bidirectional sync on 270/271, 837P, 277CA, and 835 ERA.</p>
        <ul class="wf-card__list">
          <li>Change Healthcare</li>
          <li>Availity</li>
          <li>Office Ally</li>
          <li>Waystar</li>
          <li>Trizetto</li>
        </ul>
      </article>
      <article class="wf-card">
        <span class="wf-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/></svg>
        </span>
        <h3>Wholesalers &amp; Payers</h3>
        <p>Direct connections to wholesalers for pricing and ordering, and to major payers for coverage lookup, claims, and ERA reconciliation.</p>
        <ul class="wf-card__list">
          <li>AmerisourceBergen, McKesson, Cardinal Health</li>
          <li>Medicare Part B, BCBS</li>
          <li>UnitedHealthcare, Humana, Aetna, Cigna</li>
        </ul>
      </article>
    </div>
  </div>
</section>

<!-- 3. DARK CAPABILITIES -->
<section class="tile tile--navy" aria-label="How the integrations work">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">How the Integrations Work</span>
      <h2 class="h-display">Real-time, secure,<br>and developer-accessible.</h2>
    </div>
    <div class="winners-grid">
      <article class="winner-card">
        <span class="winner-card__tag">Real-time Sync</span>
        <h3>Webhook-first event streaming</h3>
        <p>Bidirectional synchronization where partner systems support it. Webhook-first event streaming keeps data current in seconds, not hours. Median time to wire up a new pharmacy's Rx system: under 30 minutes.</p>
      </article>
      <article class="winner-card">
        <span class="winner-card__tag">Security &amp; Compliance</span>
        <h3>BAA-protected, SOC 2 Type II</h3>
        <p>All integrations covered by Business Associate Agreements. TLS 1.3 encryption in transit, AES-256 at rest, immutable audit logs with 7-year retention. SOC 2 Type II audited annually.</p>
      </article>
      <article class="winner-card">
        <span class="winner-card__tag">Developer API</span>
        <h3>REST + FHIR R4 + webhooks</h3>
        <p>REST and FHIR R4 endpoints, OAuth 2.0 authentication, SDKs for Node, Python, Ruby, and Go. Sandbox environment included for every integration partner.</p>
      </article>
    </div>
  </div>
</section>

<!-- 4. STAT BAND -->
<section class="tile tile--light tile--alt" aria-label="By the numbers">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">By the Numbers</span>
      <h2 class="h-display">Production integrations,<br>at scale.</h2>
    </div>
    <div class="stats-band">
      <div class="stats-band__cell">
        <div class="stats-band__num">38</div>
        <div class="stats-band__label">Production integrations across Rx systems, clearinghouses, wholesalers, and payers.</div>
      </div>
      <div class="stats-band__cell">
        <div class="stats-band__num">&lt; 30 min</div>
        <div class="stats-band__label">Median time to wire up a new pharmacy's Rx system into MedMe.</div>
      </div>
      <div class="stats-band__cell">
        <div class="stats-band__num">SOC 2 II</div>
        <div class="stats-band__label">Type II audited annually. Every integration BAA-protected.</div>
      </div>
    </div>
  </div>
</section>

<!-- 5. CLOSING CTA -->
<section class="tile tile--navy tile--prominent" aria-label="Don't see your stack">
  <div class="tile__inner tile__inner--narrow">
    <div class="tile__head tile__head--centered">
      <span class="kicker">Don't See Your Stack?</span>
      <h2 class="h-display">Tell us what you run.<br>We will tell you what's wired up.</h2>
      <p class="lead">A 20-minute call with our integrations team. Bring your systems list. We will walk through what's already in production and what we can wire up in your onboarding window.</p>
    </div>
    <div class="pill-cta-row pill-cta-row--center">
      <span class="pulse-rings" aria-hidden="true">
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
      </span>
      <a class="pill pill--solid" href="/us/contact">Book a demo <span class="arrow">→</span></a>
    </div>
  </div>
</section>

</BaseLayout>

---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Medical Billing, MedMe Health"
  description="End-to-end medical billing for pharmacy. Patient estimations, eligibility checks, coding and claim generation, submission, denials management, and analytics, all in one workflow built to maximize reimbursements."
  showAnnouncement={false}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en-us" href="https://medmehealth.com/us/platform/medical-billing" />
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/" />
  </Fragment>

<style>

  /* ============================================================
     MEDICAL BILLING product page. Hero is a Claim Analytics
     dashboard recreated from the source SVG (light-grey outer
     chrome, white inner panels, 4 KPI tiles, animated bar chart,
     claims-table card). Content follows the Generic Billing AD,
     Page 6 PDF: 5 RCM lifecycle capabilities, a 78%-vs-PBM
     callout, a 3-step onboarding guide for pharmacies new to
     medical billing, and a six-cell "what sets us apart" band.
     ============================================================ */

  /* ====== SUB-HERO ============================================= */
  .sub-hero { background: var(--seashell); padding: 2rem 1.5rem 3.5rem; position: relative; overflow: hidden; }
  .sub-hero__inner { max-width: var(--container); margin: 0 auto; padding-inline: var(--tile-pad-x); position: relative; }
  .sub-hero__bg {
    position: relative; max-width: 1120px; margin: 0 auto;
    /* Mockup acts as a backdrop. Solid through the top 60% (header,
       KPIs, chart top), then fades out so the headline can sit
       slightly over the lower portion of the mockup without making
       the claims rows compete with the title. */
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 60%, rgba(0,0,0,0) 100%);
            mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 60%, rgba(0,0,0,0) 100%);
    pointer-events: none;
  }
  .sub-hero__text { text-align: center; max-width: 820px; margin: -110px auto 0; position: relative; z-index: 2; }
  .sub-hero h1.h-display { font-size: clamp(28px, 4.4vw, 54px); line-height: 1.08; letter-spacing: -0.028em; margin: 0.75rem auto 1rem; text-align: center; text-wrap: balance; }
  .sub-hero h1.h-display .accent { color: var(--matcha); }
  .sub-hero__lede { font-size: 1.1rem; line-height: 1.55; color: rgba(6, 62, 84, 0.72); margin: 0 auto 1.75rem; max-width: 720px; }
  .sub-hero__cta { display: inline-flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
  @media (max-width: 980px) { .sub-hero__text { margin-top: -80px; } }
  @media (max-width: 640px) { .sub-hero__text { margin-top: -50px; } }

  /* ====== CLAIM ANALYTICS MOCKUP (recreated from source SVG)
     SVG palette preserved:
       - Outer chrome  : #F5F7F8 (light grey)
       - Inner cards   : white
       - Chart bars    : #16B1FF (the SVG analytics blue)
       - Status paid   : #56CA00 (green)
       - Status pend.  : #FFB400 (amber)
       - Text muted    : #6B6B6B / #386576 (grey + slate)
     ============================================================ */
  .bd-stage { display: flex; justify-content: center; padding: 16px 12px 36px; }
  .bd-frame {
    width: 720px; max-width: 100%;
    background: #F5F7F8;
    border-radius: 26px;
    padding: 14px;
    box-shadow:
      0 22px 44px -12px rgba(6, 62, 84, 0.20),
      0 8px 16px -4px rgba(6, 62, 84, 0.10);
    font-family: var(--font-display);
    color: var(--indigo);
    display: flex; flex-direction: column; gap: 10px;
  }
  .bd-card { background: #fff; border-radius: 22px; padding: 16px 18px; }

  /* Card 1: title + KPIs + chart */
  .bd-card__head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
  .bd-card__title { font-size: 14px; font-weight: 700; letter-spacing: -0.01em; color: var(--indigo); }
  .bd-live { font-size: 10px; color: rgba(6, 62, 84, 0.62); font-weight: 500; display: inline-flex; align-items: center; gap: 6px; }
  .bd-live__dot {
    width: 7px; height: 7px; border-radius: 50%; background: #56CA00;
    box-shadow: 0 0 0 0 rgba(86, 202, 0, 0.55);
    animation: bd-live-pulse 2.2s ease-in-out infinite;
  }
  @keyframes bd-live-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(86, 202, 0, 0.55); }
    50%      { box-shadow: 0 0 0 6px rgba(86, 202, 0, 0);    }
  }

  .bd-kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 16px; }
  @media (max-width: 560px) { .bd-kpis { grid-template-columns: repeat(2, 1fr); } }
  .bd-kpi {
    background: #F5F7F8;
    border-radius: 8px;
    padding: 10px 12px;
  }
  .bd-kpi__label { font-size: 10px; color: rgba(6, 62, 84, 0.55); font-weight: 500; display: block; margin-bottom: 4px; letter-spacing: 0; }
  .bd-kpi__value { font-size: 18px; font-weight: 700; color: var(--indigo); letter-spacing: -0.012em; }

  /* Bar chart, growing-in on load */
  .bd-chart {
    display: flex; align-items: flex-end; gap: 7px;
    height: 96px; padding: 6px 2px 0;
    border-top: 1px solid rgba(6, 62, 84, 0.06);
    margin-top: 4px;
  }
  .bd-bar {
    flex: 1;
    background: #16B1FF;
    border-radius: 3px 3px 0 0;
    transform-origin: bottom;
    animation: bd-bar-grow 1.4s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
  }
  .bd-bar--alt { background: #56CA00; }
  .bd-bar:nth-child(1)  { height: 32%; animation-delay: 0.08s; }
  .bd-bar:nth-child(2)  { height: 70%; animation-delay: 0.16s; }
  .bd-bar:nth-child(3)  { height: 95%; animation-delay: 0.24s; }
  .bd-bar:nth-child(4)  { height: 48%; animation-delay: 0.32s; }
  .bd-bar:nth-child(5)  { height: 82%; animation-delay: 0.40s; }
  .bd-bar:nth-child(6)  { height: 56%; animation-delay: 0.48s; }
  .bd-bar:nth-child(7)  { height: 88%; animation-delay: 0.56s; }
  .bd-bar:nth-child(8)  { height: 44%; animation-delay: 0.64s; }
  .bd-bar:nth-child(9)  { height: 76%; animation-delay: 0.72s; }
  .bd-bar:nth-child(10) { height: 60%; animation-delay: 0.80s; }
  .bd-bar:nth-child(11) { height: 92%; animation-delay: 0.88s; }
  .bd-bar:nth-child(12) { height: 38%; animation-delay: 0.96s; }
  @keyframes bd-bar-grow { from { transform: scaleY(0); } to { transform: scaleY(1); } }

  /* Card 2: claims table */
  .bd-rows { padding: 4px 2px; }
  .bd-row {
    display: grid;
    grid-template-columns: 1fr 90px 1.5fr 90px;
    align-items: center;
    gap: 12px;
    padding: 11px 10px;
    border-bottom: 1px solid rgba(6, 62, 84, 0.06);
    font-size: 12.5px;
  }
  .bd-row:last-child { border-bottom: 0; }
  .bd-row__id { font-weight: 600; color: var(--indigo); }
  .bd-row__svc { color: rgba(6, 62, 84, 0.62); }
  .bd-row__amt { font-weight: 700; color: var(--indigo); letter-spacing: -0.01em; text-align: right; }
  .bd-pill { display: inline-flex; align-items: center; gap: 6px; font-size: 10px; font-weight: 700; padding: 4px 10px; border-radius: 999px; letter-spacing: 0.01em; justify-self: start; }
  .bd-pill::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
  .bd-pill--paid    { background: rgba(86, 202, 0, 0.14);  color: #3d8e00; }
  .bd-pill--pending { background: rgba(255, 180, 0, 0.16); color: #a87200; }

  .bd-row:nth-child(1) .bd-pill--paid    { animation: bd-pill-pulse 4.4s ease-in-out infinite; }
  .bd-row:nth-child(3) .bd-pill--paid    { animation: bd-pill-pulse 4.4s ease-in-out infinite; animation-delay: 1.2s; }
  .bd-row:nth-child(2) .bd-pill--pending { animation: bd-pill-pulse 4.4s ease-in-out infinite; animation-delay: 0.6s; }
  @keyframes bd-pill-pulse {
    0%, 60%, 100% { filter: none; }
    30%           { filter: brightness(1.08) saturate(1.2); }
  }
  @media (prefers-reduced-motion: reduce) {
    .bd-bar, .bd-live__dot, .bd-pill { animation: none !important; }
    .bd-bar { transform: scaleY(1); }
  }
  @media (max-width: 560px) {
    .bd-row { grid-template-columns: 1fr 80px 80px; }
    .bd-row__svc { display: none; }
  }

  /* ====== 5-CARD RCM LIFECYCLE GRID ============================ */
  .rcm-grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 1.25rem; }
  @media (max-width: 1200px) { .rcm-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 720px)  { .rcm-grid { grid-template-columns: 1fr; } }
  .rcm-card {
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.25rem;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .rcm-card:hover { transform: translateY(-3px); border-color: rgba(6, 62, 84, 0.22); }
  .rcm-card__num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px;
    border-radius: 50%;
    background: var(--matcha);
    color: var(--indigo);
    font-size: 12px; font-weight: 700;
    margin-bottom: 0.9rem;
  }
  .rcm-card h3 { margin: 0 0 0.5rem; font-size: 1.05rem; font-weight: 600; color: var(--indigo); letter-spacing: -0.012em; line-height: 1.25; }
  .rcm-card__sub { font-style: italic; font-size: 0.875rem; color: #6f7b1a; margin: 0 0 0.9rem; line-height: 1.45; }
  .rcm-card__bullets { margin: 0; padding: 0; list-style: none; }
  .rcm-card__bullets li {
    font-size: 0.875rem;
    color: rgba(6, 62, 84, 0.78);
    line-height: 1.5;
    padding-left: 16px;
    position: relative;
    margin-bottom: 0.5rem;
  }
  .rcm-card__bullets li::before {
    content: "";
    position: absolute; left: 0; top: 8px;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--matcha);
  }

  /* ====== MATCHA CALLOUT BAND (78% reimbursement stat) ========= */
  .ctrl-band {
    background: rgba(195, 196, 48, 0.06);
    border: 1px solid rgba(195, 196, 48, 0.22);
    border-radius: 24px;
    padding: 2.5rem;
    display: grid; grid-template-columns: 1fr auto;
    gap: 2rem; align-items: center;
    position: relative; overflow: hidden;
  }
  .ctrl-band::before {
    content: ""; position: absolute; inset: 0;
    background: radial-gradient(circle at top right, rgba(195, 196, 48, 0.16) 0%, transparent 60%);
    pointer-events: none;
  }
  @media (max-width: 820px) { .ctrl-band { grid-template-columns: 1fr; padding: 1.75rem; text-align: left; } }
  .ctrl-band__text { max-width: 720px; position: relative; z-index: 1; }
  .ctrl-band__kicker { font-size: 11px; color: var(--matcha); font-weight: 700; letter-spacing: 0.08em; margin-bottom: 0.5rem; display: inline-block; }
  .ctrl-band h3 { margin: 0 0 0.5rem; font-size: 1.5rem; font-weight: 700; color: var(--indigo); letter-spacing: -0.018em; line-height: 1.2; }
  .ctrl-band h3 .accent { color: var(--matcha-deep, #8a8b1c); }
  .ctrl-band p { margin: 0; font-size: 1rem; line-height: 1.55; color: rgba(6, 62, 84, 0.78); text-wrap: pretty; }
  .ctrl-band__big {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 700;
    line-height: 1;
    color: var(--indigo);
    letter-spacing: -0.03em;
    position: relative; z-index: 1;
    text-align: right;
  }
  .ctrl-band__big small { display: block; font-size: 0.85rem; font-weight: 500; color: rgba(6, 62, 84, 0.62); margin-top: 0.4rem; letter-spacing: 0; }
  @media (max-width: 820px) { .ctrl-band__big { text-align: left; } }

  /* ====== 3-STEP ONBOARDING ==================================== */
  .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 800px) { .steps-grid { grid-template-columns: 1fr; } }
  .step-card {
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: var(--radius-lg);
    padding: 1.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .step-card:hover { transform: translateY(-3px); border-color: rgba(195, 196, 48, 0.5); }
  .step-card__tag { font-size: 12px; font-weight: 700; color: var(--matcha); letter-spacing: 0.06em; margin-bottom: 0.85rem; display: inline-block; }
  .step-card h3 { margin: 0 0 0.5rem; font-size: 1.1rem; font-weight: 600; color: var(--indigo); letter-spacing: -0.012em; }
  .step-card p { margin: 0; font-size: 0.95rem; color: rgba(6, 62, 84, 0.72); line-height: 1.55; }

  /* ====== "WHAT SETS US APART" 3x2 DARK CARD GRID ============== */
  .apart-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 900px) { .apart-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .apart-grid { grid-template-columns: 1fr; } }
  .apart-cell {
    background: var(--indigo);
    color: var(--seashell);
    border: 1px solid rgba(195, 196, 48, 0.18);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex; flex-direction: column; gap: 0.85rem;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 12px 32px rgba(6, 62, 84, 0.08);
  }
  .apart-cell:hover {
    transform: translateY(-3px);
    border-color: var(--matcha);
    box-shadow: 0 16px 38px rgba(6, 62, 84, 0.16);
  }
  .apart-cell__check {
    flex-shrink: 0;
    width: 34px; height: 34px;
    border-radius: 50%;
    background: var(--matcha);
    color: var(--indigo);
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 17px; font-weight: 700; line-height: 1;
  }
  .apart-cell__num {
    font-family: var(--font-display);
    font-size: clamp(1.85rem, 2.6vw, 2.25rem);
    font-weight: 700;
    color: var(--seashell);
    letter-spacing: -0.022em;
    line-height: 1.05;
  }
  .apart-cell__label {
    font-size: 0.95rem;
    color: rgba(250, 249, 245, 0.78);
    line-height: 1.55;
  }
  .apart-cell__label .accent {
    color: var(--matcha);
    font-weight: 600;
  }
</style>

<!-- ============= 1. SUB-HERO (animated Claim Analytics dashboard) ============= -->
<section class="sub-hero" aria-label="Hero">
  <div class="sub-hero__inner">
    <div class="sub-hero__bg" aria-hidden="true">
      <div class="bd-stage">
        <div class="bd-frame">
          <div class="bd-card">
            <div class="bd-card__head">
              <span class="bd-card__title">Claim Analytics</span>
              <span class="bd-live"><span class="bd-live__dot"></span> Live</span>
            </div>
            <div class="bd-kpis">
              <div class="bd-kpi">
                <span class="bd-kpi__label">Submitted</span>
                <span class="bd-kpi__value">248</span>
              </div>
              <div class="bd-kpi">
                <span class="bd-kpi__label">Clean rate</span>
                <span class="bd-kpi__value">98%</span>
              </div>
              <div class="bd-kpi">
                <span class="bd-kpi__label">Paid (30d)</span>
                <span class="bd-kpi__value">$42.7K</span>
              </div>
              <div class="bd-kpi">
                <span class="bd-kpi__label">Avg TAT</span>
                <span class="bd-kpi__value">22h</span>
              </div>
            </div>
            <div class="bd-chart" aria-hidden="true">
              <span class="bd-bar"></span>
              <span class="bd-bar"></span>
              <span class="bd-bar"></span>
              <span class="bd-bar"></span>
              <span class="bd-bar"></span>
              <span class="bd-bar"></span>
              <span class="bd-bar bd-bar--alt"></span>
              <span class="bd-bar"></span>
              <span class="bd-bar"></span>
              <span class="bd-bar"></span>
              <span class="bd-bar bd-bar--alt"></span>
              <span class="bd-bar"></span>
            </div>
          </div>
          <div class="bd-card">
            <div class="bd-rows">
              <div class="bd-row">
                <span class="bd-row__id">CL-28391</span>
                <span class="bd-pill bd-pill--paid">Paid</span>
                <span class="bd-row__svc">Reconciled, ERA received</span>
                <span class="bd-row__amt">$128.50</span>
              </div>
              <div class="bd-row">
                <span class="bd-row__id">CL-28390</span>
                <span class="bd-pill bd-pill--pending">Pending</span>
                <span class="bd-row__svc">Submitted, awaiting payer</span>
                <span class="bd-row__amt">$94.20</span>
              </div>
              <div class="bd-row">
                <span class="bd-row__id">CL-28389</span>
                <span class="bd-pill bd-pill--paid">Paid</span>
                <span class="bd-row__svc">Reconciled, ERA received</span>
                <span class="bd-row__amt">$312.00</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="sub-hero__text">
      <h1 class="h-display">Switch to MedMe's medical billing<br>and <span class="accent">get paid more, faster.</span></h1>
      <p class="sub-hero__lede">End-to-end medical billing support to reclaim your team's time and maximize reimbursements. Eligibility, coding, submission, denials, and analytics in one workflow built for pharmacy.</p>
      <div class="sub-hero__cta">
        <a class="pill pill--solid" href="/us/contact">Book a demo <span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>


<!-- ============= 2. FULL RCM LIFECYCLE (5 capability cards) ============= -->
<section class="tile tile--light" aria-label="End-to-end revenue cycle">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">End-to-End Revenue Cycle</span>
      <h2 class="h-display">Five connected capabilities,<br>one billing engine.</h2>
      <p class="lead">MedMe's RCM engine manages the full claim lifecycle, from intake to reimbursement, with built-in coding logic, eligibility verification, and reconciliation workflows. Each capability hands off cleanly to the next.</p>
    </div>
    <div class="rcm-grid">
      <article class="rcm-card">
        <span class="rcm-card__num">01</span>
        <h3>Patient Estimations</h3>
        <p class="rcm-card__sub">Predict out-of-pocket costs before the encounter.</p>
        <ul class="rcm-card__bullets">
          <li>Combine returned insurance benefits with fee schedules to estimate patient responsibility</li>
          <li>Determine if self-pay consent or pre-service credit-card capture is required</li>
          <li>Improve transparency and reduce downstream billing issues</li>
        </ul>
      </article>
      <article class="rcm-card">
        <span class="rcm-card__num">02</span>
        <h3>End-to-End Claim Automation</h3>
        <p class="rcm-card__sub">MedMe's RCM engine manages the full claim lifecycle, from intake to reimbursement.</p>
        <ul class="rcm-card__bullets">
          <li>Eligibility checks with insurer data</li>
          <li>Automatic extraction of insurance card details (OCR)</li>
          <li>Real-time verification of active coverage</li>
          <li>Structured documentation ensures compliance upstream</li>
        </ul>
      </article>
      <article class="rcm-card">
        <span class="rcm-card__num">03</span>
        <h3>Coding &amp; Claim Generation</h3>
        <p class="rcm-card__sub">Built-in coding logic simplifies billing for clinical encounters.</p>
        <ul class="rcm-card__bullets">
          <li>Auto-map encounter data to CPT/ICD codes</li>
          <li>Pre-populated claim templates reduce miscoding</li>
          <li>Human-in-the-loop review before submission</li>
        </ul>
      </article>
      <article class="rcm-card">
        <span class="rcm-card__num">04</span>
        <h3>Submission, Tracking &amp; Reconciliation</h3>
        <p class="rcm-card__sub">Stay in control with real-time visibility and hands-off denials management.</p>
        <ul class="rcm-card__bullets">
          <li>Live status updates for every claim</li>
          <li>Automatic detection and retry of denials up to 3 times before manual review</li>
          <li>Adjustment workflows for underpaid or unpaid claims</li>
          <li>Reconciliation tools for complete revenue transparency</li>
        </ul>
      </article>
      <article class="rcm-card">
        <span class="rcm-card__num">05</span>
        <h3>Dashboarding &amp; Insights</h3>
        <p class="rcm-card__sub">Monitor financial performance across stores, services, and payers.</p>
        <ul class="rcm-card__bullets">
          <li>View claims volume, reimbursement rates, and payment timelines</li>
          <li>Identify denial trends</li>
          <li>Measure billing efficiency and financial return</li>
        </ul>
      </article>
    </div>
  </div>
</section>

<!-- ============= 3. WHAT SETS US APART (3x2 dark card grid) ============= -->
<section class="tile tile--light" aria-label="What sets MedMe medical billing apart">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">What Sets Us Apart</span>
      <h2 class="h-display">Six reasons pharmacies<br>switch to MedMe billing.</h2>
    </div>
    <div class="apart-grid">
      <div class="apart-cell">
        <span class="apart-cell__check">&check;</span>
        <div class="apart-cell__num">4%</div>
        <div class="apart-cell__label"><span class="accent">Competitive pricing</span>, charged only on successful claims, no flat platform fee.</div>
      </div>
      <div class="apart-cell">
        <span class="apart-cell__check">&check;</span>
        <div class="apart-cell__num">80%+</div>
        <div class="apart-cell__label"><span class="accent">Reduction in manual workflows</span> with AI assistants and PMS integrations.</div>
      </div>
      <div class="apart-cell">
        <span class="apart-cell__check">&check;</span>
        <div class="apart-cell__num">98%+</div>
        <div class="apart-cell__label"><span class="accent">Clean claims rate</span> at first submission across the customer cohort.</div>
      </div>
      <div class="apart-cell">

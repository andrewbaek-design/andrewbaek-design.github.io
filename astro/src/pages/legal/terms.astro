---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entry = await getEntry('legal', 'terms');
if (!entry) throw new Error('legal/terms content not found');
const { Content } = await render(entry);
const { title, description, kicker, headline, lede } = entry.data;
---
<BaseLayout title={title} description={description}>
  <section class="page-hero">
    <div class="wrap">
      <div class="page-hero__content">
        <div class="page-hero__breadcrumb">
          <a href="/us">Home</a><span class="sep">›</span> Legal <span class="sep">›</span> Terms
        </div>
        <span class="eyebrow eyebrow--matcha">{kicker}</span>
        <h1>{headline}</h1>
        <p class="page-hero__lede" set:html={lede}></p>
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="wrap">
      <div style="display: grid; grid-template-columns: 240px 1fr; gap: 3rem; align-items: start;">
        <aside class="toc" style="position: sticky; top: 6rem;">
          <h4>On this page</h4>
          <ul>
            <li><a href="#acceptance">1. Acceptance</a></li>
            <li><a href="#definitions">2. Definitions</a></li>
            <li><a href="#use">3. Use of service</a></li>
            <li><a href="#subscription">4. Subscription &amp; payment</a></li>
            <li><a href="#data">5. Customer data</a></li>
            <li><a href="#confidentiality">6. Confidentiality</a></li>
            <li><a href="#ip">7. Intellectual property</a></li>
            <li><a href="#warranties">8. Warranties</a></li>
            <li><a href="#liability">9. Limitation of liability</a></li>
            <li><a href="#indemnity">10. Indemnification</a></li>
            <li><a href="#termination">11. Termination</a></li>
            <li><a href="#governing">12. Governing law</a></li>
            <li><a href="#changes">13. Changes</a></li>
            <li><a href="#general">14. General</a></li>
            <li><a href="#contact">15. Contact</a></li>
          </ul>
        </aside>
        <article class="prose">
          <Content />
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

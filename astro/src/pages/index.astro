---
import LogoMedme from '../components/LogoMedme.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>MedMe Health</title>
<meta name="description" content="MedMe is the clinical operating system for community pharmacy." />
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/assets/brand.css" />
<style is:global>
  /* Minimal loading shell, most users see this for <300ms before redirect. */
  html, body { margin: 0; padding: 0; height: 100%; }
  body {
    font-family: 'Montserrat', system-ui, -apple-system, sans-serif;
    background: var(--seashell);
    color: var(--indigo);
    display: flex; align-items: center; justify-content: center;
    text-align: center;
  }
  .splash {
    display: flex; flex-direction: column;
    align-items: center; gap: 1.25rem;
    padding: 2rem;
  }
  .splash__logo {
    height: 28px; width: auto;
    color: var(--indigo);
  }
  .splash__line {
    font-size: 13.5px;
    color: rgba(6, 62, 84, 0.55);
    letter-spacing: -0.005em;
  }
  .splash__manual {
    display: flex; gap: 12px;
    margin-top: 1rem;
    font-size: 13px;
  }
  .splash__manual a {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 14px;
    border-radius: 999px;
    background: #fff;
    border: 1px solid rgba(6, 62, 84, 0.12);
    color: var(--indigo);
    text-decoration: none;
    transition: border-color 0.18s ease;
  }
  .splash__manual a:hover { border-color: rgba(6, 62, 84, 0.35); }
  /* Show manual fallback after 1.2s so users aren't stuck if geo lookup hangs. */
  .splash__manual { opacity: 0; transition: opacity 0.3s; }
  .splash__manual.is-visible { opacity: 1; }
</style>
</head>
<body>

<div class="splash">
  <div class="splash__logo" aria-hidden="true"><LogoMedme /></div>
  <div class="splash__line" id="splashLine">Routing you to the right MedMe site&hellip;</div>
  <div class="splash__manual" id="splashManual">
    <a href="/us/" data-set-region="US">🇺🇸 United States</a>
    <a href="/ca/" data-set-region="CA">🇨🇦 Canada</a>
  </div>
</div>

<script is:inline>
/* =============================================================
   Geo-aware region redirect (root domain only).
   - 1) honor a saved preference in localStorage["medme-region"]
   - 2) else look up the visitor's country via ipapi.co
   - 3) redirect to /ca/ if Canada, else /us/
   - 4) hard fallback to /us/ if anything fails or takes > 1.5s
   ============================================================= */
(function () {
  var REGION_KEY = 'medme-region';
  var FALLBACK_MS = 1500;
  var settled = false;

  function go(path) {
    if (settled) return;
    settled = true;
    window.location.replace(path);
  }
  function setRegion(region) {
    try { localStorage.setItem(REGION_KEY, region); } catch (e) {}
  }

  var saved = null;
  try { saved = localStorage.getItem(REGION_KEY); } catch (e) {}
  if (saved === 'CA') return go('/ca/');
  if (saved === 'US') return go('/us/');

  setTimeout(function () {
    var m = document.getElementById('splashManual');
    if (m && !settled) m.classList.add('is-visible');
  }, 700);

  document.querySelectorAll('[data-set-region]').forEach(function (el) {
    el.addEventListener('click', function () {
      setRegion(el.getAttribute('data-set-region'));
    });
  });

  var timeout = setTimeout(function () {
    if (!settled) go('/us/');
  }, FALLBACK_MS);

  fetch('https://ipapi.co/json/', { mode: 'cors' })
    .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
    .then(function (data) {
      clearTimeout(timeout);
      var country = (data && data.country_code) || '';
      if (country === 'CA') { setRegion('CA'); return go('/ca/'); }
      setRegion('US');
      go('/us/');
    })
    .catch(function () {
      clearTimeout(timeout);
      if (!settled) go('/us/');
    });
})();
</script>

</body>
</html>

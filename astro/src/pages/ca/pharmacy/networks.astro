<script is:inline slot="end-of-body" set:html={`/* Reduced-motion guard for SMIL animations in the hero rollup
     graphic. CSS hides .roll-pulse via display:none under
     prefers-reduced-motion, but SMIL keeps the timeline running.
     pauseAnimations() halts it entirely. */
  (function () {
    if (!window.matchMedia) return;
    var mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    function apply() {
      if (!mq.matches) return;
      document.querySelectorAll('.hero-roll').forEach(function (svg) {
        if (typeof svg.pauseAnimations === 'function') svg.pauseAnimations();
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', apply);
    } else {
      apply();
    }
    if (mq.addEventListener) mq.addEventListener('change', apply);
    else if (mq.addListener) mq.addListener(apply);
  })();`}></script>

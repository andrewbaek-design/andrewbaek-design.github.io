---
import BaseLayout from '../../../layouts/BaseLayoutCa.astro';
---
<BaseLayout
  title="For Pharmacy Networks, MedMe Health"
  description="MedMe gives pharmacy networks a clinical services platform members actually adopt, and gives the central organization the cross-network encounter and outcomes data that strengthens its value to membership."
  showAnnouncement={false}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/pharmacy/networks" />
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/pharmacy/networks" />
  </Fragment>

<style>

  /* ============================================================
     NETWORKS sub-page. Leans on the front-page design system
     (.tile, .tile__head, .h-display, .kicker, .pill, .tile--navy).
     Page-specific bits: network rollup hero motion graphic
     (many member nodes consolidating into one), per-card motion
     in the Value to Network grid, navy story band with four
     commercial model value blocks.
     ============================================================ */

  /* ====== HERO: stacked (motion graphic above text) ============= */
  .sub-hero {
    background: var(--seashell);
    padding: 2rem 1.5rem 3.5rem;
    position: relative;
    overflow: hidden;
  }
  .sub-hero__inner {
    max-width: var(--container);
    margin: 0 auto;
    padding-inline: var(--tile-pad-x);
    position: relative;
  }
  .sub-hero__visual {
    position: relative;
    max-width: 1080px;
    margin: 0 auto;
  }
  .sub-hero__text {
    text-align: center;
    max-width: 760px;
    margin: 1rem auto 0;
    position: relative;
  }
  .sub-hero h1.h-display {
    font-size: clamp(28px, 4.4vw, 54px);
    line-height: 1.08;
    letter-spacing: -0.028em;
    margin: 0.75rem auto 1rem;
    text-align: center;
    text-wrap: balance;
  }
  .sub-hero__lede {
    font-size: 1.1rem;
    line-height: 1.55;
    color: rgba(6, 62, 84, 0.72);
    margin: 0 auto 1.75rem;
    max-width: 640px;
  }
  .sub-hero__cta {
    display: inline-flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  @media (max-width: 980px) { .sub-hero__text { margin-top: 0.75rem; } }
  @media (max-width: 640px) { .sub-hero__text { margin-top: 0.5rem; } }

  /* ====== HERO ROLLUP GRAPHIC ====================================
     A 6x4 grid of small member-store dots flowing rightward into
     a single rollup card on the right. Visualises many member
     locations consolidating into one cross-network view. Reduced-
     motion respected. */
  .hero-roll {
    position: relative;
    width: 100%;
    max-width: 820px;
    margin: 0 auto;
    aspect-ratio: 800 / 440;
    display: block;
  }
  .hero-roll .roll-mesh circle {
    fill: var(--white);
    stroke: rgba(6, 62, 84, 0.18);
    stroke-width: 1.25;
  }
  .hero-roll .roll-mesh .roll-active {
    fill: var(--matcha);
    stroke: var(--matcha);
    animation: roll-blink 3.2s ease-in-out infinite;
  }
  @keyframes roll-blink {
    0%, 100% { opacity: 0.25; }
    50%      { opacity: 1; }
  }
  .hero-roll .roll-mesh .roll-a-1 { animation-delay: 0s; }
  .hero-roll .roll-mesh .roll-a-2 { animation-delay: 0.3s; }
  .hero-roll .roll-mesh .roll-a-3 { animation-delay: 0.6s; }
  .hero-roll .roll-mesh .roll-a-4 { animation-delay: 0.9s; }
  .hero-roll .roll-mesh .roll-a-5 { animation-delay: 1.2s; }
  .hero-roll .roll-pulse { fill: var(--matcha); }
  .hero-roll .roll-card {
    fill: var(--white);
    stroke: rgba(6, 62, 84, 0.14);
    stroke-width: 1.5;
  }
  .hero-roll .roll-card-ring {
    fill: none;
    stroke: var(--matcha);
    stroke-width: 1.5;
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
    animation: roll-card-ring 2.8s cubic-bezier(0.22, 0.61, 0.36, 1) infinite;
  }
  @keyframes roll-card-ring {
    0%   { opacity: 0.55; transform: scale(1); }
    100% { opacity: 0;    transform: scale(1.6); }
  }
  .hero-roll .roll-card-label {
    fill: var(--indigo);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    text-anchor: middle;
  }
  .hero-roll .roll-card-stat {
    fill: rgba(6, 62, 84, 0.65);
    font-family: var(--font-display);
    font-size: 11px;
    text-anchor: middle;
  }
  .hero-roll .roll-bar {
    fill: var(--matcha);
    transform-origin: left center;
  }
  .hero-roll .roll-bar-bg {
    fill: rgba(6, 62, 84, 0.08);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-roll .roll-mesh .roll-active,
    .hero-roll .roll-card-ring,
    .hero-roll .roll-pulse { animation: none; opacity: 0; display: none; }
  }
  @media (max-width: 980px) {
    .sub-hero__visual { margin-inline: calc(-1 * var(--tile-pad-x)); }
    .hero-roll .roll-card-label { font-size: 15px; }
    .hero-roll .roll-card-stat { font-size: 13px; }
  }
  @media (max-width: 700px) {
    .sub-hero { padding-inline: 0.5rem; }
    .sub-hero__visual { margin-inline: 0; }
    .hero-roll .roll-card-label { font-size: 17px; }
    .hero-roll .roll-card-stat { font-size: 14px; }
  }

  /* ====== VALUE TO NETWORK: 3-feature card grid w/ motion ======= */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }
  @media (max-width: 1000px) { .feature-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .feature-grid { grid-template-columns: 1fr; } }
  /* Recruitment section ships only two cards now (Get Paid was removed),
     so split the row in half there instead of leaving a third-column gap.
     Motion graphics inside use the SVG's native 220:90 aspect ratio so
     they scale up with the wider 2-col cards instead of staying capped
     at the original 130px height. */
  section[aria-label="For member recruitment"] .feature-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  section[aria-label="For member recruitment"] .feat-graphic {
    height: auto;
    aspect-ratio: 220 / 90;
  }
  @media (max-width: 640px) {
    section[aria-label="For member recruitment"] .feature-grid { grid-template-columns: 1fr; }
  }
  .feature {
    /* Card bg uses the canonical token so .tile--alt sections pick up
       the warm-tone alternation defined in brand.css. No border, no
       shadow, only the hover lift stays. */
    background: var(--tile-card-bg);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: none;
    transition: transform 0.25s ease;
  }
  .feature:hover {
    transform: translateY(-3px);
  }

  .feat-graphic {
    width: 100%;
    height: 130px;
    background: rgba(195, 196, 48, 0.06);
    border-radius: 10px;
    margin-bottom: 1.25rem;
    overflow: hidden;
    position: relative;
  }
  /* Variant used by the Member Recruitment and Advocacy sections (no live
     motion graphic in those cards, just a centered icon). Inherits the
     same matcha-tinted tile so the row reads visually consistent with
     the animated Value-to-Network cards below it. */
  .feat-graphic--icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--indigo);
  }
  .feat-graphic--icon svg {
    width: 64px;
    height: 64px;
    display: block;
  }
  /* Scene variant: fills the tile width with a small illustration.
     Each scene is uniquely identified by `data-scene="..."` so the
     animation rules below can target the right inner SVG elements
     without touching the markup. */
  .feat-graphic--scene {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.75rem;
  }
  .feat-graphic--scene svg {
    width: 100%;
    height: auto;
    max-width: 100%;
    display: block;
    overflow: visible;
  }
  .feat-graphic--scene svg * {
    transform-box: fill-box;
  }

  /* ============================================================
     MOTION GRAPHICS (Member Recruitment + Advocacy scenes)
     Six infinite, subtle loops. Each one picks the most expressive
     element in its illustration and animates it.
     ============================================================ */

  /* 1 — Platform consolidation: scattered tool tiles blink in a wave,
        suggesting many tools collapsing into the central MedMe tile. */
  [data-scene="platform"] svg > g:first-of-type rect {
    transform-origin: center;
    animation: pc-tile-blink 3.6s ease-in-out infinite;
  }
  [data-scene="platform"] svg > g:first-of-type rect:nth-child(1) { animation-delay: 0s;   }
  [data-scene="platform"] svg > g:first-of-type rect:nth-child(2) { animation-delay: 0.3s; }
  [data-scene="platform"] svg > g:first-of-type rect:nth-child(3) { animation-delay: 0.6s; }
  [data-scene="platform"] svg > g:first-of-type rect:nth-child(4) { animation-delay: 0.9s; }
  [data-scene="platform"] svg > g:first-of-type rect:nth-child(5) { animation-delay: 1.2s; }
  @keyframes pc-tile-blink {
    0%, 100% { opacity: 0.35; transform: scale(0.92); }
    50%      { opacity: 1;    transform: scale(1); }
  }

  /* 3 — Scale without hiring: AI agent dots pulse outward with a glow,
        dashed lines flow toward the pharmacist (offset drift). */
  [data-scene="scale"] svg > g:nth-of-type(2) circle {
    transform-origin: center;
    animation: pc-ai-pulse 1.8s ease-in-out infinite;
  }
  [data-scene="scale"] svg > g:nth-of-type(2) circle:nth-child(1) { animation-delay: 0s;   }
  [data-scene="scale"] svg > g:nth-of-type(2) circle:nth-child(2) { animation-delay: 0.3s; }
  [data-scene="scale"] svg > g:nth-of-type(2) circle:nth-child(3) { animation-delay: 0.6s; }
  @keyframes pc-ai-pulse {
    0%, 100% { transform: scale(1);    filter: drop-shadow(0 0 0  rgba(195,196,48,0));   }
    50%      { transform: scale(1.15); filter: drop-shadow(0 0 8px rgba(195,196,48,0.6)); }
  }
  [data-scene="scale"] svg > g:first-of-type path {
    stroke-dasharray: 3 3;
    animation: pc-dash-flow 2s linear infinite;
  }
  @keyframes pc-dash-flow {
    to { stroke-dashoffset: -12; }
  }

  /* Reduced-motion: kill all scene animations. */
  @media (prefers-reduced-motion: reduce) {
    [data-scene] svg * {
      animation: none !important;
    }
  }

  /* Warm-tone alternation now lives in brand.css and applies site-wide
     to every `.tile--light` card (no border, var(--tile-card-bg) fill).
     This page just opts specific sections in via the `tile--alt` class. */
  .feature h3 {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--indigo);
    letter-spacing: -0.012em;
  }
  .feature p { margin: 0; color: rgba(6, 62, 84, 0.72); line-height: 1.55; }

  /* 1. Visibility: dashboard with chart bars + sweep line */
  .feat-vis {
    padding: 18px 22px;
    display: flex;
    align-items: flex-end;
    gap: 6px;
    position: relative;
  }
  .feat-vis .vis-bar {
    flex: 1;
    background: rgba(195, 196, 48, 0.25);
    border-radius: 2px 2px 0 0;
    animation: vis-grow 4s ease-in-out infinite;
  }
  .feat-vis .vis-bar:nth-child(1) { height: 30%; animation-delay: 0s; }
  .feat-vis .vis-bar:nth-child(2) { height: 55%; animation-delay: 0.15s; }
  .feat-vis .vis-bar:nth-child(3) { height: 40%; animation-delay: 0.3s; }
  .feat-vis .vis-bar:nth-child(4) { height: 70%; animation-delay: 0.45s; }
  .feat-vis .vis-bar:nth-child(5) { height: 50%; animation-delay: 0.6s; }
  .feat-vis .vis-bar:nth-child(6) { height: 80%; animation-delay: 0.75s; }
  .feat-vis .vis-bar:nth-child(7) { height: 65%; animation-delay: 0.9s; }
  .feat-vis .vis-bar:nth-child(8) { height: 90%; animation-delay: 1.05s; }
  @keyframes vis-grow {
    0%, 100% { background: rgba(195, 196, 48, 0.25); transform: scaleY(0.9); }
    50%      { background: var(--matcha);             transform: scaleY(1); }
  }

  /* 2. Standardization: 3 row blueprints aligning identically */
  .feat-std {
    padding: 16px 22px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
  }
  .feat-std .std-row {
    display: flex;
    gap: 6px;
    align-items: center;
  }
  .feat-std .std-step {
    height: 10px;
    background: rgba(195, 196, 48, 0.3);
    border-radius: 2px;
    animation: std-align 3.6s ease-in-out infinite;
  }
  .feat-std .std-row:nth-child(1) .std-step:nth-child(1) { width: 20px; animation-delay: 0s; }
  .feat-std .std-row:nth-child(1) .std-step:nth-child(2) { width: 30px; animation-delay: 0.1s; }
  .feat-std .std-row:nth-child(1) .std-step:nth-child(3) { width: 24px; animation-delay: 0.2s; }
  .feat-std .std-row:nth-child(2) .std-step:nth-child(1) { width: 20px; animation-delay: 0.4s; }
  .feat-std .std-row:nth-child(2) .std-step:nth-child(2) { width: 30px; animation-delay: 0.5s; }
  .feat-std .std-row:nth-child(2) .std-step:nth-child(3) { width: 24px; animation-delay: 0.6s; }
  .feat-std .std-row:nth-child(3) .std-step:nth-child(1) { width: 20px; animation-delay: 0.8s; }
  .feat-std .std-row:nth-child(3) .std-step:nth-child(2) { width: 30px; animation-delay: 0.9s; }
  .feat-std .std-row:nth-child(3) .std-step:nth-child(3) { width: 24px; animation-delay: 1.0s; }
  @keyframes std-align {
    0%, 100% { background: rgba(195, 196, 48, 0.3); }
    50%      { background: var(--matcha); }
  }

  /* 3. Commercial: stacked dollar/value tags cycling */
  .feat-comm {
    padding: 14px 22px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
  .feat-comm .comm-tag {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--white);
    border: 1px solid rgba(195, 196, 48, 0.3);
    padding: 4px 12px;
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    color: var(--indigo);
    opacity: 0;
    transform: translateY(8px);
    animation: comm-show 4s ease-in-out infinite;
  }
  .feat-comm .comm-tag:nth-child(1) { animation-delay: 0s; }
  .feat-comm .comm-tag:nth-child(2) { animation-delay: 1.3s; }
  .feat-comm .comm-tag:nth-child(3) { animation-delay: 2.6s; }
  .feat-comm .comm-tag .comm-dot {
    width: 6px;
    height: 6px;
    background: var(--matcha);
    border-radius: 50%;
  }
  @keyframes comm-show {
    0%, 70%, 100% { opacity: 0; transform: translateY(8px); }
    10%, 30%      { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .feat-vis .vis-bar,
    .feat-std .std-step,
    .feat-comm .comm-tag { animation: none; opacity: 1; transform: none; }
  }

  /* ====== IMPACT FUND CALLOUT BAND (per Andrew #201) =========== */
  .impact-band {
    background: rgba(195, 196, 48, 0.06);
    border: 1px solid rgba(195, 196, 48, 0.22);
    border-radius: 24px;
    padding: 2.5rem;
    display: grid;
    grid-template-columns: 1.1fr auto;
    gap: 2rem;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .impact-band::before {
    content: "";
    position: absolute;
    top: -60px; right: -60px;
    width: 220px; height: 220px;
    background: var(--matcha);
    opacity: 0.1;
    border-radius: 50%;
    pointer-events: none;
  }
  @media (max-width: 800px) {
    .impact-band { grid-template-columns: 1fr; padding: 1.75rem; }
  }
  .impact-band__text { max-width: 720px; position: relative; z-index: 1; }
  .impact-band__kicker {
    font-size: 11px; color: var(--matcha); font-weight: 700;
    letter-spacing: 0.08em; margin-bottom: 0.5rem; display: inline-block;
  }
  .impact-band h3 {
    margin: 0 0 0.5rem;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--indigo);
    letter-spacing: -0.018em;
  }
  .impact-band p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.55;
    color: rgba(6, 62, 84, 0.78);
    text-wrap: pretty;
  }
  .impact-band__cta { position: relative; z-index: 1; }

  /* ====== NAVY STORY (member benefit + 4 commercial models) ===== */
  .tile--navy { position: relative; overflow: hidden; }
  .tile--navy .tile__inner { position: relative; z-index: 1; }
  .story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (max-width: 980px) { .story-grid { grid-template-columns: 1fr; gap: 2rem; } }
  .story-quote {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2vw, 1.6rem);
    line-height: 1.4;
    font-weight: 500;
    color: var(--seashell);
    letter-spacing: -0.012em;
    margin: 1rem 0 1.25rem;
  }
  .story-quote p { margin: 0; }
  .story-attribution {
    font-size: 0.875rem;
    color: rgba(250, 249, 245, 0.60);
    margin: 0;
  }
  .story-cta { margin-top: 1.75rem; }
  .value-blocks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  @media (max-width: 600px) { .value-blocks { grid-template-columns: 1fr; } }
  .value-block {
    background: rgba(250, 249, 245, 0.06);
    border: 1px solid rgba(250, 249, 245, 0.12);
    border-radius: 14px;
    padding: 1.25rem;
    transition: border-color 0.6s ease, box-shadow 0.6s ease;
    animation: value-block-light 6s ease-in-out infinite;
  }
  .value-block:nth-child(1) { animation-delay: 0s; }
  .value-block:nth-child(2) { animation-delay: 1.5s; }
  .value-block:nth-child(3) { animation-delay: 3s; }
  .value-block:nth-child(4) { animation-delay: 4.5s; }
  @keyframes value-block-light {
    0%, 18%, 100% { border-color: rgba(250, 249, 245, 0.12); box-shadow: none; }
    6%, 12%       { border-color: var(--matcha); box-shadow: 0 0 0 1px rgba(195, 196, 48, 0.35), 0 8px 28px rgba(195, 196, 48, 0.18); }
  }
  @media (prefers-reduced-motion: reduce) {
    .value-block { animation: none; }
  }
  .value-block__icon {
    display: inline-flex;
    width: 32px;
    height: 32px;
    align-items: center;
    justify-content: center;
    background: rgba(195, 196, 48, 0.18);
    border-radius: 8px;
    margin-bottom: 0.75rem;
  }
  .value-block__icon svg { width: 18px; height: 18px; stroke: var(--matcha); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .value-block h4 {
    margin: 0 0 0.4rem;
    color: var(--seashell);
    font-size: 1.05rem;
    font-weight: 600;
  }
  .value-block p {
    margin: 0;
    color: rgba(250, 249, 245, 0.65);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* Faint navy bg pattern: dot grid + scan wave. */
  .story-bg-pattern {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    background-image: radial-gradient(circle, rgba(195, 196, 48, 0.08) 1.5px, transparent 1.6px);
    background-size: 38px 38px;
    background-position: center;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%);
            mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%);
  }
  .story-bg-pattern::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(195, 196, 48, 0.32) 1.8px, transparent 1.9px);
    background-size: 38px 38px;
    background-position: center;
    -webkit-mask-image: linear-gradient(115deg, transparent 38%, #000 50%, transparent 62%);
            mask-image: linear-gradient(115deg, transparent 38%, #000 50%, transparent 62%);
    -webkit-mask-size: 220% 220%;
            mask-size: 220% 220%;
    -webkit-mask-repeat: no-repeat;
            mask-repeat: no-repeat;
    animation: net-dot-scan 7s linear infinite;
  }
  @keyframes net-dot-scan {
    from { -webkit-mask-position: 160% 160%; mask-position: 160% 160%; }
    to   { -webkit-mask-position: -60% -60%; mask-position: -60% -60%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .story-bg-pattern::before { animation: none; opacity: 0; }
  }
</style>

<!-- ============= 1. SUB-HERO (stacked, network rollup motion above text) ============= -->
<section class="sub-hero" aria-label="Hero">
  <div class="sub-hero__inner">
    <div class="sub-hero__visual">
      <svg class="hero-roll" viewBox="0 0 800 440" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Diagram: many member pharmacy stores on the left consolidating into a single network rollup view on the right, showing active members, services delivered, and top performing locations.">

        <!-- Left side: 6x4 mesh of member-store dots -->
        <g class="roll-mesh">
          <!-- Row 1 -->
          <circle cx="80"  cy="100" r="8" class="roll-active roll-a-1" />
          <circle cx="130" cy="100" r="8" />
          <circle cx="180" cy="100" r="8" class="roll-active roll-a-3" />
          <circle cx="230" cy="100" r="8" />
          <circle cx="280" cy="100" r="8" />
          <circle cx="330" cy="100" r="8" class="roll-active roll-a-5" />
          <!-- Row 2 -->
          <circle cx="80"  cy="170" r="8" />
          <circle cx="130" cy="170" r="8" class="roll-active roll-a-2" />
          <circle cx="180" cy="170" r="8" />
          <circle cx="230" cy="170" r="8" class="roll-active roll-a-4" />
          <circle cx="280" cy="170" r="8" />
          <circle cx="330" cy="170" r="8" />
          <!-- Row 3 -->
          <circle cx="80"  cy="240" r="8" class="roll-active roll-a-4" />
          <circle cx="130" cy="240" r="8" />

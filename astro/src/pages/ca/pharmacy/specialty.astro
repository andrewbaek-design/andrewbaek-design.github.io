  .sm-report .sr-bar:nth-child(6) { height: 80%; animation-delay: 0.60s; }
  .sm-report .sr-bar:nth-child(7) { height: 60%; animation-delay: 0.72s; }
  .sm-report .sr-bar:nth-child(8) { height: 90%; animation-delay: 0.84s; }
  @keyframes sr-grow {
    0%, 100% { background: rgba(195, 196, 48, 0.3); transform: scaleY(0.85); }
    50%      { background: var(--matcha);             transform: scaleY(1); }

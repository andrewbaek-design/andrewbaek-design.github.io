---
import BaseLayout from '../../../layouts/BaseLayoutCa.astro';
---
<BaseLayout
  title="For Specialty Pharmacy, MedMe Health"
  description="The end-to-end platform for specialty pharmacy, powered by three AI agents working across every stage of the patient journey, from referral and onboarding through outcome reporting."
  showAnnouncement={false}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/pharmacy/specialty" />
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/" />
  </Fragment>

<style>

  /* ============================================================
     SPECIALTY sub-page. Layout: 3 AI agents introduced, 4 stages
     with 3 service cards each, featured AI agent (Patient
     Concierge), commitment band. Leans on the front-page design
     system (.tile, .tile__head, .h-display, .kicker, .pill,
     .tile--navy) plus the independents sub-hero pattern. Each
     stage gets its own motion idiom; cards within a stage carry
     small variations so all 12 service cards read as differentiated.
     ============================================================ */

  /* ====== HERO: stacked (patient-journey motion above text) ===== */
  .sub-hero {
    background: var(--seashell);
    padding: 2rem 1.5rem 3.5rem;
    position: relative;
    overflow: hidden;
  }
  .sub-hero__inner {
    max-width: var(--container);
    margin: 0 auto;
    padding-inline: var(--tile-pad-x);
    position: relative;
  }
  .sub-hero__visual {
    position: relative;
    max-width: 1080px;
    margin: 0 auto;
    border: 1px solid rgba(6, 62, 84, 0.12);
    border-radius: var(--radius-lg);
    overflow: hidden;
    /* Mockup acts as a backdrop; soft bottom fade so the headline
       can sit slightly over the lower portion of the SVG. */
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 60%, rgba(0,0,0,0) 100%);
            mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 60%, rgba(0,0,0,0) 100%);
    pointer-events: none;
  }
  .hero-mockup {
    display: block;
    width: 100%;
    max-width: 820px;
    height: auto;
    margin: 0 auto;
  }
  .sub-hero__text {
    text-align: center;
    max-width: 820px;
    margin: -110px auto 0;
    position: relative;
    z-index: 2;
  }
  .sub-hero h1.h-display {
    font-size: clamp(28px, 4.4vw, 54px);
    line-height: 1.08;
    letter-spacing: -0.028em;
    margin: 0.75rem auto 1rem;
    text-align: center;
    text-wrap: balance;
  }
  .sub-hero h1.h-display .accent { color: var(--matcha); }
  .sub-hero__lede {
    font-size: 1.1rem;
    line-height: 1.55;
    color: rgba(6, 62, 84, 0.72);
    margin: 0 auto 1.75rem;
    max-width: 680px;
  }
  .sub-hero__cta {
    display: inline-flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  @media (max-width: 980px) { .sub-hero__text { margin-top: -80px; } }
  @media (max-width: 640px) { .sub-hero__text { margin-top: -50px; } }

  /* ====== HERO JOURNEY GRAPHIC ===================================
     Horizontal patient-journey timeline. Four stage stops
     connected by a straight line. Each stage stop pulses on
     a staggered loop. Static otherwise, reduced-motion handles
     the ring animations via CSS. */
  .hero-journey {
    position: relative;
    width: 100%;
    max-width: 880px;
    margin: 0 auto;
    aspect-ratio: 880 / 360;
    display: block;
  }
  .hero-journey .jr-path {
    stroke: rgba(6, 62, 84, 0.16);
    stroke-width: 2;
    fill: none;
  }
  .hero-journey .jr-stage circle {
    fill: var(--white);
    stroke: rgba(6, 62, 84, 0.18);
    stroke-width: 1.5;
  }
  .hero-journey .jr-stage .jr-stage-num {
    fill: var(--indigo);
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    text-anchor: middle;
    dominant-baseline: central;
  }
  .hero-journey .jr-stage .jr-stage-ring {
    fill: none;
    stroke: var(--matcha);
    stroke-width: 1.5;
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
    animation: jr-stage-ring 6.5s ease-in-out infinite;
  }
  .hero-journey .jr-stage:nth-of-type(1) .jr-stage-ring { animation-delay: 0s; }
  .hero-journey .jr-stage:nth-of-type(2) .jr-stage-ring { animation-delay: 1.3s; }
  .hero-journey .jr-stage:nth-of-type(3) .jr-stage-ring { animation-delay: 2.6s; }
  .hero-journey .jr-stage:nth-of-type(4) .jr-stage-ring { animation-delay: 3.9s; }
  .hero-journey .jr-stage:nth-of-type(5) .jr-stage-ring { animation-delay: 5.2s; }
  @keyframes jr-stage-ring {
    0%, 80%, 100% { opacity: 0; transform: scale(1); }
    8%            { opacity: 0.7; transform: scale(1); }
    20%           { opacity: 0; transform: scale(2.4); }
  }
  .hero-journey .jr-stage text.jr-stage-label {
    fill: var(--indigo);
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    text-anchor: middle;
    letter-spacing: -0.005em;
  }
  .hero-journey .jr-pulse {
    fill: var(--matcha);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-journey .jr-stage-ring,
    .hero-journey .jr-pulse { animation: none; opacity: 0; display: none; }
  }
  @media (max-width: 980px) {
    .sub-hero__visual { margin-inline: calc(-1 * var(--tile-pad-x)); }
    .hero-journey .jr-stage .jr-stage-num { font-size: 18px; }
    .hero-journey .jr-stage text.jr-stage-label { font-size: 16px; }
  }
  @media (max-width: 700px) {
    .sub-hero { padding-inline: 0.5rem; }
    .sub-hero__visual { margin-inline: 0; }
    .hero-journey .jr-stage .jr-stage-num { font-size: 22px; }
    .hero-journey .jr-stage text.jr-stage-label { font-size: 19px; }
  }

  /* ====== AI AGENTS introduction (3 cards) ===================== */
  .agents-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 900px) { .agents-grid { grid-template-columns: 1fr; } }
  .agent-card {
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    position: relative;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .agent-card:hover {
    transform: translateY(-3px);
    border-color: rgba(6, 62, 84, 0.18);
  }
  .agent-card__icon {
    display: inline-flex;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    background: rgba(195, 196, 48, 0.14);
    border-radius: 10px;
    margin-bottom: 1rem;
  }
  .agent-card__icon svg { width: 24px; height: 24px; stroke: var(--matcha); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .agent-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--indigo);
  }
  .agent-card p { margin: 0; color: rgba(6, 62, 84, 0.72); line-height: 1.55; }

  /* ====== STAGE SECTIONS (alternating tile backgrounds) =========
     Each .stage-section is a tile with kicker + h2 + 3 stage cards.
     The 4 stages alternate light / very-light / light / very-light
     so the rhythm reads as a journey progression. */
  .stage-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 1000px) { .stage-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .stage-grid { grid-template-columns: 1fr; } }
  .stage-card {
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: none;
    transition: transform 0.25s ease, border-color 0.25s ease;
    display: flex;
    flex-direction: column;
  }
  .stage-card:hover {
    transform: translateY(-3px);
    border-color: rgba(6, 62, 84, 0.18);
  }
  .stage-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--indigo);
    letter-spacing: -0.012em;
  }
  .stage-card p { margin: 0 0 1rem; color: rgba(6, 62, 84, 0.72); line-height: 1.55; font-size: 0.95rem; }
  .stage-card__motion {
    width: 100%;
    height: 100px;
    background: rgba(195, 196, 48, 0.06);
    border-radius: 10px;
    margin-bottom: 1.25rem;
    overflow: hidden;
    position: relative;
  }
  .stage-card__tags {
    margin-top: auto;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .stage-card__tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    color: var(--indigo);
    background: rgba(195, 196, 48, 0.14);
    border-radius: 999px;
    padding: 3px 10px;
    letter-spacing: 0.01em;
  }
  .stage-card__tag--clerk {
    background: rgba(6, 62, 84, 0.08);
    color: rgba(6, 62, 84, 0.85);
  }

  /* 12 distinct stage-card motion graphics, one per card. Each
     motion is themed to the specific service the card describes,
     so the four cards in any one stage no longer share identical
     animation idioms. Grouped here by stage for navigability. */

  /* === STAGE 01 / Card 1, Referrals: digital intake rows filling === */
  .sm-intake {
    padding: 18px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    justify-content: center;
  }
  .sm-intake .si-row {
    height: 8px;
    border-radius: 3px;
    background: rgba(6, 62, 84, 0.08);
    overflow: hidden;
    position: relative;
  }
  .sm-intake .si-row::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--matcha);
    transform: scaleX(0);
    transform-origin: left center;
    animation: si-fill 3.6s ease-in-out infinite;
  }
  .sm-intake .si-row:nth-child(1)::after { animation-delay: 0s; }
  .sm-intake .si-row:nth-child(2)::after { animation-delay: 0.25s; }
  .sm-intake .si-row:nth-child(3)::after { animation-delay: 0.5s; }
  @keyframes si-fill {
    0%, 75%, 100% { transform: scaleX(0); }
    35%, 55%      { transform: scaleX(1); }
  }

  /* === STAGE 01 / Card 2, Program Enrollment: eligibility checks === */
  .sm-elig {
    padding: 18px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }
  .sm-elig .se-box {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 2px solid rgba(195, 196, 48, 0.4);
    background: transparent;
    position: relative;
    animation: se-check 4.2s ease-in-out infinite;
  }
  .sm-elig .se-box::after {
    content: "";
    position: absolute;
    left: 50%; top: 50%;
    width: 10px; height: 5px;
    border-left: 2.5px solid var(--indigo);
    border-bottom: 2.5px solid var(--indigo);
    transform: translate(-50%, -65%) rotate(-45deg);
    opacity: 0;
    animation: se-mark 4.2s ease-in-out infinite;
  }
  .sm-elig .se-box:nth-child(1) { animation-delay: 0s; }
  .sm-elig .se-box:nth-child(2) { animation-delay: 0.4s; }
  .sm-elig .se-box:nth-child(3) { animation-delay: 0.8s; }
  .sm-elig .se-box:nth-child(1)::after { animation-delay: 0s; }
  .sm-elig .se-box:nth-child(2)::after { animation-delay: 0.4s; }
  .sm-elig .se-box:nth-child(3)::after { animation-delay: 0.8s; }
  @keyframes se-check {
    0%, 30%, 100% { background: transparent; border-color: rgba(195, 196, 48, 0.4); }
    45%, 85%      { background: var(--matcha); border-color: var(--matcha); }
  }
  @keyframes se-mark {
    0%, 30%, 100% { opacity: 0; }
    45%, 85%      { opacity: 1; }
  }

  /* === STAGE 01 / Card 3, Prior Auth: scan over doc grid === */
  .sm-pa {
    padding: 12px;
    position: relative;
    height: 100%;
    overflow: hidden;
  }
  .sm-pa .sp-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
    height: 100%;
    align-content: center;
  }
  .sm-pa .sp-cell {
    height: 12px;
    background: rgba(6, 62, 84, 0.08);
    border-radius: 2px;
  }
  .sm-pa .sp-cell:nth-child(2n) { background: rgba(195, 196, 48, 0.22); }
  .sm-pa::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 35%, rgba(195, 196, 48, 0.5) 50%, transparent 65%);
    background-size: 100% 60%;
    background-repeat: no-repeat;
    animation: sp-scan 3s linear infinite;
  }
  @keyframes sp-scan {
    from { background-position: 0 -60%; }
    to   { background-position: 0 160%; }
  }

  /* === STAGE 02 / Card 4, Delivery: 3-stop tracker (package → truck →
     delivered). Connecting line fills with matcha as each stop lights
     up in sequence, suggesting a delivery progressing on schedule. == */
  .sm-delivery {
    padding: 0 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }
  .sm-delivery .sd-line {
    position: absolute;
    left: 60px;
    right: 60px;
    top: 50%;
    height: 3px;
    background: rgba(6, 62, 84, 0.12);
    border-radius: 2px;
    transform: translateY(-50%);
    z-index: 0;
    overflow: hidden;
  }
  .sm-delivery .sd-line::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--matcha);
    border-radius: inherit;
    transform-origin: left;
    transform: scaleX(0);
    animation: sd-fill 3.6s cubic-bezier(0.22, 0.61, 0.36, 1) infinite;
  }
  .sm-delivery .sd-stop {
    position: relative;
    z-index: 1;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--white);
    border: 2px solid rgba(6, 62, 84, 0.18);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(6, 62, 84, 0.55);
    animation: sd-stop 3.6s ease-in-out infinite;
  }
  .sm-delivery .sd-stop svg { width: 18px; height: 18px; fill: currentColor; }
  .sm-delivery .sd-stop--1 { animation-delay: 0.4s; }
  .sm-delivery .sd-stop--2 { animation-delay: 1.6s; }
  .sm-delivery .sd-stop--3 { animation-delay: 2.8s; }
  @keyframes sd-fill {
    0%, 8%    { transform: scaleX(0); }
    86%, 100% { transform: scaleX(1); }
  }
  @keyframes sd-stop {
    0%, 12%, 100% {
      background: var(--white);
      border-color: rgba(6, 62, 84, 0.18);
      color: rgba(6, 62, 84, 0.55);
    }
    20%, 80% {
      background: var(--matcha);
      border-color: var(--matcha);
      color: var(--indigo);
    }
  }

  /* === STAGE 02 / Card 5, Scheduling: chat in/out bubbles === */
  .sm-chat {
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
  }
  .sm-chat .sa-bubble {
    height: 12px;
    border-radius: 6px;
    opacity: 0;
    animation: sa-bubble 3.8s ease-in-out infinite;
  }
  .sm-chat .sa-bubble--out {
    background: rgba(6, 62, 84, 0.18);
    align-self: flex-start;
    max-width: 70%;
  }
  .sm-chat .sa-bubble--in {
    background: var(--matcha);
    align-self: flex-end;
    max-width: 60%;
  }
  .sm-chat .sa-bubble:nth-child(1) { width: 70%; animation-delay: 0s; }
  .sm-chat .sa-bubble:nth-child(2) { width: 55%; animation-delay: 0.5s; }
  .sm-chat .sa-bubble:nth-child(3) { width: 60%; animation-delay: 1.0s; }
  @keyframes sa-bubble {
    0%, 70%, 100% { opacity: 0; transform: translateY(6px); }
    18%, 50%      { opacity: 1; transform: translateY(0); }
  }

  /* === STAGE 02 / Card 6, Shortage outreach: broadcast fan-out
     (central hub + 4 patient-receiver nodes around it). Hub pulses
     ripples outward; each target lights up in sequence to read as
     a batch notification reaching multiple patients at once. ===== */
  .sm-fanout {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .sm-fanout .sf-hub {
    position: relative;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--matcha);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--indigo);
    animation: sf-hub 1.6s ease-in-out infinite;
  }
  .sm-fanout .sf-hub svg { width: 14px; height: 14px; fill: currentColor; }
  .sm-fanout .sf-ring {
    position: absolute;
    top: 50%; left: 50%;
    width: 26px;
    height: 26px;
    margin: -13px 0 0 -13px;
    border-radius: 50%;
    border: 2px solid var(--matcha);
    opacity: 0;
    z-index: 1;
    animation: sf-ring 2.4s ease-out infinite;
  }
  .sm-fanout .sf-ring:nth-of-type(2) { animation-delay: 0.8s; }
  .sm-fanout .sf-ring:nth-of-type(3) { animation-delay: 1.6s; }
  .sm-fanout .sf-target {
    position: absolute;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: rgba(6, 62, 84, 0.22);
    z-index: 2;
    animation: sf-target 2.4s ease-in-out infinite;
  }
  .sm-fanout .sf-target--1 { top: 20%;    left: 22%;  animation-delay: 0.4s; }
  .sm-fanout .sf-target--2 { top: 20%;    right: 22%; animation-delay: 0.8s; }
  .sm-fanout .sf-target--3 { bottom: 20%; left: 22%;  animation-delay: 1.2s; }
  .sm-fanout .sf-target--4 { bottom: 20%; right: 22%; animation-delay: 1.6s; }
  @keyframes sf-hub {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.15); }
  }
  @keyframes sf-ring {
    0%   { transform: scale(1);   opacity: 0.7; }
    100% { transform: scale(4.5); opacity: 0; }
  }
  @keyframes sf-target {
    0%, 30%, 100% { background: rgba(6, 62, 84, 0.22); transform: scale(1); }
    50%, 72%      { background: var(--matcha);          transform: scale(1.3); }
  }

  /* === STAGE 03 / Card 7, Medication review: pharmacist waveform === */
  .sm-wave {
    padding: 0 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }
  .sm-wave .sc-bar {
    width: 4px;
    background: var(--matcha);
    border-radius: 2px;
    animation: sc-pulse 1.6s ease-in-out infinite;
  }
  .sm-wave .sc-bar:nth-child(1)  { height: 24px; animation-delay: 0s; }
  .sm-wave .sc-bar:nth-child(2)  { height: 38px; animation-delay: 0.06s; }
  .sm-wave .sc-bar:nth-child(3)  { height: 28px; animation-delay: 0.12s; }
  .sm-wave .sc-bar:nth-child(4)  { height: 50px; animation-delay: 0.18s; }
  .sm-wave .sc-bar:nth-child(5)  { height: 32px; animation-delay: 0.24s; }
  .sm-wave .sc-bar:nth-child(6)  { height: 60px; animation-delay: 0.30s; }
  .sm-wave .sc-bar:nth-child(7)  { height: 44px; animation-delay: 0.36s; }
  .sm-wave .sc-bar:nth-child(8)  { height: 30px; animation-delay: 0.42s; }
  .sm-wave .sc-bar:nth-child(9)  { height: 52px; animation-delay: 0.48s; }
  .sm-wave .sc-bar:nth-child(10) { height: 26px; animation-delay: 0.54s; }
  .sm-wave .sc-bar:nth-child(11) { height: 42px; animation-delay: 0.60s; }
  .sm-wave .sc-bar:nth-child(12) { height: 30px; animation-delay: 0.66s; }
  @keyframes sc-pulse {
    0%, 100% { transform: scaleY(0.45); opacity: 0.6; }
    50%      { transform: scaleY(1);    opacity: 1; }
  }

  /* === STAGE 03 / Card 8, Telehealth: two video tiles + LIVE pill === */
  .sm-video {
    padding: 14px;
    position: relative;
    display: flex;
    gap: 10px;
    align-items: center;
    justify-content: center;
  }
  .sm-video .sv-tile {
    width: 60px;
    height: 42px;
    background: rgba(6, 62, 84, 0.1);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sm-video .sv-tile::after {
    content: "";
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--matcha);
  }
  .sm-video .sv-live {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 9px;
    font-weight: 700;
    color: var(--indigo);
    background: rgba(195, 196, 48, 0.18);
    padding: 3px 9px;
    border-radius: 999px;
    letter-spacing: 0.05em;
  }
  .sm-video .sv-live::before {
    content: "";
    width: 5px;
    height: 5px;
    background: var(--matcha);
    border-radius: 50%;
    animation: sv-blink 1.4s ease-in-out infinite;
  }
  @keyframes sv-blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.3; }
  }

  /* === STAGE 03 / Card 9, Patient education: 7-day calendar grid === */
  .sm-calendar {
    padding: 14px 22px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sm-calendar .sc-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 5px;
    width: 100%;
  }
  .sm-calendar .sc-day {
    aspect-ratio: 1;
    background: rgba(6, 62, 84, 0.08);
    border-radius: 3px;
    position: relative;
  }
  .sm-calendar .sc-day--checked {

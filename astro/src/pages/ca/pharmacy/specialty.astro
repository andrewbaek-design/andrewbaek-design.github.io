  .sm-orbit .so-node--2 { bottom: 12%; left: -6px; }
  .sm-orbit .so-node--3 { bottom: 12%; right: -6px; }
  .sm-orbit .so-center {
    position: absolute;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--indigo);
    z-index: 2;
  }
  @keyframes so-rotate {
    from { transform: rotate(0deg); }

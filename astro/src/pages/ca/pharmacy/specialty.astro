  .sm-calendar .sc-day--checked:nth-of-type(3) { animation-delay: 1.2s; }
  .sm-calendar .sc-day--checked:nth-of-type(4) { animation-delay: 1.8s; }
  @keyframes sc-day-pop {
    0%, 50%, 100% { background: var(--matcha); transform: scale(1); }

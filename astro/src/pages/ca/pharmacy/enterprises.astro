---
import BaseLayout from '../../../layouts/BaseLayoutCa.astro';
import LogoMedme from '../../../components/LogoMedme.astro';
---
<BaseLayout
  title="For Enterprise Pharmacy, MedMe Health"
  description="The platform of choice for Canadian enterprise pharmacy. The strategic partner with the scale, integrations, and AI capabilities to support the largest pharmacy networks in Canada."
  showAnnouncement={false}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/pharmacy/enterprises" />
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/" />
  </Fragment>

<style>

  /* ============================================================
     ENTERPRISES sub-page. Leans on the front-page design system
     (.tile, .tile__head, .h-display, .kicker, .pill, .tile--navy)
     plus the independents sub-hero pattern.

     Hero: A reporting-dashboard mockup sits as a faded background
     above the headline. Mirrors the Looker-style enterprise
     reporting view Christine flagged as the visual reference for
     this page (filter pills, two stat tiles, two pie charts, a
     monthly bar chart). The mockup fades to transparent at the
     bottom; the headline rises into that fade via negative margin.

     Sections: Strategic Partnership, Modular Architecture (4
     tiers), Interoperability and Future-Forward (4 cards), Rollout
     Playbook (3 case patterns), Navy Operations (3 value blocks).
     ============================================================ */

  /* ====== HERO: dashboard mockup as faded BG above text ========= */
  .sub-hero__bg {
    position: relative;
    max-width: 1120px;
    margin: 0 auto;
    border: 1px solid rgba(6, 62, 84, 0.12);
    border-radius: var(--radius-lg);
    overflow: hidden;
    /* Fade the bottom 55% of the mockup to transparent so the
       headline rises out of it cleanly. */
    -webkit-mask-image: linear-gradient(to bottom,
                          rgba(0, 0, 0, 1) 0%,
                          rgba(0, 0, 0, 1) 45%,
                          rgba(0, 0, 0, 0) 95%);
            mask-image: linear-gradient(to bottom,
                          rgba(0, 0, 0, 1) 0%,
                          rgba(0, 0, 0, 1) 45%,
                          rgba(0, 0, 0, 0) 95%);
    pointer-events: none;
  }
  .sub-hero__text {
    text-align: center;
    max-width: 760px;
    /* Negative margin pulls the headline UP into the dashboard's
       fade zone; the dashboard is set to fade ~45% down so the
       headline naturally sits in the transparent area. */
    margin: -140px auto 0;
    position: relative;
    z-index: 2;
  }
  .sub-hero h1.h-display {
    font-size: clamp(28px, 4.4vw, 54px);
    line-height: 1.08;
    letter-spacing: -0.028em;
    margin: 0.75rem auto 1rem;
    text-align: center;
    text-wrap: balance;
  }
  .sub-hero__lede {
    font-size: 1.1rem;
    line-height: 1.55;
    color: rgba(6, 62, 84, 0.72);
    margin: 0 auto 1.75rem;
    max-width: 640px;
  }
  @media (max-width: 980px) {
    .sub-hero__text { margin-top: -90px; }
  }
  @media (max-width: 640px) {
    .sub-hero__text { margin-top: -60px; }
  }

  /* ====== DASHBOARD MOCKUP (decorative) =========================
     Mirrors the Looker Studio "Pharmacy Network Usage Data" panel
     Christine referenced in the meeting: filter row + two stat
     tiles + two donut charts + a monthly bar chart. Subtle
     animations keep it feeling live without competing with the
     headline text rising into its fade zone. */
  .dash {
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: 16px;
    padding: 20px 22px;
    font-family: var(--font-display);
    color: var(--indigo);
    box-shadow: 0 12px 40px rgba(6, 62, 84, 0.06);
  }
  .dash__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 14px;
    margin-bottom: 14px;
    border-bottom: 1px solid rgba(6, 62, 84, 0.08);
  }
  .dash__title {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .dash__brand {
    display: inline-flex;
    align-items: center;
    color: var(--indigo);
    height: 22px;
  }
  .dash__brand svg {
    height: 22px;
    width: auto;
    display: block;
  }
  /* Filter row: 4 dropdown pills + a yellow "Save Filters" button */
  .dash__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin-bottom: 18px;
  }
  .dash__pill {
    background: rgba(6, 62, 84, 0.05);
    border: 1px solid rgba(6, 62, 84, 0.1);
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 500;
    color: var(--indigo);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .dash__pill::after {
    content: "▾";
    font-size: 10px;
    opacity: 0.5;
  }
  .dash__pill-save {
    background: var(--matcha);
    color: var(--indigo);
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 700;
    margin-left: auto;
  }
  /* Top grid: stat tiles left, donut block right */
  .dash__grid {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 18px;
    margin-bottom: 18px;
  }
  .dash__stats {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .dash__stat {
    background: rgba(6, 62, 84, 0.04);
    border-radius: 12px;
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .dash__stat-label {
    font-size: 11px;
    color: rgba(6, 62, 84, 0.55);
    font-weight: 500;
    text-transform: none;
  }
  .dash__stat-value {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--indigo);
  }
  .dash__pies {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .dash__pie-block {
    background: rgba(6, 62, 84, 0.04);
    border-radius: 12px;
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .dash__pie-title {
    font-size: 13px;
    color: rgba(6, 62, 84, 0.65);
    font-weight: 600;
  }
  .dash__pie-row {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .dash__pie {
    width: 140px;
    height: 140px;
    flex-shrink: 0;
  }
  .dash__pie circle {
    fill: transparent;
    stroke-width: 32;
    transform-origin: 50px 50px;
    transform: rotate(-90deg);
    animation: dash-pie-breathe 6s ease-in-out infinite;
  }
  .dash__pie circle:nth-of-type(1) { animation-delay: 0s; }
  .dash__pie circle:nth-of-type(2) { animation-delay: 0.4s; }
  .dash__pie circle:nth-of-type(3) { animation-delay: 0.8s; }
  .dash__pie circle:nth-of-type(4) { animation-delay: 1.2s; }
  .dash__pie circle:nth-of-type(5) { animation-delay: 1.6s; }
  @keyframes dash-pie-breathe {
    0%, 100% { stroke-width: 32; }
    50%      { stroke-width: 34; }
  }
  .dash__pie-legend {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 12px;
    color: rgba(6, 62, 84, 0.72);
    font-weight: 500;
  }
  .dash__pie-legend span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .dash__pie-legend i {
    width: 11px;
    height: 11px;
    border-radius: 3px;
    display: inline-block;
    flex-shrink: 0;
  }
  /* Service-by-region performance matrix. Replaces the old pie-chart
     pair, surfaces a multi-store insight (which services perform best
     where) that an enterprise leader could act on in a single glance.
     The cell with the matcha "headroom" tag is the implied next move
     called out in the insight band below. */
  .dash__matrix {
    background: rgba(6, 62, 84, 0.04);
    border-radius: 12px;
    padding: 16px 18px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .dash__matrix-title {
    font-size: 11px;
    color: rgba(6, 62, 84, 0.55);
    font-weight: 500;
  }
  .dash__matrix-grid {
    display: grid;
    grid-template-columns: 64px repeat(5, 1fr);
    gap: 4px;
  }
  .dash__matrix-cell {
    aspect-ratio: 2.4 / 1;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(195, 196, 48, 0.10);
    font-size: 10px;
    font-weight: 600;
    color: var(--indigo);
  }
  .dash__matrix-cell--head {
    background: transparent;
    color: rgba(6, 62, 84, 0.55);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.04em;
    aspect-ratio: auto;
  }
  .dash__matrix-cell--label {
    background: transparent;
    color: var(--indigo);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: -0.005em;
    text-align: left;
    justify-content: flex-start;
    padding-left: 2px;
    aspect-ratio: auto;
  }
  .dash__matrix-cell--opportunity {
    background: var(--matcha) !important;
    position: relative;
    box-shadow: 0 0 0 2px rgba(195, 196, 48, 0.35);
    animation: matrix-pulse 2.4s ease-in-out infinite;
  }
  .dash__matrix-tag {
    font-size: 9px;
    font-weight: 800;
    color: var(--indigo);
    line-height: 1.05;
    letter-spacing: -0.01em;
    text-align: center;
  }
  @keyframes matrix-pulse {
    0%, 100% { box-shadow: 0 0 0 2px rgba(195, 196, 48, 0.35); }
    50%      { box-shadow: 0 0 0 5px rgba(195, 196, 48, 0.45); }
  }
  @media (prefers-reduced-motion: reduce) {
    .dash__matrix-cell--opportunity { animation: none; }
  }

  /* Insight callout band — the "what should I do next" takeaway
     that bridges the matrix and the broader network trend chart. */
  .dash__insight {
    display: flex;
    align-items: center;
    gap: 12px;
    background: rgba(195, 196, 48, 0.10);
    border-radius: 12px;
    padding: 12px 16px;
    margin-bottom: 18px;
    font-size: 12px;
    color: var(--indigo);
    line-height: 1.45;
  }
  .dash__insight-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--matcha);
    flex-shrink: 0;
    box-shadow: 0 0 0 4px rgba(195, 196, 48, 0.22);
  }
  .dash__insight-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--indigo);
    text-transform: none;
    flex-shrink: 0;
  }
  .dash__insight-body { color: rgba(6, 62, 84, 0.82); }
  .dash__insight-body strong { color: var(--indigo); font-weight: 700; }

  /* Monthly bar chart at the bottom */
  .dash__chart {
    background: rgba(6, 62, 84, 0.04);
    border-radius: 12px;
    padding: 16px 18px 14px;
  }
  .dash__chart-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }
  .dash__chart-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--indigo);
  }
  .dash__chart-legend {
    display: flex;
    gap: 14px;
    font-size: 10px;
    color: rgba(6, 62, 84, 0.6);
    font-weight: 500;
  }
  .dash__chart-legend span {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .dash__chart-legend i {
    width: 10px;
    height: 10px;
    border-radius: 2px;
  }
  .dash__bars {
    display: flex;
    align-items: flex-end;
    height: 96px;
    gap: 4px;
  }
  .dash__bar-group {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    flex: 1;
  }
  .dash__bar {
    flex: 1;
    border-radius: 2px 2px 0 0;
    animation: dash-bar-rise 4s ease-in-out infinite;
    transform-origin: bottom center;
  }
  .dash__bar--patients { background: var(--indigo); }
  .dash__bar--appts    { background: var(--matcha); }
  @keyframes dash-bar-rise {
    0%, 100% { transform: scaleY(0.9); }
    50%      { transform: scaleY(1); }
  }
  /* Stagger every group's bar animation so the chart feels alive */
  .dash__bar-group:nth-child(1)  .dash__bar { animation-delay: 0s; }
  .dash__bar-group:nth-child(2)  .dash__bar { animation-delay: 0.06s; }
  .dash__bar-group:nth-child(3)  .dash__bar { animation-delay: 0.12s; }
  .dash__bar-group:nth-child(4)  .dash__bar { animation-delay: 0.18s; }
  .dash__bar-group:nth-child(5)  .dash__bar { animation-delay: 0.24s; }
  .dash__bar-group:nth-child(6)  .dash__bar { animation-delay: 0.30s; }
  .dash__bar-group:nth-child(7)  .dash__bar { animation-delay: 0.36s; }
  .dash__bar-group:nth-child(8)  .dash__bar { animation-delay: 0.42s; }
  .dash__bar-group:nth-child(9)  .dash__bar { animation-delay: 0.48s; }
  .dash__bar-group:nth-child(10) .dash__bar { animation-delay: 0.54s; }
  .dash__bar-group:nth-child(11) .dash__bar { animation-delay: 0.60s; }
  .dash__bar-group:nth-child(12) .dash__bar { animation-delay: 0.66s; }
  .dash__bar-group:nth-child(13) .dash__bar { animation-delay: 0.72s; }
  .dash__bar-group:nth-child(14) .dash__bar { animation-delay: 0.78s; }
  .dash__bar-group:nth-child(15) .dash__bar { animation-delay: 0.84s; }
  .dash__bar-group:nth-child(16) .dash__bar { animation-delay: 0.90s; }
  @media (prefers-reduced-motion: reduce) {
    .dash__pie circle,
    .dash__bar { animation: none; }
  }
  @media (max-width: 900px) {
    .dash { padding: 14px 16px; }
    .dash__grid { grid-template-columns: 1fr; }
    .dash__pies { grid-template-columns: 1fr 1fr; }
    .dash__stats { flex-direction: row; }
    .dash__pill-save { margin-left: 0; }
  }
  @media (max-width: 640px) {
    .dash__title { font-size: 13px; }
    .dash__stat-value { font-size: 26px; }
    .dash__pie { width: 110px; height: 110px; }
    .dash__pie-legend { font-size: 11px; }
    .dash__bars { height: 70px; }
  }

  /* ====== STRATEGIC PARTNER: 3-feature card grid w/ per-card motion */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }
  @media (max-width: 1000px) { .feature-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .feature-grid { grid-template-columns: 1fr; } }
  .feature {
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: none;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .feature:hover {
    transform: translateY(-3px);
    border-color: rgba(6, 62, 84, 0.18);
  }
  .feat-graphic {
    width: 100%;
    height: 130px;
    background: rgba(195, 196, 48, 0.06);
    border-radius: 10px;
    margin-bottom: 1.25rem;
    overflow: hidden;
    position: relative;
  }
  .feature h3 {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--indigo);
    letter-spacing: -0.012em;
  }
  .feature p { margin: 0; color: rgba(6, 62, 84, 0.72); line-height: 1.55; }

  /* 1. Depth: stacked horizontal layers rising bottom-up */
  .feat-depth {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 8px;
    padding: 18px 24px;
  }
  .feat-depth .layer {
    width: 36px;
    background: var(--matcha);
    border-radius: 4px;
    opacity: 0;
    animation: depth-rise 3.4s ease-in-out infinite;
  }
  .feat-depth .layer:nth-child(1) { height: 22px; animation-delay: 0s; }
  .feat-depth .layer:nth-child(2) { height: 38px; animation-delay: 0.18s; }
  .feat-depth .layer:nth-child(3) { height: 54px; animation-delay: 0.36s; }
  .feat-depth .layer:nth-child(4) { height: 70px; animation-delay: 0.54s; }
  .feat-depth .layer:nth-child(5) { height: 86px; animation-delay: 0.72s; }
  @keyframes depth-rise {
    0%, 100% { opacity: 0.25; transform: translateY(8px); }
    50%      { opacity: 1;    transform: translateY(0); }
  }

  /* 2. AI-Native: 7-node neural mesh, lines trace continuously */
  .feat-ai svg { width: 100%; height: 100%; display: block; }
  .feat-ai .ai-line {
    stroke: rgba(195, 196, 48, 0.5);
    stroke-width: 1.5;
    fill: none;
    stroke-dasharray: 120;
    stroke-dashoffset: 120;
    animation: ai-line-trace 3s linear infinite;
  }
  .feat-ai .ai-line:nth-of-type(2) { animation-delay: 0.3s; }
  .feat-ai .ai-line:nth-of-type(3) { animation-delay: 0.6s; }
  .feat-ai .ai-line:nth-of-type(4) { animation-delay: 0.9s; }
  .feat-ai .ai-line:nth-of-type(5) { animation-delay: 1.2s; }
  .feat-ai .ai-line:nth-of-type(6) { animation-delay: 1.5s; }
  @keyframes ai-line-trace {
    0%   { stroke-dashoffset: 120; opacity: 0; }
    20%  { opacity: 1; }
    100% { stroke-dashoffset: -120; opacity: 0; }
  }
  .feat-ai .ai-node { fill: var(--matcha); }
  .feat-ai .ai-node--mid { fill: var(--indigo); }

  /* 3. Experience: 5 timeline ticks lighting up in sequence */
  .feat-exp {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 0 24px;
  }
  .feat-exp .tick {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(195, 196, 48, 0.18);
    border: 2px solid rgba(195, 196, 48, 0.35);
    flex-shrink: 0;
    animation: exp-light 3.6s ease-in-out infinite;
  }
  .feat-exp .tick:nth-child(1) { animation-delay: 0s; }
  .feat-exp .tick:nth-child(3) { animation-delay: 0.4s; }
  .feat-exp .tick:nth-child(5) { animation-delay: 0.8s; }
  .feat-exp .tick:nth-child(7) { animation-delay: 1.2s; }
  .feat-exp .tick:nth-child(9) { animation-delay: 1.6s; }
  .feat-exp .tick-line {
    flex: 1;
    height: 2px;
    background: rgba(195, 196, 48, 0.18);
    max-width: 28px;
  }
  @keyframes exp-light {
    0%, 80%, 100% { background: rgba(195, 196, 48, 0.18); border-color: rgba(195, 196, 48, 0.35); transform: scale(1); }
    20%, 60%      { background: var(--matcha); border-color: var(--matcha); transform: scale(1.25); }
  }

  @media (prefers-reduced-motion: reduce) {
    .feat-depth .layer,
    .feat-ai .ai-line,
    .feat-exp .tick { animation: none; opacity: 1; }
  }

  /* ====== MODULAR ARCHITECTURE: 4 integration tiers ============= */
  .tier-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem;
  }
  @media (max-width: 1000px) { .tier-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px)  { .tier-grid { grid-template-columns: 1fr; } }
  /* Dark navy cards on a light section, so the modular architecture
     story reads as visually weightier. Christine flagged these as
     "really important", so the dark treatment signals priority. */
  .tier {
    background: var(--indigo);
    border: 1px solid rgba(195, 196, 48, 0.18);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    display: flex;
    flex-direction: column;
    box-shadow: 0 12px 32px rgba(6, 62, 84, 0.08);
  }
  .tier:hover {
    transform: translateY(-3px);
    border-color: var(--matcha);
    box-shadow: 0 16px 38px rgba(6, 62, 84, 0.16), 0 0 0 1px rgba(195, 196, 48, 0.2);
  }
  .tier__num {
    font-family: ui-monospace, "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--matcha);
    margin-bottom: 0.5rem;
    letter-spacing: 0.06em;
    text-transform: none;
  }
  .tier h3 {
    margin: 0 0 0.4rem;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--seashell);
  }
  .tier p { margin: 0 0 0.6rem; font-size: 0.9rem; color: rgba(250, 249, 245, 0.72); line-height: 1.5; }
  .tier__detail {
    margin-top: auto;
    font-size: 0.8rem;
    color: rgba(195, 196, 48, 0.85);
    font-family: ui-monospace, "JetBrains Mono", monospace;
    padding-top: 0.6rem;
    border-top: 1px dashed rgba(195, 196, 48, 0.22);
  }
  .tier__motion {
    width: 100%;
    height: 80px;
    background: rgba(250, 249, 245, 0.05);
    border-radius: 8px;
    margin-bottom: 1rem;
    overflow: hidden;
    position: relative;
    border: 1px solid rgba(250, 249, 245, 0.08);
  }

  /* Tier 1: Embedded UI, browser frame with content rows filling */
  .tm-embed {
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .tm-embed .tm-embed-bar {
    height: 6px;
    background: rgba(250, 249, 245, 0.2);
    border-radius: 3px;
  }
  .tm-embed .tm-embed-row {
    height: 8px;
    background: var(--matcha);
    border-radius: 3px;
    opacity: 0;
    animation: tm-embed-fill 2.8s ease-in-out infinite;
  }
  .tm-embed .tm-embed-row:nth-of-type(1) { width: 70%; animation-delay: 0.2s; }
  .tm-embed .tm-embed-row:nth-of-type(2) { width: 50%; animation-delay: 0.5s; }
  .tm-embed .tm-embed-row:nth-of-type(3) { width: 60%; animation-delay: 0.8s; }
  @keyframes tm-embed-fill {
    0%, 100% { opacity: 0; transform: translateX(-8px); }
    35%, 75% { opacity: 1; transform: translateX(0); }
  }

  /* Tier 2: APIs, code line with blinking cursor */
  .tm-api {
    font-family: ui-monospace, "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--seashell);
    padding: 14px 16px;
    line-height: 1.4;
  }
  .tm-api .tm-api-key { color: var(--matcha); }
  .tm-api .tm-api-bracket { color: rgba(250, 249, 245, 0.45); }
  .tm-api .tm-api-cursor {
    display: inline-block;
    width: 6px;
    height: 12px;
    background: var(--matcha);
    vertical-align: -2px;
    margin-left: 2px;
    animation: tm-cursor-blink 1.1s steps(2, end) infinite;
  }
  @keyframes tm-cursor-blink {
    0%, 50%   { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Tier 3: Data feeds, rows scrolling upward continuously */
  .tm-data {
    padding: 6px 10px;
    overflow: hidden;
    position: relative;
  }
  .tm-data-rows {
    animation: tm-data-scroll 4.2s linear infinite;
  }
  .tm-data-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 14px;
    border-bottom: 1px solid rgba(250, 249, 245, 0.1);
    padding: 0 2px;
  }
  .tm-data-row .tm-data-label {
    width: 30%;
    height: 4px;
    background: rgba(250, 249, 245, 0.28);
    border-radius: 2px;
  }
  .tm-data-row .tm-data-val {
    width: 20%;
    height: 4px;
    background: var(--matcha);
    border-radius: 2px;
  }
  @keyframes tm-data-scroll {
    from { transform: translateY(0); }
    to   { transform: translateY(-60px); }
  }

  /* Tier 4: Legacy/RPA, sweep across grid (RPA reading rows) */
  .tm-rpa {
    padding: 6px 10px;
    position: relative;
  }
  .tm-rpa-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 4px;
    margin-top: 6px;
  }
  .tm-rpa-cell {
    height: 8px;
    background: rgba(250, 249, 245, 0.14);
    border-radius: 2px;
  }
  .tm-rpa-sweep {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(195, 196, 48, 0.5) 45%,
      rgba(195, 196, 48, 0.85) 50%,
      rgba(195, 196, 48, 0.5) 55%,
      transparent 100%);
    background-size: 40% 100%;
    background-repeat: no-repeat;
    animation: tm-rpa-sweep 2.4s linear infinite;
  }
  @keyframes tm-rpa-sweep {
    from { background-position: -50% 0; }
    to   { background-position: 150% 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tm-embed .tm-embed-row,
    .tm-api .tm-api-cursor,
    .tm-data-rows,
    .tm-rpa-sweep { animation: none; opacity: 1; }

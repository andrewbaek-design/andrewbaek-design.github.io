---
import BaseLayout from '../../../layouts/BaseLayoutCa.astro';
import LogoMedme from '../../../components/LogoMedme.astro';
---
<BaseLayout
  title="For Pharmacy Associations, MedMe Health"
  description="MedMe partners with state and national pharmacy associations to launch clinical-service pilots, expand member revenue, and produce the outcomes data associations need to advance pharmacist scope of practice."
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/partners/pharmacy-associations" />
  </Fragment>

<style>

  /* ============================================================
     PHARMACY ASSOCIATIONS sub-page. Built off the Enterprises
     template (.sub-hero overlap pattern, .tier-grid for dark
     benefit cards, .rollout-grid for the pilot timeline) plus a
     bespoke hero "constellation" motion graphic that visualizes
     the MedMe / Association / Member Pharmacy relationship.

     Featured case study: PANS Member Pilot. Anchored on the
     Pharmacy Association of Nova Scotia collaboration so
     the page reads as a working proof point, not a pitch deck.
     ============================================================ */

  /* ====== HERO: constellation motion graphic, faded BG above text */
  .sub-hero__bg {
    position: relative;
    max-width: 1120px;
    margin: 0 auto;
    pointer-events: none;
  }
  .sub-hero__text {
    text-align: center;
    max-width: 760px;
    margin: -150px auto 0;
    position: relative;
    z-index: 2;
  }
  .sub-hero h1.h-display {
    font-size: clamp(28px, 4.4vw, 54px);
    line-height: 1.08;
    letter-spacing: -0.028em;
    margin: 0.75rem auto 1rem;
    text-align: center;
    text-wrap: balance;
  }
  .sub-hero__lede {
    font-size: 1.1rem;
    line-height: 1.55;
    color: rgba(6, 62, 84, 0.72);
    margin: 0 auto 1.75rem;
    max-width: 640px;
  }
  @media (max-width: 980px) {
    .sub-hero__text { margin-top: -100px; }
  }
  @media (max-width: 640px) {
    .sub-hero__text { margin-top: -70px; }
  }

  /* ====== CONSTELLATION =====================================
     Three layers, top-down:
       1. MedMe brand node (center, pulse rings emanating).
       2. Three association nodes (PANS front-and-centre, plus
          two generic state / national labels) in an upper arc.
       3. Twelve member-pharmacy dots scattered below, each
          tethered to an association by a tracing line.
     The whole canvas breathes via stroke-dash and subtle
     opacity loops so it feels alive without competing with the
     headline that rises into the bottom fade.
  */
  .const {
    background: var(--white);
    border-radius: 20px;
    padding: 28px 32px 24px;
    box-shadow: none;
    position: relative;
  }
  .const__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 14px;
    margin-bottom: 14px;
    border-bottom: 1px solid rgba(6, 62, 84, 0.08);
    font-family: var(--font-display);
  }
  .const__title {
    font-size: 14px;
    font-weight: 600;
    color: var(--indigo);
    letter-spacing: -0.01em;
  }
  .const__legend {
    display: flex;
    gap: 14px;
    font-size: 11px;
    color: rgba(6, 62, 84, 0.6);
    font-weight: 500;
  }
  .const__legend span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .const__legend i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    display: inline-block;
  }
  .const__stage {
    position: relative;
    width: 100%;
    height: 360px;
  }
  .const__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  /* Connection lines: stroke-dash trace continuously */
  .const__svg .c-line {
    fill: none;
    stroke-width: 1.25;
    stroke-linecap: round;
    stroke-dasharray: 4 6;
    animation: const-flow 6s linear infinite;
  }
  .const__svg .c-line--up   { stroke: rgba(6, 62, 84, 0.45); }
  .const__svg .c-line--down { stroke: rgba(195, 196, 48, 0.7); }
  @keyframes const-flow {
    from { stroke-dashoffset: 60; }
    to   { stroke-dashoffset: 0; }
  }
  /* Stagger each line a bit so the flow does not feel mechanical */
  .const__svg .c-line:nth-of-type(2)  { animation-delay: 0.20s; }
  .const__svg .c-line:nth-of-type(3)  { animation-delay: 0.40s; }
  .const__svg .c-line:nth-of-type(4)  { animation-delay: 0.60s; }
  .const__svg .c-line:nth-of-type(5)  { animation-delay: 0.80s; }
  .const__svg .c-line:nth-of-type(6)  { animation-delay: 1.00s; }
  .const__svg .c-line:nth-of-type(7)  { animation-delay: 1.20s; }
  .const__svg .c-line:nth-of-type(8)  { animation-delay: 1.40s; }
  .const__svg .c-line:nth-of-type(9)  { animation-delay: 1.60s; }
  .const__svg .c-line:nth-of-type(10) { animation-delay: 1.80s; }
  .const__svg .c-line:nth-of-type(11) { animation-delay: 2.00s; }
  .const__svg .c-line:nth-of-type(12) { animation-delay: 2.20s; }
  .const__svg .c-line:nth-of-type(13) { animation-delay: 2.40s; }
  .const__svg .c-line:nth-of-type(14) { animation-delay: 2.60s; }
  .const__svg .c-line:nth-of-type(15) { animation-delay: 2.80s; }

  /* Pharmacy dots: gentle breathe */
  .const__svg .c-pharm {
    fill: var(--indigo);
    animation: const-breathe 4.2s ease-in-out infinite;
  }
  .const__svg .c-pharm:nth-of-type(2)  { animation-delay: 0.15s; }
  .const__svg .c-pharm:nth-of-type(3)  { animation-delay: 0.30s; }
  .const__svg .c-pharm:nth-of-type(4)  { animation-delay: 0.45s; }
  .const__svg .c-pharm:nth-of-type(5)  { animation-delay: 0.60s; }
  .const__svg .c-pharm:nth-of-type(6)  { animation-delay: 0.75s; }
  .const__svg .c-pharm:nth-of-type(7)  { animation-delay: 0.90s; }
  .const__svg .c-pharm:nth-of-type(8)  { animation-delay: 1.05s; }
  .const__svg .c-pharm:nth-of-type(9)  { animation-delay: 1.20s; }
  .const__svg .c-pharm:nth-of-type(10) { animation-delay: 1.35s; }
  .const__svg .c-pharm:nth-of-type(11) { animation-delay: 1.50s; }
  .const__svg .c-pharm:nth-of-type(12) { animation-delay: 1.65s; }
  @keyframes const-breathe {
    0%, 100% { opacity: 0.55; transform: scale(1); }
    50%      { opacity: 1;    transform: scale(1.18); }
    transform-origin: center;
  }

  /* Association badges: positioned absolutely over SVG, labeled */
  .const__assn {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--white);
    border: 1.5px solid var(--indigo);
    border-radius: 999px;
    padding: 7px 14px 7px 9px;
    font-size: 12px;
    font-weight: 600;
    color: var(--indigo);
    box-shadow: 0 6px 18px rgba(6, 62, 84, 0.08);
    font-family: var(--font-display);
    letter-spacing: -0.005em;
    white-space: nowrap;
  }
  .const__assn::before {
    content: "";
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--matcha);
    flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(195, 196, 48, 0.25);
  }
  .const__assn--ncap  { left: 16%;  top: 18px; }
  .const__assn--state { left: 46%;  top: 4px;  transform: translateX(-50%); }
  .const__assn--natl  { right: 16%; top: 18px; }
  .const__assn--featured { border-color: var(--matcha); background: rgba(195, 196, 48, 0.08); }

  /* MedMe central node, anchored to the middle of the stage */
  .const__center {
    position: absolute;
    left: 50%;
    top: 48%;
    transform: translate(-50%, -50%);
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background: var(--indigo);
    color: var(--seashell);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    z-index: 3;
    box-shadow: 0 8px 24px rgba(6, 62, 84, 0.18);
  }
  .const__center svg {
    width: 56px;
    height: auto;
    color: var(--seashell);
  }
  .const__center-label {
    font-size: 9px;
    color: var(--matcha);
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.08em;
  }
  /* Pulse rings around the center MedMe node */
  .const__rings {
    position: absolute;
    left: 50%;
    top: 48%;
    width: 0;
    height: 0;
    z-index: 2;
    pointer-events: none;
  }
  .const__rings span {
    position: absolute;
    left: 0;
    top: 0;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 1.5px solid rgba(195, 196, 48, 0.5);
    width: 110px;
    height: 110px;
    opacity: 0;
    animation: const-ring 5s cubic-bezier(0.22, 0.61, 0.36, 1) infinite;
  }
  .const__rings span:nth-child(2) { animation-delay: 1.25s; }
  .const__rings span:nth-child(3) { animation-delay: 2.5s; }
  .const__rings span:nth-child(4) { animation-delay: 3.75s; }
  @keyframes const-ring {
    0%   { transform: translate(-50%, -50%) scale(0.85); opacity: 0; }
    15%  { opacity: 0.55; }
    100% { transform: translate(-50%, -50%) scale(3.2); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .const__svg .c-line,
    .const__svg .c-pharm,
    .const__rings span { animation: none; }
    .const__svg .c-line { stroke-dasharray: 0; }
    .const__svg .c-pharm { opacity: 1; }
  }
  @media (max-width: 900px) {
    .const__stage { height: 320px; }
    .const__center { width: 92px; height: 92px; }
    .const__rings span { width: 92px; height: 92px; }
    .const__assn { font-size: 11px; padding: 6px 12px 6px 8px; }
  }
  @media (max-width: 640px) {
    .const { padding: 18px 16px; }
    .const__legend { display: none; }
    .const__stage { height: 280px; }
    .const__center { width: 76px; height: 76px; }
    .const__rings span { width: 76px; height: 76px; }
    .const__assn--ncap  { left: 4%; }
    .const__assn--natl  { right: 4%; }
  }

  /* ====== HOW WE PARTNER: 3-card grid (mirrors Strategic Partnership) */
  .partner-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }
  @media (max-width: 1000px) { .partner-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .partner-grid { grid-template-columns: 1fr; } }
  .partner-card {
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .partner-card:hover {
    transform: translateY(-3px);
    border-color: rgba(6, 62, 84, 0.18);
  }
  .partner-card__graphic {
    width: 100%;
    height: 130px;
    background: rgba(195, 196, 48, 0.06);
    border-radius: 10px;
    margin-bottom: 1.25rem;
    overflow: hidden;
    position: relative;
  }
  .partner-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--indigo);
    letter-spacing: -0.012em;
  }
  .partner-card p { margin: 0; color: rgba(6, 62, 84, 0.72); line-height: 1.55; }

  /* Card 1: Endorsed platform, three concentric layers fanning out */
  .pg-endorse {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pg-endorse svg { width: 100%; height: 100%; }
  .pg-endorse .pg-ring {
    fill: none;
    stroke: var(--matcha);
    stroke-width: 1.5;
    animation: pg-pulse 3.5s ease-in-out infinite;
    transform-origin: 100px 65px;
  }
  .pg-endorse .pg-ring:nth-of-type(1) { animation-delay: 0s;    }
  .pg-endorse .pg-ring:nth-of-type(2) { animation-delay: 0.4s;  }
  .pg-endorse .pg-ring:nth-of-type(3) { animation-delay: 0.8s;  }
  .pg-endorse .pg-dot { fill: var(--indigo); }
  @keyframes pg-pulse {
    0%, 100% { opacity: 0.25; transform: scale(0.95); }
    50%      { opacity: 1;    transform: scale(1.05); }
  }

  /* Card 2: Pilot cohort, sequenced row of pharmacy nodes lighting up */
  .pg-cohort {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  .pg-cohort .pg-node {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: rgba(195, 196, 48, 0.2);
    border: 1.5px solid rgba(195, 196, 48, 0.4);
    animation: pg-light 3.2s ease-in-out infinite;
  }
  .pg-cohort .pg-node:nth-child(1) { animation-delay: 0s; }
  .pg-cohort .pg-node:nth-child(2) { animation-delay: 0.18s; }
  .pg-cohort .pg-node:nth-child(3) { animation-delay: 0.36s; }
  .pg-cohort .pg-node:nth-child(4) { animation-delay: 0.54s; }
  .pg-cohort .pg-node:nth-child(5) { animation-delay: 0.72s; }
  .pg-cohort .pg-node:nth-child(6) { animation-delay: 0.90s; }
  .pg-cohort .pg-node:nth-child(7) { animation-delay: 1.08s; }
  @keyframes pg-light {
    0%, 70%, 100% { background: rgba(195, 196, 48, 0.2); border-color: rgba(195, 196, 48, 0.4); transform: scale(1); }
    20%, 50%      { background: var(--matcha); border-color: var(--matcha); transform: scale(1.25); }
  }

  /* Card 3: Outcomes return, ascending bars (data flow back to association) */
  .pg-data {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 6px;
    padding: 18px 28px;
  }
  .pg-data .pg-bar {
    width: 14px;
    background: var(--matcha);
    border-radius: 3px;
    animation: pg-bar-grow 4s ease-in-out infinite;
    transform-origin: bottom center;
  }
  .pg-data .pg-bar:nth-child(1) { height: 30px; animation-delay: 0s; }
  .pg-data .pg-bar:nth-child(2) { height: 44px; animation-delay: 0.12s; }
  .pg-data .pg-bar:nth-child(3) { height: 58px; animation-delay: 0.24s; }
  .pg-data .pg-bar:nth-child(4) { height: 72px; animation-delay: 0.36s; }
  .pg-data .pg-bar:nth-child(5) { height: 86px; animation-delay: 0.48s; }
  @keyframes pg-bar-grow {
    0%, 100% { transform: scaleY(0.8); opacity: 0.55; }
    50%      { transform: scaleY(1);   opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pg-endorse .pg-ring,
    .pg-cohort .pg-node,
    .pg-data .pg-bar { animation: none; opacity: 1; }
  }

  /* ====== PANS CASE STUDY SPOTLIGHT =========================
     A featured navy panel that frames the PANS pilot as the
     working proof point. Includes a small "logo-mark" header,
     the pilot framing, four goal pills, and three service rows.
  */
  .ncap {
    background: var(--indigo);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2.25rem;
    color: var(--seashell);
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 2.5rem;
    align-items: start;
    box-shadow: 0 18px 48px rgba(6, 62, 84, 0.16);
  }
  @media (max-width: 900px) { .ncap { grid-template-columns: 1fr; gap: 2rem; padding: 2rem 1.5rem; } }
  .ncap__chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(195, 196, 48, 0.18);
    color: var(--matcha);
    border-radius: 999px;
    padding: 5px 12px 5px 8px;
    font-size: 11px;
    font-weight: 700;
    font-family: var(--font-display);
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
  }
  .ncap__chip::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--matcha);
  }
  .ncap h3 {
    margin: 0 0 0.75rem;
    font-size: 1.65rem;
    font-weight: 600;
    color: var(--seashell);
    letter-spacing: -0.018em;
    line-height: 1.15;
    text-wrap: balance;
  }
  .ncap__lede {
    margin: 0 0 1.5rem;
    color: rgba(250, 249, 245, 0.78);
    line-height: 1.55;
    font-size: 1rem;
  }
  .ncap__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .ncap__stat {
    background: rgba(250, 249, 245, 0.06);
    border: 1px solid rgba(195, 196, 48, 0.18);
    border-radius: 10px;
    padding: 0.85rem 0.9rem;
  }
  .ncap__stat-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--matcha);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 4px;
  }
  .ncap__stat-label {
    display: block;
    font-size: 0.7rem;
    color: rgba(250, 249, 245, 0.65);
    line-height: 1.3;
  }
  .ncap__goals {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .ncap__goals li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.92rem;
    color: rgba(250, 249, 245, 0.85);
    line-height: 1.5;
  }
  .ncap__goals li::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--matcha);
    margin-top: 8px;
    flex-shrink: 0;
  }
  /* Right column, services list */
  .ncap__col-label {
    font-size: 0.78rem;
    color: rgba(195, 196, 48, 0.85);
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.06em;
    margin: 0 0 0.85rem;
  }
  .ncap__svc {
    background: rgba(250, 249, 245, 0.04);
    border: 1px solid rgba(250, 249, 245, 0.08);
    border-radius: 12px;
    padding: 1rem 1.15rem;
    margin-bottom: 0.75rem;
  }
  .ncap__svc h4 {
    margin: 0 0 0.3rem;
    font-size: 0.98rem;
    font-weight: 600;
    color: var(--seashell);
  }
  .ncap__svc p {
    margin: 0;
    font-size: 0.85rem;
    color: rgba(250, 249, 245, 0.7);
    line-height: 1.5;
  }
  .ncap__svc-tag {
    display: inline-block;
    background: rgba(195, 196, 48, 0.14);
    color: var(--matcha);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 999px;
    margin-bottom: 0.45rem;
    letter-spacing: 0.04em;
  }

  /* ====== MEMBER BENEFITS (4 light cards, mirrors Modular Architecture grid) */
  .benefit-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem;
  }
  @media (max-width: 1000px) { .benefit-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px)  { .benefit-grid { grid-template-columns: 1fr; } }
  .benefit {
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .benefit:hover {
    transform: translateY(-3px);
    border-color: rgba(6, 62, 84, 0.18);
  }
  .benefit__icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(195, 196, 48, 0.16);
    color: var(--indigo);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .benefit__icon svg {
    width: 22px;
    height: 22px;
  }
  .benefit h3 {
    margin: 0 0 0.4rem;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--indigo);
    letter-spacing: -0.012em;
  }
  .benefit p {
    margin: 0;
    color: rgba(6, 62, 84, 0.72);
    line-height: 1.55;
    font-size: 0.92rem;
  }

  /* ====== SERVICE MARKETING (4 channel cards, per Sayna #251) === */
  .mkt-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem;
  }
  @media (max-width: 1000px) { .mkt-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px)  { .mkt-grid { grid-template-columns: 1fr; } }
  .mkt-card {
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: var(--radius-lg);
    padding: 1.6rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .mkt-card:hover { transform: translateY(-3px); border-color: rgba(195, 196, 48, 0.42); }
  .mkt-card__icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    background: rgba(195, 196, 48, 0.16);
    color: var(--indigo);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.25rem;
  }
  .mkt-card__icon svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .mkt-card h3 {
    margin: 0 0 0.2rem;
    font-size: 1.02rem;
    font-weight: 600;
    color: var(--indigo);
    letter-spacing: -0.012em;
    line-height: 1.3;

---
import BaseLayout from '../../../../layouts/BaseLayoutCa.astro';
---
<BaseLayout
  title="Admin Clerk, MedMe Health"
  description="Admin Clerk is an AI agent that performs pharmacy data entry directly inside your existing systems. Reads screens with OCR, applies pharmacy-specific business rules, automates when confident, and routes exceptions to a pharmacist with a full audit trail."
  showAnnouncement={false}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/platform/ai-assistants/admin-clerk" />
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/" />
  </Fragment>

<style>

  /* ============================================================
     ADMIN CLERK product page. Hero embeds the source Admin Clerk
     SVG (whole one-pager mockup) as the backdrop. Content follows
     the one-pager PDF: four "works like a clerk" capabilities,
     six-step fax-to-Rx workflow, four-card security grid.
     ============================================================ */

  /* ====== SUB-HERO ============================================= */
  .sub-hero { background: var(--seashell); padding: 2rem 1.5rem 3.5rem; position: relative; overflow: hidden; }
  .sub-hero__inner { max-width: var(--container); margin: 0 auto; padding-inline: var(--tile-pad-x); position: relative; }
  .sub-hero__bg {
    position: relative; max-width: 1120px; margin: 0 auto;
    /* Mockup acts as a backdrop; soft fade so the headline can
       sit slightly over the bottom of the Admin Clerk widget. */
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 60%, rgba(0,0,0,0) 100%);
            mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 60%, rgba(0,0,0,0) 100%);
    pointer-events: none;
  }
  .sub-hero__text { text-align: center; max-width: 820px; margin: -120px auto 0; position: relative; z-index: 2; }
  .sub-hero h1.h-display { font-size: clamp(28px, 4.4vw, 54px); line-height: 1.08; letter-spacing: -0.028em; margin: 0.75rem auto 1rem; text-align: center; text-wrap: balance; }
  .sub-hero h1.h-display .accent { color: var(--matcha); }
  .sub-hero__lede { font-size: 1.1rem; line-height: 1.55; color: rgba(6, 62, 84, 0.72); margin: 0 auto 1.75rem; max-width: 720px; }
  .sub-hero__cta { display: inline-flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
  @media (max-width: 980px) { .sub-hero__text { margin-top: -90px; } }
  @media (max-width: 640px) { .sub-hero__text { margin-top: -50px; } }

  /* ====== ADMIN CLERK MOCKUP (whole SVG embedded as image) ===== */
  .ac-stage { display: flex; justify-content: center; padding: 18px 12px 36px; }
  .ac-mockup {
    display: block;
    width: 100%;
    max-width: 920px;
    height: auto;
    margin: 0 auto;
  }

  /* ====== 4 CAPABILITY CHECKS (light cards, 1x4 -> 2x2 -> 1col) === */
  .cap-checks {
    list-style: none; padding: 0;
    margin: 0 auto; max-width: 1120px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 1100px) { .cap-checks { grid-template-columns: repeat(2, 1fr); max-width: 820px; } }
  @media (max-width: 560px)  { .cap-checks { grid-template-columns: 1fr; max-width: 560px; } }
  .cap-checks li {
    display: flex; flex-direction: column;
    align-items: flex-start; gap: 1rem;
    font-size: 0.98rem; color: rgba(6, 62, 84, 0.82);
    line-height: 1.55;
    padding: 1.5rem 1.4rem;
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: var(--radius-lg);
    transition: transform 0.25s ease, border-color 0.25s ease;
    text-align: left;
  }
  .cap-checks li:hover { transform: translateY(-3px); border-color: rgba(195, 196, 48, 0.42); }
  .cap-checks li::before {
    content: "";
    flex-shrink: 0;
    width: 32px; height: 32px;
    border-radius: 50%;
    background: var(--matcha);
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 18 18'><path d='M5 9.5l2.5 2.5L13 6.5' stroke='%23063E54' stroke-width='2.2' fill='none' stroke-linecap='round' stroke-linejoin='round'/></svg>");
    background-repeat: no-repeat;
    background-position: center;
    background-size: 20px 20px;
  }

  /* ====== 6-STEP WORKFLOW (dark cards in vertical sequence) ===== */
  .flow {
    max-width: 760px; margin: 0 auto;
    display: flex; flex-direction: column; gap: 0.65rem;
    position: relative;
  }
  .flow::before {
    content: "";
    position: absolute;
    top: 28px; bottom: 28px; left: 30px;
    width: 2px;
    background: linear-gradient(180deg, rgba(195, 196, 48, 0.4) 0%, var(--matcha) 50%, rgba(195, 196, 48, 0.4) 100%);
    z-index: 0;
  }
  @media (max-width: 600px) { .flow::before { display: none; } }
  .flow-step {
    background: var(--indigo);
    color: var(--seashell);
    border: 1px solid rgba(195, 196, 48, 0.18);
    border-radius: var(--radius-lg);
    padding: 1.1rem 1.4rem 1.1rem 1.1rem;
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 1rem;
    align-items: center;
    position: relative;
    z-index: 1;
    transition: transform 0.25s ease;
    box-shadow: none;
  }
  .flow-step:hover { transform: translateX(4px); }
  .flow-step__num {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: var(--matcha);
    color: var(--indigo);
    display: inline-flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 13px;
    letter-spacing: -0.01em;
  }
  .flow-step__title { font-size: 1rem; font-weight: 600; margin: 0 0 0.15rem; color: var(--seashell); letter-spacing: -0.01em; }
  .flow-step__desc { font-size: 0.85rem; color: rgba(250, 249, 245, 0.72); margin: 0; line-height: 1.5; }
  @media (max-width: 600px) {
    .flow-step { grid-template-columns: 36px 1fr; gap: 0.85rem; padding: 1rem; }
    .flow-step__num { width: 32px; height: 32px; font-size: 12px; }
  }

  /* ====== 4-CARD SECURITY GRID =================================== */
  .sec-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  @media (max-width: 1100px) { .sec-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px)  { .sec-grid { grid-template-columns: 1fr; } }
  .sec-card {
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: var(--radius-lg);
    padding: 1.6rem 1.4rem;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .sec-card:hover { transform: translateY(-3px); border-color: rgba(195, 196, 48, 0.42); }
  .sec-card h3 {
    margin: 0 0 0.95rem;
    font-size: 1.02rem;
    font-weight: 600;
    color: var(--indigo);
    letter-spacing: -0.012em;
    line-height: 1.25;
  }
  .sec-card ul { margin: 0; padding: 0; list-style: none; }
  .sec-card li {
    font-size: 0.875rem;
    color: rgba(6, 62, 84, 0.78);
    line-height: 1.5;
    padding-left: 16px;
    position: relative;
    margin-bottom: 0.55rem;
  }
  .sec-card li:last-child { margin-bottom: 0; }
  .sec-card li::before {
    content: "";
    position: absolute;
    left: 0; top: 7px;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--matcha);
  }
</style>

<!-- ============= 1. SUB-HERO (Admin Clerk widget mockup) ============= -->
<section class="sub-hero" aria-label="Hero">
  <div class="sub-hero__inner">
    <div class="sub-hero__bg" aria-hidden="true">
      <div class="ac-stage">
        <img class="ac-mockup" src="/assets/admin-clerk-mockup.svg" alt="" />
      </div>
    </div>
    <div class="sub-hero__text">
      <h1 class="h-display">Your AI clerk for<br><span class="accent">pharmacy data entry.</span></h1>
      <p class="sub-hero__lede">Admin Clerk is an AI agent that performs pharmacy data entry directly inside your existing systems. It reads screens with OCR, applies pharmacy-specific business rules, automates when confident, and routes exceptions to a pharmacist with a full audit trail.</p>
      <div class="sub-hero__cta">
        <a class="pill pill--solid" href="/ca/contact">Book a demo <span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>


<!-- ============= 2. WORKS LIKE A REAL CLERK (4 capability checks) ============= -->
<section class="tile tile--navy" aria-label="Admin Clerk capabilities">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">How It Works</span>
      <h2 class="h-display">Automated data entry<br>that works like a real clerk.</h2>
      <p class="lead">Pharmacy back-office runs on systems built before the integration era. Admin Clerk operates against those systems the way a careful clerk would, with screens, rules, and a paper trail.</p>
    </div>
    <ul class="cap-checks">
      <li>Reads your screen using OCR to extract data from faxes, portals, and any interface a clerk would read.</li>
      <li>Applies pharmacy-specific business rules: brand vs generic, on-hand inventory, fill timing, controlled-substance handling.</li>
      <li>Automates when confident and routes exceptions to a pharmacist for review, with a complete audit trail of every action taken.</li>
      <li>Runs continuously in the background or overnight, processing the queue while your team is closed.</li>
    </ul>
  </div>
</section>

<!-- ============= 3. SAMPLE WORKFLOW (6-step dark sequence) ============= -->
<section class="tile tile--light tile--alt" aria-label="Sample workflow: Fax-to-Rx Entry">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">Sample Workflow</span>
      <h2 class="h-display">Fax-to-Rx entry,<br>end to end.</h2>
      <p class="lead">Six steps. No clicks from your team. Admin Clerk monitors the inbox, classifies docs, matches patient and provider, picks the right drug, applies your business logic, and fills in the Rx details, then routes anything ambiguous to a pharmacist for review.</p>
    </div>
    <div class="flow">
      <article class="flow-step">
        <span class="flow-step__num">01</span>
        <div>
          <h3 class="flow-step__title">Monitor PMS fax inbox for new docs</h3>
          <p class="flow-step__desc">Polls the fax inbox on a default 3-minute cadence; tunable to your traffic profile.</p>
        </div>
      </article>
      <article class="flow-step">
        <span class="flow-step__num">02</span>
        <div>
          <h3 class="flow-step__title">Classify Document</h3>
          <p class="flow-step__desc">Only processes designated document classes such as Rxs and transfers; everything else is set aside.</p>
        </div>
      </article>
      <article class="flow-step">
        <span class="flow-step__num">03</span>
        <div>
          <h3 class="flow-step__title">Patient &amp; Provider Match</h3>
          <p class="flow-step__desc">Looks up the patient and prescriber in your PMS, or creates a new record if no match is found.</p>
        </div>
      </article>
      <article class="flow-step">
        <span class="flow-step__num">04</span>
        <div>
          <h3 class="flow-step__title">Drug Selection</h3>
          <p class="flow-step__desc">Picks the right DIN based on your business rules: brand vs generic preferences, on-hand inventory, formulary.</p>
        </div>
      </article>
      <article class="flow-step">
        <span class="flow-step__num">05</span>
        <div>
          <h3 class="flow-step__title">Additional Business Logic</h3>
          <p class="flow-step__desc">Applies fill-timing rules, controlled-substance handling, special-authorization flags, and any other workflow logic your pharmacy enforces.</p>
        </div>
      </article>
      <article class="flow-step">
        <span class="flow-step__num">06</span>
        <div>
          <h3 class="flow-step__title">Fill Rx Details</h3>
          <p class="flow-step__desc">SIG, dispensed quantity, refills, day supply, and any remaining fields, ready for pharmacist verification.</p>
        </div>
      </article>
    </div>
  </div>
</section>

<!-- ============= 4. SECURITY (4 light cards) ============= -->
<section class="tile tile--light" aria-label="Designed with security top of mind">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">Secure By Design</span>
      <h2 class="h-display">Enterprise-grade controls<br>across every layer.</h2>
      <p class="lead">Admin Clerk handles PHI, runs on real production systems, and is subject to the same compliance bar as the rest of your pharmacy stack. The platform is built accordingly.</p>
    </div>
    <div class="sec-grid">
      <article class="sec-card">
        <h3>Compliance &amp; Assurance</h3>
        <ul>
          <li>SOC 2 Type II certified</li>
          <li>PHIPA and PIPEDA compliant</li>
          <li>Annual third-party penetration testing</li>
        </ul>
      </article>
      <article class="sec-card">
        <h3>Access Controls</h3>
        <ul>
          <li>SAML SSO with 2FA</li>
          <li>Role-based permissions</li>
          <li>Strict session controls</li>
        </ul>
      </article>
      <article class="sec-card">
        <h3>Encryption &amp; Infrastructure</h3>
        <ul>
          <li>AES-256 at rest, TLS in transit</li>
          <li>Secure key management</li>
          <li>Hosted in AWS</li>
        </ul>
      </article>
      <article class="sec-card">
        <h3>Responsible AI</h3>
        <ul>
          <li>Patient explicit consent</li>
          <li>No model training on your PHI</li>
          <li>PHI redaction and minimization</li>
          <li>Default zero-retention policy</li>
        </ul>
      </article>
    </div>
  </div>
</section>

<!-- ============= 5. CLOSING CTA ============= -->
<section class="tile tile--navy tile--prominent" aria-label="See Admin Clerk in action">
  <div class="tile__inner tile__inner--narrow">
    <div class="tile__head tile__head--centered">
      <span class="kicker">See It in Action</span>
      <h2 class="h-display">Designed to work with your pharmacy,<br><span style="color: var(--matcha);">not disrupt it.</span></h2>
      <p class="lead">A 20-minute walkthrough on a real fax-to-Rx workflow. We'll configure Admin Clerk against a sample PMS inbox and let you watch it process a multi-medication fax end to end.</p>
    </div>
    <div class="pill-cta-row pill-cta-row--center">
      <span class="pulse-rings" aria-hidden="true">
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
      </span>
      <a class="pill pill--solid" href="/ca/contact">Book a demo <span class="arrow">→</span></a>
    </div>
  </div>
</section>

</BaseLayout>

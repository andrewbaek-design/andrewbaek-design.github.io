---
import BaseLayout from '../../../layouts/BaseLayoutCa.astro';
---
<BaseLayout
  title="Clinical Documentation, MedMe Health"
  description="Customizable, jurisdictionally compliant documentation with Clinical Assistant supporting auto-fills notes and care plans."
  showAnnouncement={false}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/platform/assisted-documentation" />
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/" />
  </Fragment>

<style>

  /* ============================================================
     ASSISTED DOCUMENTATION product page. Hero uses the real
     Clinical Documentation SVG mockup as faded BG. Page covers
     standardized service templates and the pharmacist-tuned UX,
     then closes with the AI Clinical Assistant add-on framed as
     a featured product (same pattern as the specialty page's
     "Where the Operational Pressure Is" section).
     ============================================================ */

  /* ====== SUB-HERO ============================================= */
  .sub-hero { background: var(--seashell); padding: 2rem 1.5rem 3.5rem; position: relative; overflow: hidden; }
  .sub-hero__inner { max-width: var(--container); margin: 0 auto; padding-inline: var(--tile-pad-x); position: relative; }
  .sub-hero__bg {
    position: relative; max-width: 1120px; margin: 0 auto;
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 45%, rgba(0,0,0,0) 95%);
            mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 45%, rgba(0,0,0,0) 95%);
    pointer-events: none;
  }
  .sub-hero__bg img { display: block; width: 100%; max-width: 1080px; height: auto; margin: 0 auto; }
  .sub-hero__text { text-align: center; max-width: 820px; margin: -140px auto 0; position: relative; z-index: 2; }
  .sub-hero h1.h-display { font-size: clamp(28px, 4.4vw, 54px); line-height: 1.08; letter-spacing: -0.028em; margin: 0.75rem auto 1rem; text-align: center; text-wrap: balance; }
  .sub-hero h1.h-display .accent { color: var(--matcha); }
  .sub-hero__lede { font-size: 1.1rem; line-height: 1.55; color: rgba(6, 62, 84, 0.72); margin: 0 auto 1.75rem; max-width: 720px; }
  .sub-hero__cta { display: inline-flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
  @media (max-width: 980px) { .sub-hero__text { margin-top: -90px; } }
  @media (max-width: 640px) { .sub-hero__text { margin-top: -60px; } }

  /* ====== TEMPLATES (out of the box) =========================== */
  .templates-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  @media (max-width: 900px) { .templates-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .templates-grid { grid-template-columns: 1fr; } }
  .template-card { background: var(--white); border: 1px solid rgba(6,62,84,0.08); border-radius: var(--radius-lg); padding: 1.5rem; transition: transform 0.25s ease, border-color 0.25s ease; }
  .template-card:hover { transform: translateY(-3px); border-color: rgba(6,62,84,0.18); }
  .template-card__tag { font-family: ui-monospace, "JetBrains Mono", monospace; font-size: 11px; color: rgba(6,62,84,0.5); margin-bottom: 0.5rem; letter-spacing: 0.04em; }
  .template-card h4 { margin: 0 0 0.4rem; font-size: 1rem; font-weight: 600; color: var(--indigo); }
  .template-card p { margin: 0; color: rgba(6,62,84,0.72); line-height: 1.5; font-size: 0.875rem; }

  /* ====== DARK WINNER CARDS (Built Around the Pharmacist) ===== */
  .winners-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 1000px) { .winners-grid { grid-template-columns: 1fr; } }
  .winner-card { background: var(--indigo); color: var(--seashell); border: 1px solid rgba(195,196,48,0.18); border-radius: var(--radius-lg); padding: 1.75rem; transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease; box-shadow: 0 12px 32px rgba(6,62,84,0.08); }
  .winner-card:hover { transform: translateY(-3px); border-color: var(--matcha); box-shadow: 0 16px 38px rgba(6,62,84,0.16); }
  .winner-card__tag { font-size: 11px; color: var(--matcha); font-weight: 700; letter-spacing: 0.06em; margin-bottom: 0.6rem; display: inline-block; }
  .winner-card h3 { margin: 0 0 0.5rem; font-size: 1.1rem; font-weight: 600; color: var(--seashell); }
  .winner-card p { margin: 0; color: rgba(250,249,245,0.78); line-height: 1.55; font-size: 0.95rem; }

  /* ====== FEATURED AI AGENT (Clinical Assistant add-on)
     Mirrors the specialty page pattern: warm matcha-tinted story
     wrapper with a decorative corner blob, industry quote on the
     left and a dark "Add-on Product" card on the right, followed
     by a 3-card capabilities breakdown. */
  .featured-story-card {
    background: rgba(195, 196, 48, 0.20);
    border-radius: 24px;
    padding: 2.5rem;
    margin: 0 0 2.5rem;
    position: relative;
    overflow: hidden;
  }
  .featured-story-card::before {
    content: "";
    position: absolute;
    top: -60px; right: -60px;
    width: 220px; height: 220px;
    background: var(--matcha);
    opacity: 0.1;
    border-radius: 50%;
    pointer-events: none;
  }
  @media (max-width: 700px) {
    .featured-story-card { padding: 1.75rem; }
  }
  .featured-story {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: stretch;
    position: relative;
    z-index: 1;
  }
  @media (max-width: 980px) { .featured-story { grid-template-columns: 1fr; gap: 2rem; } }
  .featured-story__quote {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .featured-quote { margin: 0; }
  .featured-quote p {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1.6vw, 1.35rem);
    line-height: 1.45;
    font-weight: 500;
    color: var(--seashell);
    letter-spacing: -0.012em;
    margin: 0;
    text-wrap: pretty;
  }
  .featured-quote__attrib {
    margin: 1rem 0 0;
    font-size: 0.875rem;
    color: rgba(250, 249, 245, 0.72);
  }
  .ai-card {
    background: var(--indigo);
    color: var(--seashell);
    border: 1px solid rgba(195, 196, 48, 0.28);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .ai-card__tag {
    display: inline-block;
    font-size: 11px;
    color: var(--matcha);
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-bottom: 0.25rem;
  }
  .ai-card h3 {
    margin: 0;
    font-size: clamp(1.35rem, 2vw, 1.65rem);
    font-weight: 700;
    color: var(--seashell);
    letter-spacing: -0.018em;
  }
  .ai-card p {
    margin: 0;
    font-size: 1rem;
    color: rgba(250, 249, 245, 0.78);
    line-height: 1.55;
  }
  .ai-card .pill { align-self: flex-start; margin-top: 0.5rem; }
  /* Scoped pill override: render the .pill--solid as matcha
     on dark inside the .ai-card, matching the .tile--navy
     treatment. */
  .ai-card .pill--solid {
    background: var(--matcha);
    color: var(--indigo);
    border-color: var(--matcha);
    box-shadow: none;
  }
  .ai-card .pill--solid:hover {
    background: transparent;
    color: var(--matcha);
    border-color: var(--matcha);
  }

  /* 3-card capability breakdown */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 900px) { .featured-grid { grid-template-columns: 1fr; } }
  .featured-cap {
    background: var(--indigo);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    transition: transform 0.25s ease;
  }
  .featured-cap:hover { transform: translateY(-3px); }
  .featured-cap__num {
    display: inline-block;
    font-size: 11px;
    color: var(--matcha);
    font-weight: 600;
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
  }
  .featured-cap h4 {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--matcha);
    letter-spacing: -0.012em;
  }
  .featured-cap p {
    margin: 0;
    color: rgba(250, 249, 245, 0.82);
    line-height: 1.55;
    font-size: 0.95rem;
  }
</style>

<!-- ============= 1. SUB-HERO (Clinical Documentation SVG as BG) ============= -->
<section class="sub-hero" aria-label="Hero">
  <div class="sub-hero__inner">
    <div class="sub-hero__bg" aria-hidden="true">
      <img src="/assets/assisted-documentation-mockup.svg" alt="" />
    </div>
    <div class="sub-hero__text">
      <h1 class="h-display">Documentation, handled.<br><span class="accent">Patient care, focused.</span></h1>
      <p class="sub-hero__lede">Customizable, jurisdictionally compliant documentation with Clinical Assistant supporting auto-fills notes and care plans.</p>
      <div class="sub-hero__cta">
        <a class="pill pill--solid" href="/ca/contact">Book a demo <span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>


<!-- ============= 2. SERVICE TEMPLATES (kept as-is) ============= -->
<section class="tile tile--light" aria-label="Service templates">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">Service Templates, Ready Out of the Box</span>
      <h2 class="h-display">Every clinical service<br>pharmacy delivers, templated.</h2>
      <p class="lead">Pre-built service templates for the encounters your pharmacy already runs, plus a drag-and-drop builder for everything else.</p>
    </div>
    <div class="templates-grid">
      <article class="template-card">
        <div class="template-card__tag">/ SOAP</div>
        <h4>SOAP notes</h4>
        <p>Medication-focused subjective, objective, assessment, plan, with built-in code suggestion.</p>
      </article>
      <article class="template-card">
        <div class="template-card__tag">/ Immunizations</div>
        <h4>Vaccine workflows</h4>
        <p>Consent and screening, lot and expiry capture, provincial registry reporting, and AEFI tracking wired in.</p>
      </article>
      <article class="template-card">
        <div class="template-card__tag">/ Med Review</div>
        <h4>Medication reviews</h4>
        <p>20+ chronic conditions templated with drug therapy problems, goals, and follow-up actions.</p>
      </article>
      <article class="template-card">
        <div class="template-card__tag">/ Minor Ailments</div>
        <h4>Minor ailments</h4>
        <p>Province-specific assessment templates, prescribing pathways, and follow-up cadences.</p>
      </article>
      <article class="template-card">
        <div class="template-card__tag">/ Transitions</div>
        <h4>Transitions of care</h4>
        <p>Discharge follow-up, medication reconciliation, 7-14 day cycles.</p>
      </article>
      <article class="template-card">
        <div class="template-card__tag">/ Travel</div>
        <h4>Travel consults</h4>
        <p>Destination-based screening, vaccine sequencing, malaria and traveller's-diarrhea protocols, and follow-up.</p>
      </article>
      <article class="template-card">
        <div class="template-card__tag">/ Cessation</div>
        <h4>Smoking cessation</h4>
        <p>Patient-centred counselling cadence, NRT and pharmacotherapy protocols, and follow-up workflows.</p>
      </article>
      <article class="template-card">
        <div class="template-card__tag">/ Contraception</div>
        <h4>Hormonal contraception</h4>
        <p>Risk screening, blood pressure capture, follow-up cadence.</p>
      </article>
      <article class="template-card">
        <div class="template-card__tag">/ Custom</div>
        <h4>Drag-and-drop builder</h4>
        <p>Build your own protocols for POC testing, anticoagulation, naloxone, and any other service your province authorizes. The template library is fully customizable, with no protocol off-limits.</p>
      </article>
    </div>
  </div>
</section>

<!-- ============= 3. BUILT AROUND THE PHARMACIST (kept as-is) ============= -->
<section class="tile tile--light tile--alt" aria-label="Built around the pharmacist">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">Built Around the Pharmacist</span>
      <h2 class="h-display">One screen.<br>Everything to make the clinical decision.</h2>
    </div>
    <div class="winners-grid">
      <article class="winner-card">
        <span class="winner-card__tag">Single Surface</span>
        <h3>No tab switching</h3>
        <p>Active medications with PDC, care plan goals with status, and live encounter timing, all in one dashboard view. No clicking between five tabs to assemble a clinical picture.</p>
      </article>
      <article class="winner-card">
        <span class="winner-card__tag">Pharmacy-Tuned</span>
        <h3>Protocol-aligned workflows</h3>
        <p>Service templates are built around the protocols pharmacy is paid to run. Medication reviews, minor ailments, immunizations, and transitions of care work the way provincial scope-of-practice actually requires, not retrofitted onto a generic EMR.</p>
      </article>
      <article class="winner-card">
        <span class="winner-card__tag">PMS Sync</span>
        <h3>Charts that stay current</h3>
        <p>Bidirectional integration with Kroll, Nexxsys, TelusHealth, and HealthWatch pulls demographics, allergies, and dispensing history in real time. No re-keying. The chart is always current.</p>
      </article>
    </div>
  </div>
</section>

<!-- ============= 4. CLINICAL ASSISTANT ADD-ON (featured product, specialty pattern) ============= -->
<section class="tile tile--navy" aria-label="Featured add-on: AI Clinical Assistant">
  <div class="tile__inner">
    <div class="tile__head">
      <span class="kicker">Add-on Product</span>
      <h2 class="h-display">Documentation eats clinical time.<br>An AI Scribe gives it back.</h2>
      <p class="lead">Pharmacists end the day finishing notes from visits they wrapped hours ago. AI Clinical Assistant is the add-on that closes that loop, capturing the consultation, drafting the SOAP note, and pre-coding the encounter so the pharmacist reviews and signs in seconds, not after-hours.</p>
    </div>

    <!-- Story-card wrapper: industry quote + dark "Add-on Product" card -->
    <div class="featured-story-card">
      <div class="featured-story">
        <div class="featured-story__quote">
          <blockquote class="featured-quote"><p>"Documentation is the part of clinical pharmacy that runs into the parking lot. Our pharmacists are still finishing notes after close, and the encounters that matter most are the ones we never quite caught up on."</p></blockquote>
          <p class="featured-quote__attrib">What we hear from clinical pharmacy teams</p>
        </div>
        <div class="ai-card">
          <span class="ai-card__tag">Add-on Product &middot; AI Scribe</span>
          <h3>AI Clinical Assistant</h3>
          <p>Pharmacy-tuned AI Scribe that captures the consultation, drafts the SOAP note, and pre-codes the encounter. Pharmacist reviews and signs in under 90 seconds. Available as an add-on on top of Clinical Documentation.</p>
          <a class="pill pill--solid" href="/ca/platform/ai-clinical-assistant">Learn more about AI Clinical Assistant <span class="arrow">→</span></a>
        </div>
      </div>
    </div>

    <!-- 3-card capability breakdown -->
    <div class="featured-grid">
      <article class="featured-cap">
        <span class="featured-cap__num">/ Real-Time Capture</span>
        <h4>AI transcription in real time</h4>
        <p>Tap record. The scribe captures the consultation audio and transcribes in real time, tagging clinical entities like drugs, doses, and conditions as they come up.</p>
      </article>
      <article class="featured-cap">
        <span class="featured-cap__num">/ Auto-Fill</span>
        <h4>Note populates itself</h4>
        <p>SOAP note fields populate automatically as the conversation flows. The pharmacist edits the draft, not the blank page. Documentation finishes during the visit, not after it.</p>
      </article>
      <article class="featured-cap">
        <span class="featured-cap__num">/ Smart Coding</span>
        <h4>Pre-coded for billing</h4>
        <p>Suggests the right provincial billing code based on encounter type, time, and conditions. Pharmacist reviews and signs. The note ships ready to bill.</p>
      </article>
    </div>
  </div>
</section>

<!-- ============= 5. CLOSING CTA ============= -->
<section class="tile tile--navy tile--prominent" aria-label="Tired of fighting your EMR">
  <div class="tile__inner tile__inner--narrow">
    <div class="tile__head tile__head--centered">
      <span class="kicker">Tired of Fighting Your EMR?</span>
      <h2 class="h-display">See the chart your pharmacists<br>will actually want to open.</h2>
      <p class="lead">A 20-minute walkthrough on a sample medication review patient and a real encounter. We will load the chart, run the encounter live, and show you the SOAP note ready to bill at the end.</p>
    </div>
    <div class="pill-cta-row pill-cta-row--center">
      <span class="pulse-rings" aria-hidden="true">
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
      </span>
      <a class="pill pill--solid" href="/ca/contact">Book a demo <span class="arrow">→</span></a>
    </div>
  </div>
</section>

</BaseLayout>

---
import BaseLayoutCa from '../../layouts/BaseLayoutCa.astro';
import LogoMedme from '../../components/LogoMedme.astro';
---
<BaseLayoutCa
  title="MedMe Health, The clinical operating system for Canadian community pharmacy"
  description="MedMe is the pharmacy-specific EHR that documents every encounter and turns it into a documented, reimbursable service. Built with Canadian pharmacy operators."
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en-us" href="https://medmehealth.com/us/" />
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/" />
    <link rel="alternate" hreflang="x-default" href="https://medmehealth.com/ca/" />
    <link rel="stylesheet" href="/assets/homepage-ca.css" />
    <script type="application/ld+json" is:inline set:html={`{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "MedMe Health",
  "url": "https://medmehealth.com",
  "logo": "https://medmehealth.com/logo.svg",
  "sameAs": ["https://www.linkedin.com/company/medme-health/"]
}`}></script>
    <script type="application/ld+json" is:inline set:html={`{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "MedMe Care Platform for Canadian Pharmacy",
  "applicationCategory": "HealthApplication",
  "operatingSystem": "Web",
  "offers": {"@type":"Offer","price":"0","priceCurrency":"USD","description":"Contact sales for pricing"},
  "audience": {"@type":"Audience","audienceType":"Pharmacy operators in Canada"}
}`}></script>
  </Fragment>

<!-- ============= 1. HERO (centered headline + AI-scribe mockup) ============= -->
<section class="hero-end" aria-label="Hero">
  <div class="tile__inner">
    <h1>
      <span>The end-to-end platform for pharmacy clinical services.</span>
      <span>From launch to reimbursement.</span>
    </h1>
    <div class="cta-row">
      <a class="btn btn-primary btn--lg" href="/ca/contact">Book a demo <span class="arrow">&rarr;</span></a>
    </div>
  </div>
</section>

<div class="tab-bar-wrap">
  <div class="tab-bar" role="tablist" aria-label="Product mockup tabs">
    <button class="tab tab--active"   type="button" data-tab="scheduling"    role="tab" aria-selected="true">Scheduling &amp; Queueing</button>
    <button class="tab"               type="button" data-tab="intake"        role="tab" aria-selected="false">Patient Intake Forms</button>
    <button class="tab"               type="button" data-tab="documentation" role="tab" aria-selected="false">Assisted Documentation</button>
    <button class="tab"               type="button" data-tab="messaging"     role="tab" aria-selected="false">Messaging &amp; Follow-Ups</button>
  </div>
</div>

<div class="visual-wrap" aria-hidden="true">
  <div class="visual-halo"></div>
  <div class="visual-frame">

    <!-- ===== PANE: Scheduling & Queueing ===== -->
    <div class="mockup-pane mockup-pane--active" data-pane="scheduling" role="tabpanel">
      <div class="mockup-host" id="schedHost">
        <div class="frame-inner" id="schedFrame">

          <!-- LEFT CARD, MedMe Pharmacy booking widget -->
          <section class="sched-book" aria-label="Booking widget">
            <h2 class="sched-book-title">MedMe Pharmacy</h2>
            <div class="sched-book-divider"></div>

            <div class="sched-radios" role="radiogroup" aria-label="Visit type">
              <span class="sched-radio" role="radio" aria-checked="false">
                <span class="sched-radio-circle"></span>
                <span>Walk-in</span>
              </span>
              <span class="sched-radio sched-radio--active" role="radio" aria-checked="true">
                <span class="sched-radio-circle"></span>
                <span>Book Appointment</span>
              </span>
            </div>

            <div class="sched-grid-card">
              <div class="sched-grid-nav">
                <button class="sched-nav-arrow" type="button" aria-label="Previous week">&#x2039;</button>
                <span class="sched-nav-label">Wed Aug 13 - Tue Aug 19</span>
                <button class="sched-nav-arrow" type="button" aria-label="Next week">&#x203A;</button>
              </div>

              <div class="sched-grid">
                <div class="sched-col">
                  <div class="sched-col-head"><div class="sched-col-date">Aug 13</div><div class="sched-col-day">Today</div></div>
                  <button class="sched-slot" type="button">8:00 AM</button>
                  <button class="sched-slot" type="button">8:15 AM</button>
                  <button class="sched-slot" type="button">8:30 AM</button>
                  <button class="sched-slot" type="button">8:45 AM</button>
                  <button class="sched-slot" type="button">9:00 AM</button>
                  <button class="sched-slot" type="button">9:15 AM</button>
                </div>
                <div class="sched-col">
                  <div class="sched-col-head"><div class="sched-col-date">Aug 14</div><div class="sched-col-day">Thu</div></div>
                  <button class="sched-slot" type="button">8:00 AM</button>
                  <button class="sched-slot" type="button">8:15 AM</button>
                  <button class="sched-slot" type="button">8:30 AM</button>
                  <button class="sched-slot" type="button">8:45 AM</button>
                  <button class="sched-slot" type="button" id="schTargetSlot">9:00 AM</button>
                  <button class="sched-slot" type="button">9:15 AM</button>
                </div>
                <div class="sched-col">
                  <div class="sched-col-head"><div class="sched-col-date">Aug 15</div><div class="sched-col-day">Fri</div></div>
                  <button class="sched-slot" type="button">8:00 AM</button>
                  <button class="sched-slot" type="button">8:15 AM</button>
                  <button class="sched-slot" type="button">8:30 AM</button>
                  <button class="sched-slot" type="button">8:45 AM</button>
                  <button class="sched-slot" type="button">9:00 AM</button>
                  <button class="sched-slot" type="button">9:15 AM</button>
                </div>
                <div class="sched-col">
                  <div class="sched-col-head"><div class="sched-col-date">Aug 16</div><div class="sched-col-day">Sat</div></div>
                  <button class="sched-slot" type="button">8:00 AM</button>
                  <button class="sched-slot" type="button">8:15 AM</button>
                  <button class="sched-slot" type="button">8:30 AM</button>
                  <button class="sched-slot" type="button">8:45 AM</button>
                  <button class="sched-slot" type="button">9:00 AM</button>
                  <button class="sched-slot" type="button">9:15 AM</button>
                </div>
                <div class="sched-col">
                  <div class="sched-col-head"><div class="sched-col-date">Aug 17</div><div class="sched-col-day">Sun</div></div>
                  <button class="sched-slot" type="button">8:00 AM</button>
                  <button class="sched-slot" type="button">8:15 AM</button>
                  <button class="sched-slot" type="button">8:30 AM</button>
                  <button class="sched-slot" type="button">8:45 AM</button>
                  <button class="sched-slot" type="button">9:00 AM</button>
                  <button class="sched-slot" type="button">9:15 AM</button>
                </div>
                <div class="sched-col">
                  <div class="sched-col-head"><div class="sched-col-date">Aug 18</div><div class="sched-col-day">Mon</div></div>
                  <button class="sched-slot" type="button">8:00 AM</button>
                  <button class="sched-slot" type="button">8:15 AM</button>
                  <button class="sched-slot" type="button">8:30 AM</button>
                  <button class="sched-slot" type="button">8:45 AM</button>
                  <button class="sched-slot" type="button">9:00 AM</button>
                  <button class="sched-slot" type="button">9:15 AM</button>
                </div>
                <div class="sched-col">
                  <div class="sched-col-head"><div class="sched-col-date">Aug 19</div><div class="sched-col-day">Tue</div></div>
                  <button class="sched-slot" type="button">8:00 AM</button>
                  <button class="sched-slot" type="button">8:15 AM</button>
                  <button class="sched-slot" type="button">8:30 AM</button>
                  <button class="sched-slot" type="button">8:45 AM</button>
                  <button class="sched-slot" type="button">9:00 AM</button>
                  <button class="sched-slot" type="button">9:15 AM</button>
                </div>
              </div>
            </div>
          </section>

          <!-- RIGHT CARD, Store Locator -->
          <section class="sched-locator" aria-label="Store locator">
            <h3 class="sched-locator-title">Store Locator</h3>
            <div class="sched-map">
              <svg class="sched-map-bg" viewBox="0 0 250 480" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
                <!-- park blocks -->
                <ellipse cx="170" cy="120" rx="70" ry="55" fill="rgba(150, 188, 140, 0.30)"/>
                <ellipse cx="40" cy="270" rx="55" ry="40" fill="rgba(150, 188, 140, 0.22)"/>
                <ellipse cx="200" cy="380" rx="45" ry="35" fill="rgba(150, 188, 140, 0.18)"/>
                <!-- subtle building blocks -->
                <rect x="80" y="30" width="40" height="30" rx="3" fill="rgba(4, 43, 59, 0.05)"/>
                <rect x="20" y="180" width="50" height="35" rx="3" fill="rgba(4, 43, 59, 0.05)"/>
                <rect x="140" y="220" width="45" height="40" rx="3" fill="rgba(4, 43, 59, 0.05)"/>
                <rect x="90" y="320" width="50" height="35" rx="3" fill="rgba(4, 43, 59, 0.05)"/>
                <!-- roads -->
                <path d="M-10 90 Q70 100 130 80 T260 100"  stroke="rgba(4, 43, 59, 0.10)" stroke-width="2" fill="none"/>
                <path d="M-10 210 Q90 195 160 215 T260 215" stroke="rgba(4, 43, 59, 0.10)" stroke-width="2" fill="none"/>
                <path d="M50 -10 Q60 130 50 240 T70 490"     stroke="rgba(4, 43, 59, 0.10)" stroke-width="2" fill="none"/>
                <path d="M180 -10 Q170 140 195 260 T205 490" stroke="rgba(4, 43, 59, 0.10)" stroke-width="2" fill="none"/>
                <!-- river -->
                <path d="M-15 340 Q60 320 130 345 T265 360" stroke="rgba(120, 175, 205, 0.55)" stroke-width="22" fill="none" stroke-linecap="round"/>
              </svg>

              <div class="sched-pin" style="left:42%; top:24%;">
                <svg viewBox="0 0 24 32" fill="none"><path d="M12 0C5.4 0 0 5.4 0 12c0 9 12 20 12 20s12-11 12-20c0-6.6-5.4-12-12-12z" fill="var(--indigo-dark)"/><circle cx="12" cy="12" r="4.5" fill="#fff"/></svg>
              </div>
              <div class="sched-pin sched-pin--active" style="left:58%; top:44%;">
                <svg viewBox="0 0 24 32" fill="none"><path d="M12 0C5.4 0 0 5.4 0 12c0 9 12 20 12 20s12-11 12-20c0-6.6-5.4-12-12-12z" fill="var(--indigo-dark)"/><circle cx="12" cy="12" r="4.5" fill="#fff"/></svg>
              </div>
              <div class="sched-pin" style="left:64%; top:82%;">
                <svg viewBox="0 0 24 32" fill="none"><path d="M12 0C5.4 0 0 5.4 0 12c0 9 12 20 12 20s12-11 12-20c0-6.6-5.4-12-12-12z" fill="var(--indigo-dark)"/><circle cx="12" cy="12" r="4.5" fill="#fff"/></svg>
              </div>
            </div>
          </section>

          <div class="cursor" id="schCursor">
            <svg width="20" height="22" viewBox="0 0 20 22" fill="none">
              <path d="M2 1.5l14.5 9.4-6.4 1.6-2.6 6.5L2 1.5z" fill="#0c1217" stroke="#fff" stroke-width="1.2" stroke-linejoin="round"/>
            </svg>
            <span class="ripple" id="schRipple"></span>
          </div>

        </div>
      </div>
    </div>

    <!-- ===== PANE: Patient Intake Forms ===== -->
    <div class="mockup-pane" data-pane="intake" role="tabpanel">
      <div class="mockup-host" id="intakeHost">
        <div class="frame-inner" id="intakeFrame">

          <!-- Top header with logo -->
          <div class="intake-topbar">
            <div class="intake-logo"><LogoMedme /></div>
          </div>

          <div class="intake-body">
            <!-- LEFT: form section -->
            <div class="intake-card-left">
              <h2 class="intake-h1">Contact Information</h2>

              <!-- 8-step horizontal indicator. Steps 1=done, 2=active, 3-8=pending -->
              <div class="intake-steps" id="intakeSteps">
                <span class="intake-step is-done"></span>
                <span class="intake-step-line is-done"></span>
                <span class="intake-step is-active"></span>
                <span class="intake-step-line"><span class="fill" id="intakeProgress"></span></span>
                <span class="intake-step"></span>
                <span class="intake-step-line"></span>
                <span class="intake-step"></span>
                <span class="intake-step-line"></span>
                <span class="intake-step"></span>
                <span class="intake-step-line"></span>
                <span class="intake-step"></span>
                <span class="intake-step-line"></span>
                <span class="intake-step"></span>
                <span class="intake-step-line"></span>
                <span class="intake-step"></span>
              </div>

              <!-- Inner white form card -->
              <div class="intake-form">
                <h3 class="intake-form-h">Personal Information for individual(s) receiving service</h3>
                <p class="intake-form-sub">Please enter the required information for yourself and anyone else in your booking.</p>

                <div class="intake-fields-row row-2-1">
                  <div class="intake-field" id="fldFirstName">
                    <span class="intake-field-label">First Name *</span>
                    <div class="intake-field-value"></div>
                  </div>
                  <div class="intake-field" id="fldLastName">
                    <span class="intake-field-label">Last Name *</span>
                    <div class="intake-field-value"></div>
                  </div>
                </div>
                <div class="intake-fields-row row-half">
                  <div class="intake-field" id="fldDOB">
                    <span class="intake-field-label">Date of Birth (YYYY-MM-DD) *</span>
                    <div class="intake-field-value"></div>
                    <span class="intake-field-icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    </span>
                  </div>
                </div>

                <div class="intake-section-h">Address</div>
                <div class="intake-fields-row row-1">
                  <div class="intake-field" id="fldAddress">
                    <span class="intake-field-label">Continue</span>
                    <div class="intake-field-value"></div>
                    <span class="intake-field-icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>
                    </span>
                  </div>
                </div>
                <div class="intake-fields-row row-3">
                  <div class="intake-field" id="fldCity">
                    <span class="intake-field-label">City *</span>
                    <div class="intake-field-value"></div>
                  </div>
                  <div class="intake-field" id="fldProvince">
                    <span class="intake-field-label">Province *</span>
                    <div class="intake-field-value"></div>
                    <span class="intake-field-icon" aria-hidden="true">
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 5 6 8 9 5"/></svg>
                    </span>
                  </div>
                  <div class="intake-field" id="fldPostal">
                    <span class="intake-field-label">Postal Code *</span>
                    <div class="intake-field-value"></div>
                  </div>
                </div>

                <button class="intake-cta" type="button" id="intakeCta">Continue</button>
              </div>
            </div>

            <!-- RIGHT: booking summary -->
            <aside class="intake-card-right">
              <h3 class="intake-summary-title">Flu Shot (Regular)</h3>
              <div class="intake-summary-row">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span>Sun Nov 30, 8:30AM</span>
              </div>
              <div class="intake-summary-row">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Approximately 15 minutes</span>
              </div>
              <div class="intake-summary-row">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span>1 person</span>
              </div>
              <div class="intake-summary-row">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>MedMe Pharmacy<br>175 Bloor Street East<br>Toronto, ON M4W 3R8</span>
              </div>
              <div class="intake-summary-divider"></div>
              <ul class="intake-vsteps" id="intakeVSteps">
                <li class="intake-vstep is-active"><span class="intake-vstep-dot"></span>Contact Information</li>
                <li class="intake-vstep"><span class="intake-vstep-dot"></span>Medical Information</li>
                <li class="intake-vstep"><span class="intake-vstep-dot"></span>Flu Screening</li>
                <li class="intake-vstep"><span class="intake-vstep-dot"></span>Consent</li>
                <li class="intake-vstep"><span class="intake-vstep-dot"></span>Review and Submit</li>
              </ul>
            </aside>
          </div>

        </div>
      </div>
    </div>

    <!-- ===== PANE: Messaging & Follow-Ups ===== -->
    <div class="mockup-pane" data-pane="messaging" role="tabpanel">
      <div class="mockup-host" id="msgHost">
        <div class="frame-inner" id="msgFrame">
          <div class="msg-stage">

            <!-- PHONE 1, booking confirmation email -->
            <div class="msg-phone msg-phone--email">
              <div class="msg-status">
                <span>9:41</span>
                <span class="msg-status-icons">
                  <svg width="16" height="11" viewBox="0 0 18 11" fill="currentColor"><rect x="1" y="7" width="3" height="4" rx="0.6"/><rect x="5" y="5" width="3" height="6" rx="0.6"/><rect x="9" y="3" width="3" height="8" rx="0.6"/><rect x="13" y="0" width="3" height="11" rx="0.6"/></svg>
                  <svg width="14" height="11" viewBox="0 0 16 11" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><path d="M1 4 Q8 -1 15 4"/><path d="M3 6 Q8 3 13 6"/><path d="M5.5 8 Q8 7 10.5 8"/></svg>
                  <svg width="22" height="11" viewBox="0 0 24 11" fill="none"><rect x="0.5" y="0.5" width="21" height="10" rx="2.5" stroke="currentColor" opacity="0.45"/><rect x="22" y="3.5" width="1.4" height="4" rx="0.6" fill="currentColor" opacity="0.45"/><rect x="2" y="2" width="14" height="7" rx="1.2" fill="currentColor"/></svg>
                </span>
              </div>
              <div class="msg-logo"><LogoMedme /></div>
              <div class="msg-email-body">
                <p>Hi John,</p>
                <p>Thank you for booking with us!</p>
                <p class="muted">Your appointment details:</p>
                <div class="msg-card">
                  <div class="msg-card-row"><span class="lbl">What:</span><span>Flu Shot (Regular)</span></div>
                  <div class="msg-card-row"><span class="lbl">When:</span><span>Wednesday, November 26<br>10:00 AM EST.</span></div>
                  <div class="msg-card-row"><span class="lbl">Where:</span><span>MedMe Pharmacy<br>175 Bloor Street East<br>Toronto, ON 90036-1234</span></div>
                  <div class="msg-card-foot">Need to manage your appointment?</div>
                  <div class="msg-card-links"><a href="#">Reschedule</a> or <a href="#">Cancel</a></div>
                </div>
                <p class="muted">Next steps for your appointment:</p>
                <p class="bold">Flu Shot (Regular)</p>
                <ul>
                  <li>A day before your appointment, you&rsquo;ll receive a text/email reminder.</li>
                  <li>Please arrive 5-10 minutes before your appointment time, and let the pharmacist know when you arrive.</li>
                  <li>Please bring your insurance information, prescription (if you have one), and wear clothing that makes it easy to access the injection site (most often the upper arm)</li>
                  <li>You may be asked to wait up to 15 minutes after your</li>
                </ul>
              </div>
            </div>

            <!-- PHONE 2, SMS conversation -->
            <div class="msg-phone msg-phone--sms">
              <div class="msg-status">
                <span>9:41</span>
                <span class="msg-status-icons">
                  <svg width="16" height="11" viewBox="0 0 18 11" fill="currentColor"><rect x="1" y="7" width="3" height="4" rx="0.6"/><rect x="5" y="5" width="3" height="6" rx="0.6"/><rect x="9" y="3" width="3" height="8" rx="0.6"/><rect x="13" y="0" width="3" height="11" rx="0.6"/></svg>
                  <svg width="14" height="11" viewBox="0 0 16 11" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><path d="M1 4 Q8 -1 15 4"/><path d="M3 6 Q8 3 13 6"/><path d="M5.5 8 Q8 7 10.5 8"/></svg>
                  <svg width="22" height="11" viewBox="0 0 24 11" fill="none"><rect x="0.5" y="0.5" width="21" height="10" rx="2.5" stroke="currentColor" opacity="0.45"/><rect x="22" y="3.5" width="1.4" height="4" rx="0.6" fill="currentColor" opacity="0.45"/><rect x="2" y="2" width="14" height="7" rx="1.2" fill="currentColor"/></svg>
                </span>
              </div>
              <div class="msg-sms-header">
                <span class="msg-sms-back">&#x2039;</span>
                <span class="msg-sms-back-badge">5</span>
                <div class="msg-sms-name-block">
                  <div class="msg-sms-name">MedMe Pharmacy</div>
                  <div class="msg-sms-status">last seen today at 3:12pm</div>
                </div>
                <span class="msg-sms-avatar"></span>
              </div>
              <div class="msg-sms-body" id="msgSmsBody">
                <div class="msg-date-pill">March 3</div>
                <div class="msg-bubble" id="msgBubble1">
                  Hi John! Your Flu Shot Regular appointment for 1 person(s) with MedMe Pharmacy is <b>tomorrow</b> at Nov-26 10:00 AM EST.
                  <span class="t">12:31pm</span>
                </div>
                <div class="msg-bubble" id="msgBubble2">
                  Hi John! Just a reminder that your Flu Shot Regular appointment for 1 person(s) with MedMe Pharmacy is <b>starting in an hour</b>.<br>It is scheduled for Wednesday, November 26 at 10:00 AM EST.
                  <span class="t">12:31pm</span>
                </div>
                <div class="msg-typing" id="msgTyping">
                  <span></span><span></span><span></span>
                </div>
              </div>
              <div class="msg-sms-input">
                <span class="msg-sms-input-clip">

/* ============================================================
   Messaging & Follow-Ups motion graphic
   - 3 phone screens visible side-by-side
   - Phone 2 (SMS) animates: typing indicator → bubble 1 → typing → bubble 2 → reset
   - ~10s loop
   ============================================================ */
(function () {
  'use strict';
  var host = document.getElementById('msgHost');
  var inner = document.getElementById('msgFrame');
  if (!host || !inner) return;

  function fit() {
    var r = host.getBoundingClientRect();
    var s = Math.min(r.width / 1192, r.height / 656);
    if (s > 0) inner.style.transform = 'translate(-50%,-50%) scale(' + s + ')';
  }
  window.addEventListener('resize', fit);
  requestAnimationFrame(function () { requestAnimationFrame(fit); });
  window.addEventListener('load', fit);

  function $(id) { return document.getElementById(id); }

  var TOTAL = 10000;
  var SEQ = {
    typing1On:  500,
    typing1Off: 1700,
    bubble1On:  1800,
    typing2On:  3700,
    typing2Off: 4900,
    bubble2On:  5000,
    reset:      9000
  };

  var step = -1;
  var wasHidden = true;
  var startTime = 0;

  function reset(now) {
    step = 0;
    startTime = now || performance.now();
    var b1 = $('msgBubble1'); if (b1) b1.classList.remove('is-on');
    var b2 = $('msgBubble2'); if (b2) b2.classList.remove('is-on');
    var ty = $('msgTyping');  if (ty) ty.classList.remove('is-on');
  }

  function tick(now) {
    var rect = host.getBoundingClientRect();
    if (rect.width === 0) {
      wasHidden = true;
      requestAnimationFrame(tick);
      return;
    }
    if (wasHidden) {
      wasHidden = false;
      reset(now);
    }
    var t = (now - startTime) % TOTAL;
    if (t < 0) t = 0;
    if (t < 200 && step !== 0) reset(now);

    if (t >= SEQ.typing1On  && step === 0) { $('msgTyping').classList.add('is-on');    step = 1; }
    if (t >= SEQ.typing1Off && step === 1) { $('msgTyping').classList.remove('is-on'); step = 2; }
    if (t >= SEQ.bubble1On  && step === 2) { $('msgBubble1').classList.add('is-on');   step = 3; }
    if (t >= SEQ.typing2On  && step === 3) { $('msgTyping').classList.add('is-on');    step = 4; }
    if (t >= SEQ.typing2Off && step === 4) { $('msgTyping').classList.remove('is-on'); step = 5; }
    if (t >= SEQ.bubble2On  && step === 5) { $('msgBubble2').classList.add('is-on');   step = 6; }
    if (t >= SEQ.reset      && step === 6) {
      $('msgBubble1').classList.remove('is-on');
      $('msgBubble2').classList.remove('is-on');
      step = 7;
    }

    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
})();

/* ============================================================
   Product mockup tabs, swap which mockup-pane is visible.
   Scribe pane re-runs fitMockup() on activation so the inner
   1192×656 frame scales correctly after being display:none.
   ============================================================ */
(function(){
  'use strict';
  var tabs = document.querySelectorAll('.tab[data-tab]');
  var panes = document.querySelectorAll('.mockup-pane[data-pane]');

  function activate(key){
    tabs.forEach(function(t){
      var on = t.getAttribute('data-tab') === key;
      t.classList.toggle('tab--active', on);
      t.setAttribute('aria-selected', on ? 'true' : 'false');
    });
    panes.forEach(function(p){
      p.classList.toggle('mockup-pane--active', p.getAttribute('data-pane') === key);
    });

    /* Re-fit motion-graphic mockups when their pane becomes active.
       While display:none, the host had zero dimensions and the inner
       1192×656 frame's scale collapsed. */
    function refit(hostId, innerId) {
      var host = document.getElementById(hostId);
      var inner = document.getElementById(innerId);
      if (!host || !inner) return;
      requestAnimationFrame(function(){
        var r = host.getBoundingClientRect();
        var s = Math.min(r.width / 1192, r.height / 656);
        if (s > 0) inner.style.transform = 'translate(-50%,-50%) scale(' + s + ')';
      });
    }
    if (key === 'documentation') refit('mockupHost', 'frame');
    if (key === 'scheduling')    refit('schedHost', 'schedFrame');
    if (key === 'intake')        refit('intakeHost', 'intakeFrame');
    if (key === 'messaging')     refit('msgHost', 'msgFrame');
    if (key === 'billing')       refit('billHost', 'billFrame');
  }

  /* ----------------------------------------------------------
     Auto-rotate tabs every 10 seconds, with a matcha progress
     bar that fills under the active tab.
     - Only runs while the tab bar is in the viewport.
     - Pauses when the browser tab is hidden.
     - Stops permanently once the user clicks a tab.
     ---------------------------------------------------------- */
  var ROTATE_MS    = 10000;
  var rotateTimer  = null;
  var userTouched  = false;
  var inView       = false;
  var tabBar       = document.querySelector('.tab-bar');

  function activeIdx() {
    for (var i = 0; i < tabs.length; i++) {
      if (tabs[i].classList.contains('tab--active')) return i;
    }
    return 0;
  }
  function advance() {
    if (userTouched || !inView || document.hidden) return;
    var next = (activeIdx() + 1) % tabs.length;
    activate(tabs[next].getAttribute('data-tab'));
    /* Restart the CSS progress animation on the new active tab.
       The animation runs on .tab--active::after and is keyed to the
       same 10s as ROTATE_MS, so the bar reaches 100% just as the
       next interval fires. Forcing reflow guarantees a clean restart
       even when the same tab key is somehow re-activated. */
    if (tabBar) {
      tabBar.classList.remove('is-rotating');
      void tabBar.offsetWidth;
      tabBar.classList.add('is-rotating');
    }
  }
  function startRotation() {
    if (rotateTimer || userTouched) return;
    if (tabBar) tabBar.classList.add('is-rotating');
    rotateTimer = setInterval(advance, ROTATE_MS);
  }
  function stopRotation() {
    if (rotateTimer) { clearInterval(rotateTimer); rotateTimer = null; }
    if (tabBar) tabBar.classList.remove('is-rotating');
  }

  if (tabBar && 'IntersectionObserver' in window) {
    new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        inView = e.isIntersecting;
        if (inView && !userTouched) startRotation();
        else stopRotation();
      });
    }, { threshold: 0.3 }).observe(tabBar);
  } else {
    inView = true;
    startRotation();
  }

  document.addEventListener('visibilitychange', function () {
    if (document.hidden) stopRotation();
    else if (inView && !userTouched) startRotation();
  });

  /* Manual click: stop rotation, activate the chosen tab. The active
     tab keeps its full-width matcha underline (no animation), so the
     bar remains a clean static indicator after user interaction. */
  tabs.forEach(function (t) {
    t.addEventListener('click', function () {
      userTouched = true;
      stopRotation();
      activate(t.getAttribute('data-tab'));
    });
  });
})();

/* ============================================================
   Reimbursement calculator, live update on input change
   ============================================================ */
(function(){
  'use strict';
  document.querySelectorAll('[data-calc-widget]').forEach(function(widget){
    var stores = widget.querySelector('[data-calc-stores]');
    var enc    = widget.querySelector('[data-calc-encounters]');
    var out    = widget.querySelector('[data-calc-result]');
    if (!stores || !enc || !out) return;

    var AVG_PER_ENC = 74;
    var WEEKS = 50;
    var CAPTURE = 0.78;

    function recalc(){
      var s = Math.max(0, parseInt(stores.value, 10) || 0);
      var e = Math.max(0, parseInt(enc.value, 10) || 0);
      var unlock = Math.round(s * e * WEEKS * AVG_PER_ENC * CAPTURE);
      out.textContent = '$' + unlock.toLocaleString('en-US');
    }
    stores.addEventListener('input', recalc);
    enc.addEventListener('input', recalc);
    recalc();
  });
})();`}></script>

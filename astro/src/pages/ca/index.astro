<script is:inline slot="end-of-body" set:html={`/* ============================================================
   Hero AI-Scribe motion graphic, 16-second loop:
   cursor → Start Scribe → record/wave/transcription stream →
   Populate fields → per-field auto-type → note typing →
   Continue pulse. Mockup scales to fit its responsive container.
   ============================================================ */
(function(){
  'use strict';
  var host = document.getElementById('mockupHost');
  var inner = document.getElementById('frame');
  if (!host || !inner) return;

  function fitMockup(){
    var r = host.getBoundingClientRect();
    var s = Math.min(r.width / 1192, r.height / 656);
    inner.style.transform = 'translate(-50%,-50%) scale(' + s + ')';
  }
  window.addEventListener('resize', fitMockup);
  requestAnimationFrame(function(){ requestAnimationFrame(fitMockup); });
  window.addEventListener('load', fitMockup);

  function $(id){ return document.getElementById(id); }
  var TOTAL = 16000;

  var SEQ = {
    cursorToScribe:   { at: 300,   dur: 900 },
    clickScribe:      { at: 1200 },
    recordWindow:     { from: 1300, to: 6800 },
    cursorToPopulate: { at: 6800,  dur: 800 },
    clickPopulate:    { at: 7600 },
    fill: [
      { id: 'f-first',  at: 7800 },
      { id: 'f-last',   at: 8200 },
      { id: 'f-dob',    at: 8600 },
      { id: 'f-street', at: 9100 },
      { id: 'f-apt',    at: 9550 },
      { id: 'f-city',   at: 10000 },
      { id: 'f-prov',   at: 10400 },
      { id: 'f-post',   at: 10800 }
    ],
    cursorToNote:     { at: 11200, dur: 700 },
    typeNote:         { from: 11900, to: 13200 },
    cursorToContinue: { at: 13400, dur: 700 },
    pulseContinue:    { at: 14100 }
  };

  var TRANS = [
    { t: "Patient: ", speaker: true },
    { t: "Hi, I'm Sophia Ramirez. " },
    { t: "My date of birth is February 1st, 1993. " },
    { t: "I live at 118 Queen Street West, Apartment 402, in Toronto, Ontario, " },
    { t: "postal code M5H 2N2. " },
    { t: "\nPharmacist: ", speaker: true },
    { t: "Thanks Sophia. I'll book a follow-up next month." }
  ];

  /* Build the transcription DOM safely (no innerHTML for user-style strings) */
  (function(){
    var stream = $('stream');
    if (!stream) return;
    TRANS.forEach(function(tok){
      var wrap = tok.speaker ? document.createElement('span') : stream;
      if (tok.speaker) { wrap.className = 'speaker'; stream.appendChild(wrap); }
      tok.t.split('').forEach(function(c){
        var node = document.createElement('span');
        if (c === '\n') { node.appendChild(document.createElement('br')); }
        else if (c === ' ') { node.appendChild(document.createTextNode(' ')); }
        else { node.textContent = c; }
        wrap.appendChild(node);
      });
    });
  })();

  function fmt(s){ return String(Math.floor(s/60)).padStart(2,'0') + ':' + String(s%60).padStart(2,'0'); }

  function moveCursor(target, dur){
    dur = dur || 800;
    var cur = $('cursor');
    var fr = inner.getBoundingClientRect();
    var r = target.getBoundingClientRect();
    var m = new DOMMatrixReadOnly(getComputedStyle(inner).transform);
    var sx = m.a, sy = m.d;
    var fx = (r.left - fr.left) / sx + r.width / sx / 2 - 6;
    var fy = (r.top  - fr.top)  / sy + r.height / sy / 2 - 4;
    cur.style.transition = 'transform ' + dur + 'ms cubic-bezier(.5,.05,.2,1)';
    cur.style.transform  = 'translate(' + fx + 'px,' + fy + 'px)';
  }
  function moveInstant(x, y){
    var c = $('cursor');
    c.style.transition = 'none';
    c.style.transform  = 'translate(' + x + 'px,' + y + 'px)';
  }
  function ripple(){
    var r = $('ripple');
    r.classList.remove('go');
    void r.offsetWidth;
    r.classList.add('go');
  }

  var step = -1;
  var clicked = {};

  function reset(){
    step = -1;
    clicked = {};
    $('scribeBtn').classList.remove('recording','pressed');
    $('scribeLabel').textContent = 'Start Scribe';
    $('wave').classList.remove('live');
    $('barFill').style.width = '0%';
    $('timer').textContent = '00:00';
    $('populate').classList.remove('flash');
    $('continue').classList.remove('pulse');
    $('stream').style.display = 'none';
    $('transPh').style.display = 'block';
    document.querySelectorAll('#stream span').forEach(function(s){ s.classList.remove('on'); });
    SEQ.fill.forEach(function(it){
      var f = $(it.id); if (!f) return;
      f.classList.remove('lit','has-val','filled');
      var typed = f.querySelector('.typed');
      typed.textContent = '';
      typed.classList.remove('caret');
    });
    $('notePh').style.display = 'block';
    $('noteVal').style.display = 'none';
    $('noteVal').textContent = '';
    $('noteField').classList.remove('lit');
  }

  function tick(now){
    var t = now % TOTAL;

    if (t < 200 && step !== 0) { reset(); step = 0; moveInstant(60, 540); }

    if (t >= SEQ.cursorToScribe.at && step === 0) {
      moveCursor($('scribeBtn'), SEQ.cursorToScribe.dur); step = 1;
    }
    if (t >= SEQ.clickScribe.at && !clicked.scribe) {
      clicked.scribe = true;
      ripple();
      var b = $('scribeBtn');
      b.classList.add('pressed');
      setTimeout(function(){ b.classList.remove('pressed'); }, 150);
      setTimeout(function(){
        b.classList.add('recording');
        $('scribeLabel').textContent = 'Stop Scribe';
        $('wave').classList.add('live');
      }, 180);
    }
    if (t >= SEQ.cursorToPopulate.at && step === 1) {
      moveCursor($('populate'), SEQ.cursorToPopulate.dur); step = 2;
    }
    if (t >= SEQ.clickPopulate.at && !clicked.populate) {
      clicked.populate = true;
      ripple();
      $('populate').classList.add('flash');
    }
    if (t >= SEQ.cursorToNote.at && step === 2) {
      moveCursor($('addBtn'), SEQ.cursorToNote.dur); step = 3;
    }
    if (t >= SEQ.cursorToContinue.at && step === 3) {
      moveCursor($('continue'), SEQ.cursorToContinue.dur); step = 4;
    }
    if (t >= SEQ.pulseContinue.at && !clicked.cont) {
      clicked.cont = true;
      ripple();
      $('continue').classList.add('pulse');
    }

    var rw = SEQ.recordWindow;
    if (t >= rw.from) {
      var e = Math.min(rw.to, t) - rw.from;
      $('timer').textContent = fmt(Math.min(22, Math.floor(e / 1000 * 4)));
      $('barFill').style.width = (15 + Math.min(1, e / (rw.to - rw.from)) * 70) + '%';
      var stream = $('stream');
      var spans = stream.querySelectorAll('span:not(.speaker)');
      if (stream.style.display !== 'block') {
        stream.style.display = 'block';
        $('transPh').style.display = 'none';
      }
      var p = Math.min(1, (t - rw.from) / (rw.to - rw.from - 200));
      var upto = Math.floor(p * spans.length);
      for (var i = 0; i < spans.length; i++) {
        if (i < upto) spans[i].classList.add('on');
      }
    }

    SEQ.fill.forEach(function(item){
      var f = $(item.id); if (!f) return;
      var target = f.dataset.target;
      var DUR = 380;
      if (t >= item.at) {
        f.classList.add('lit','has-val','filled');
        var typed = f.querySelector('.typed');
        var p = Math.min(1, (t - item.at) / DUR);
        var n = Math.floor(p * target.length);
        typed.textContent = target.slice(0, n);
        if (p < 1) typed.classList.add('caret'); else typed.classList.remove('caret');
        if (t - item.at > 700) f.classList.remove('lit');
      }
    });

    if (t >= SEQ.typeNote.from) {
      var txt = "Schedule MedsCheck follow-up in 4 weeks";
      var pn = Math.min(1, (t - SEQ.typeNote.from) / (SEQ.typeNote.to - SEQ.typeNote.from));
      var nn = Math.floor(pn * txt.length);
      $('notePh').style.display = 'none';
      var v = $('noteVal');
      v.style.display = 'inline';
      v.textContent = txt.slice(0, nn);
      $('noteField').classList.add('lit');
    }

    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
})();

/* ============================================================
   Marquee carousel, duplicate each track's children once so a
   translateX(-50%) loop wraps seamlessly (the second set takes
   the first set's place at the wrap point).
   ============================================================ */
(function(){
  'use strict';
  document.querySelectorAll('[data-marquee]').forEach(function(track){
    var originals = Array.prototype.slice.call(track.children);
    originals.forEach(function(node){
      var clone = node.cloneNode(true);
      clone.setAttribute('aria-hidden', 'true');
      track.appendChild(clone);
    });
  });
})();

/* ============================================================
   Counter animation, ticks numeric values from 0 to their target
   when first scrolled into view. Uses easeOutCubic for a smooth
   settle. Honors prefers-reduced-motion (sets the final value
   directly without animating).
   ============================================================ */
(function(){
  'use strict';
  var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  function format(value, decimals, prefix, suffix){
    if (decimals > 0) {
      return prefix + value.toFixed(decimals) + suffix;
    }
    return prefix + Math.floor(value).toLocaleString('en-US') + suffix;
  }
  function animateCount(el){
    var target   = parseFloat(el.dataset.count);
    var decimals = parseInt(el.dataset.decimals || '0', 10);
    var prefix   = el.dataset.prefix || '';
    var suffix   = el.dataset.suffix || '';
    if (isNaN(target)) return;
    if (reduce) { el.textContent = format(target, decimals, prefix, suffix); return; }

    var duration = 1500;
    var start = performance.now();
    function tick(now){
      var p = Math.min(1, (now - start) / duration);
      var eased = 1 - Math.pow(1 - p, 3); /* easeOutCubic */
      el.textContent = format(target * eased, decimals, prefix, suffix);
      if (p < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  if (!('IntersectionObserver' in window)) {
    document.querySelectorAll('[data-count]').forEach(animateCount);
    return;
  }
  var observer = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting){
        animateCount(e.target);
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.4 });
  document.querySelectorAll('[data-count]').forEach(function(el){ observer.observe(el); });
})();

/* ============================================================
   Scroll reveal, fades + rises elements as they enter the
   viewport. Auto-staggers siblings within grid containers.
   ============================================================ */
(function(){
  'use strict';
  if (!('IntersectionObserver' in window)) return;
  if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  /* Targets: every card/stat that should reveal on scroll. */
  var selectors = [
    '.h-card',
    '.trust__stat',
    '.calc-card',
    '.tile__head'
  ];
  var nodes = document.querySelectorAll(selectors.join(','));

  nodes.forEach(function(node){
    node.classList.add('reveal');
    /* Stagger siblings that share a parent grid/row */
    var parent = node.parentElement;
    if (!parent) return;
    var siblings = Array.prototype.filter.call(parent.children, function(c){
      return c.matches && c.matches(selectors.join(','));
    });
    var idx = siblings.indexOf(node);
    if (idx >= 0 && idx < 6) node.classList.add('is-stagger-' + (idx + 1));
  });

  var observer = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting){
        e.target.classList.add('is-visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });

  document.querySelectorAll('.reveal').forEach(function(el){ observer.observe(el); });
})();

/* ============================================================
   Testimonial slider, auto-rotates every 6s, dot click jumps,
   hover pauses, respects prefers-reduced-motion (no auto-rotate).
   ============================================================ */
(function(){
  'use strict';
  var stage = document.querySelector('[data-testimonials]');
  if (!stage) return;
  var slides = stage.querySelectorAll('.testimonial');
  var dots = stage.querySelectorAll('.testimonials__dots button');
  if (!slides.length) return;
  var idx = 0;
  var timer;
  var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  function go(i){
    idx = (i + slides.length) % slides.length;
    slides.forEach(function(s, j){ s.classList.toggle('testimonial--active', j === idx); });
    dots.forEach(function(d, j){ d.classList.toggle('active', j === idx); });
  }
  function advance(){ go(idx + 1); }
  function play(){ if (!reduce) timer = setInterval(advance, 6000); }
  function pause(){ clearInterval(timer); }

  dots.forEach(function(d, i){
    d.addEventListener('click', function(){ go(i); pause(); play(); });
  });
  stage.addEventListener('mouseenter', pause);
  stage.addEventListener('mouseleave', play);
  play();
})();

/* ============================================================
   Scheduling & Queueing mockup, cursor moves to an empty slot,
   tooltip appears with patient details, slot fills matcha, and a
   new queue entry slides in from the top. ~12-second loop.
   ============================================================ */
(function () {
  'use strict';
  var host = document.getElementById('schedHost');
  var inner = document.getElementById('schedFrame');
  if (!host || !inner) return;

  function fit() {
    var r = host.getBoundingClientRect();
    var s = Math.min(r.width / 1192, r.height / 656);
    if (s > 0) inner.style.transform = 'translate(-50%,-50%) scale(' + s + ')';
  }
  window.addEventListener('resize', fit);
  requestAnimationFrame(function () { requestAnimationFrame(fit); });
  window.addEventListener('load', fit);

  function $(id) { return document.getElementById(id); }
  var TOTAL = 9000;
  var SEQ = {
    cursorToSlot: { at: 400,  dur: 1600 },
    slotHover:    { at: 2000 },
    clickSlot:    { at: 3300 },
    slotBooked:   { at: 3400 },
    reset:        { at: 7500 }
  };

  function moveCursor(target, dur) {
    dur = dur || 800;
    var cur = $('schCursor');
    var fr = inner.getBoundingClientRect();
    var r = target.getBoundingClientRect();
    var m = new DOMMatrixReadOnly(getComputedStyle(inner).transform);
    var sx = m.a, sy = m.d;
    var fx = (r.left - fr.left) / sx + r.width / sx / 2 - 6;
    var fy = (r.top - fr.top) / sy + r.height / sy / 2 - 4;
    cur.style.transition = 'transform ' + dur + 'ms cubic-bezier(.5,.05,.2,1)';
    cur.style.transform = 'translate(' + fx + 'px,' + fy + 'px)';
  }
  function moveInstant(x, y) {
    var c = $('schCursor');
    c.style.transition = 'none';
    c.style.transform = 'translate(' + x + 'px,' + y + 'px)';
  }
  function ripple() {
    var r = $('schRipple');
    r.classList.remove('go');
    void r.offsetWidth;
    r.classList.add('go');
  }

  var step = -1;
  var clicked = {};
  var wasHidden = true;
  var startTime = 0;

  function reset(now) {
    step = 0;
    clicked = {};
    startTime = now || performance.now();
    var slot = $('schTargetSlot');
    if (slot) slot.classList.remove('is-hover', 'is-booked');
    moveInstant(80, 580);
  }

  function tick(now) {
    /* Pane is display:none on inactive tabs, host has zero dimensions
       and DOMMatrixReadOnly would throw parsing 'none'. Skip until the
       host is visible (Scheduling tab is active). */
    var rect = host.getBoundingClientRect();
    if (rect.width === 0) {
      wasHidden = true;
      requestAnimationFrame(tick);
      return;
    }

    if (wasHidden) {
      wasHidden = false;
      reset(now);
    }

    var t = (now - startTime) % TOTAL;
    if (t < 0) t = 0;

    if (t < 200 && step !== 0) reset(now);

    if (t >= SEQ.cursorToSlot.at && step === 0) {
      moveCursor($('schTargetSlot'), SEQ.cursorToSlot.dur);
      step = 1;
    }
    if (t >= SEQ.slotHover.at && step === 1) {
      $('schTargetSlot').classList.add('is-hover');
      step = 2;
    }
    if (t >= SEQ.clickSlot.at && !clicked.slot) {
      clicked.slot = true;
      ripple();
    }
    if (t >= SEQ.slotBooked.at && step === 2) {
      var slot = $('schTargetSlot');
      slot.classList.remove('is-hover');
      slot.classList.add('is-booked');
      step = 3;
    }
    if (t >= SEQ.reset.at && step === 3) {
      var s = $('schTargetSlot');
      if (s) s.classList.remove('is-booked');
      step = 4;
    }

    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
})();

/* ============================================================
   Patient Intake motion graphic
   - Types into 7 form fields one at a time
   - Progress bar segment between step 2 (current) and step 3
     fills proportional to typed characters
   - Cursor clicks Continue → step 2 fills, step 3 activates
   - Right-side vertical step list updates too
   - 14-second loop
   ============================================================ */
(function () {
  'use strict';
  var host = document.getElementById('intakeHost');
  var inner = document.getElementById('intakeFrame');
  if (!host || !inner) return;

  function fit() {
    var r = host.getBoundingClientRect();
    var s = Math.min(r.width / 1192, r.height / 656);
    if (s > 0) inner.style.transform = 'translate(-50%,-50%) scale(' + s + ')';
  }
  window.addEventListener('resize', fit);
  requestAnimationFrame(function () { requestAnimationFrame(fit); });
  window.addEventListener('load', fit);

  function $(id) { return document.getElementById(id); }

  var FIELDS = [
    { id: 'fldFirstName', text: 'Jane' },
    { id: 'fldLastName',  text: 'Doe' },
    { id: 'fldDOB',       text: '1993-02-01' },
    { id: 'fldAddress',   text: '311-38 Cameron Street' },
    { id: 'fldCity',      text: 'Toronto' },
    { id: 'fldProvince',  text: 'Ontario' },
    { id: 'fldPostal',    text: 'M5T 0C3' }
  ];
  var TOTAL_CHARS = FIELDS.reduce(function (a, f) { return a + f.text.length; }, 0);

  var TOTAL       = 14000;
  var TYPE_START  = 900;
  var TYPE_END    = 8700;
  var CTA_START   = 9200;
  var CTA_END     = 10100;
  var CLICK       = 10300;
  var ADVANCE     = 10500;
  var RESET_VIS   = 12800;

  var step = -1;
  var typedIdx = -1;
  var clicked = false;
  var wasHidden = true;
  var startTime = 0;

  function setStepsBaseline() {
    var steps = host.querySelectorAll('.intake-step');
    var lines = host.querySelectorAll('.intake-step-line');
    steps.forEach(function (s, i) {
      s.classList.remove('is-done', 'is-active');
      if (i === 0) s.classList.add('is-done');
      if (i === 1) s.classList.add('is-active');
    });
    lines.forEach(function (l, i) {
      l.classList.toggle('is-done', i === 0);
    });
    var vsteps = host.querySelectorAll('.intake-vstep');
    vsteps.forEach(function (v, i) {
      v.classList.remove('is-done', 'is-active');
      if (i === 0) v.classList.add('is-active');
    });
  }

  function reset(now) {
    step = 0;
    typedIdx = -1;
    clicked = false;
    startTime = now || performance.now();
    FIELDS.forEach(function (f) {
      var fld = $(f.id);
      if (!fld) return;
      fld.classList.remove('is-typing');
      var v = fld.querySelector('.intake-field-value');
      if (v) v.textContent = '';
    });
    var prog = $('intakeProgress');
    if (prog) prog.style.width = '0%';
    setStepsBaseline();
  }

  function tick(now) {
    var rect = host.getBoundingClientRect();
    if (rect.width === 0) {
      wasHidden = true;
      requestAnimationFrame(tick);
      return;
    }
    if (wasHidden) {
      wasHidden = false;
      reset(now);
    }
    var t = (now - startTime) % TOTAL;
    if (t < 0) t = 0;
    if (t < 200 && step !== 0) reset(now);

    if (t >= TYPE_START && t < TYPE_END) {
      var pct = (t - TYPE_START) / (TYPE_END - TYPE_START);
      if (pct < 0) pct = 0;
      if (pct > 1) pct = 1;
      var targetChars = Math.floor(pct * TOTAL_CHARS);

      var consumed = 0;
      var currentTypingIdx = -1;
      for (var i = 0; i < FIELDS.length; i++) {
        var f = FIELDS[i];
        var fld = $(f.id);
        if (!fld) continue;
        var v = fld.querySelector('.intake-field-value');
        var avail = targetChars - consumed;
        if (avail <= 0) {
          if (v) v.textContent = '';
          fld.classList.remove('is-typing');
          consumed += 0;
          continue;
        }
        if (avail >= f.text.length) {
          if (v) v.textContent = f.text;
          fld.classList.remove('is-typing');
          consumed += f.text.length;
        } else {
          if (v) v.textContent = f.text.substring(0, avail);
          fld.classList.add('is-typing');
          currentTypingIdx = i;
          consumed = targetChars;
          break;
        }
      }
      var prog = $('intakeProgress');
      if (prog) prog.style.width = (pct * 100) + '%';
    } else if (t >= TYPE_END) {
      var allDone = $('intakeProgress');
      if (allDone) allDone.style.width = '100%';
      FIELDS.forEach(function (f) {
        var fld = $(f.id);
        if (fld) fld.classList.remove('is-typing');
        var v = fld && fld.querySelector('.intake-field-value');
        if (v && v.textContent !== f.text) v.textContent = f.text;
      });
    }

    if (t >= CTA_START && step === 0) {
      step = 1;
    }
    if (t >= CLICK && !clicked) {
      clicked = true;
    }
    if (t >= ADVANCE && step === 1) {
      var steps = host.querySelectorAll('.intake-step');
      var lines = host.querySelectorAll('.intake-step-line');
      if (steps[1]) { steps[1].classList.remove('is-active'); steps[1].classList.add('is-done'); }
      if (lines[1]) { lines[1].classList.add('is-done'); }
      if (steps[2]) { steps[2].classList.add('is-active'); }
      var vsteps = host.querySelectorAll('.intake-vstep');
      if (vsteps[0]) { vsteps[0].classList.remove('is-active'); vsteps[0].classList.add('is-done'); }
      if (vsteps[1]) { vsteps[1].classList.add('is-active'); }
      step = 2;
    }
    if (t >= RESET_VIS && step === 2) {
      step = 3;
    }

    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
})();


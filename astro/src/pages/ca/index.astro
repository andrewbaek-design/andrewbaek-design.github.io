</style>

  <script is:inline slot="end-of-body" set:html={`/* ============================================================
   Hero AI-Scribe motion graphic, 16-second loop:
   cursor → Start Scribe → record/wave/transcription stream →
   Populate fields → per-field auto-type → note typing →
   Continue pulse. Mockup scales to fit its responsive container.
   ============================================================ */
(function(){
  'use strict';
  var host = document.getElementById('mockupHost');
  var inner = document.getElementById('frame');
  if (!host || !inner) return;

  function fitMockup(){
    var r = host.getBoundingClientRect();
    var s = Math.min(r.width / 1192, r.height / 656);
    inner.style.transform = 'translate(-50%,-50%) scale(' + s + ')';
  }
  window.addEventListener('resize', fitMockup);
  requestAnimationFrame(function(){ requestAnimationFrame(fitMockup); });
  window.addEventListener('load', fitMockup);

  function $(id){ return document.getElementById(id); }

  /* Conceptual AI Clinical Assistant animation (rewrote 2026-05-26).
     Flow: cursor → Start Scribe → wave + transcription → 4 consult
     fields reveal one-by-one → brief hold → loop. */
  /* Documentation timing tightened so popup fires before the 10s rotation
     timer can cut the pane off, and so heroAdvance() can fire at ~9.7s
     to hand off cleanly to Billing with full hold time on the popup. */
  var TOTAL = 11000;
  var SEQ = {
    cursorToScribe:  { at: 300,   dur: 900 },
    clickScribe:     { at: 1200 },
    recordWindow:    { from: 1300, to: 6500 },
    bubbleRevealAt:  [1500, 2700, 3900, 5000],   /* 4 chat bubbles stagger */
    fieldsRevealAt:  [6700, 7200, 7700, 8200],   /* 500ms staggered per field */
    popupAt:         8800,                        /* "Consult completed" popup */
    advanceAt:       9700                         /* heroAdvance → Billing */
  };
  /* Every value here is something the patient or pharmacist literally said
     in the chat transcript above, paraphrased only as a clinical note would
     paraphrase it. No diagnoses, codes, or follow-up windows that the speakers
     didn't surface — that was prior feedback ("don't show hallucinations"). */
  var FIELDS = [
    { id: 'f-reason',     text: 'Metformin, lisinopril' },
    { id: 'f-assessment', text: 'Misses evening doses; dry cough' },
    { id: 'f-plan',       text: 'Switch to AM dosing; set up pillbox' },
    { id: 'f-followup',   text: 'Note cough on lisinopril' }
  ];

  function fmt(s){ return String(Math.floor(s/60)).padStart(2,'0') + ':' + String(s%60).padStart(2,'0'); }

  function moveCursor(target, dur){
    dur = dur || 800;
    var cur = $('cursor');
    var fr = inner.getBoundingClientRect();
    var r = target.getBoundingClientRect();
    var m = new DOMMatrixReadOnly(getComputedStyle(inner).transform);
    var sx = m.a, sy = m.d;
    var fx = (r.left - fr.left) / sx + r.width / sx / 2 - 6;
    var fy = (r.top  - fr.top)  / sy + r.height / sy / 2 - 4;
    cur.style.transition = 'transform ' + dur + 'ms cubic-bezier(.5,.05,.2,1)';
    cur.style.transform  = 'translate(' + fx + 'px,' + fy + 'px)';
  }
  function moveInstant(x, y){
    var c = $('cursor');
    c.style.transition = 'none';
    c.style.transform  = 'translate(' + x + 'px,' + y + 'px)';
  }
  function ripple(){
    var r = $('ripple');
    r.classList.remove('go');
    void r.offsetWidth;
    r.classList.add('go');
  }

  var step = -1;
  var clicked = {};
  var wasHidden = true;
  var startTime = 0;
  function reset(now){
    step = -1;
    docAdvanced = false;
    startTime = now || performance.now();
    clicked = {};
    $('scribeBtn').classList.remove('recording','pressed');
    $('scribeLabel').textContent = 'Start Scribe';
    $('wave').classList.remove('live');
    $('timer').textContent = '00:00';
    var ph = $('transPh');
    if (ph) ph.classList.remove('is-hidden');
    document.querySelectorAll('.doc-bubble').forEach(function(b){ b.classList.remove('is-on'); });
    FIELDS.forEach(function(f){
      var fld = $(f.id); if (!fld) return;
      fld.classList.remove('is-filling', 'is-filled', 'is-typing');
      var v = fld.querySelector('.doc-field-value');
      if (v) v.textContent = '';
    });
    filledFlags = [false, false, false, false];
    var dp = $('docPopup');
    if (dp) dp.classList.remove('is-visible');
  }

  /* Per-field "filling" glow window (matches Patient Intake's 600ms). */
  var FILL_GLOW_MS = 600;
  var docAdvanced = false;
  /* Tracks which fields have already been filled this loop, so the instant
     fill only fires once per field per cycle (reset on each restart). */
  var filledFlags = [false, false, false, false];

  function tick(now){
    /* Skip while the pane is display:none (zero dimensions). When it
       becomes visible, reset so the animation starts fresh, not mid-loop. */
    var rect = host.getBoundingClientRect();
    if (rect.width === 0) {
      wasHidden = true;
      requestAnimationFrame(tick);
      return;
    }
    if (wasHidden) {
      wasHidden = false;
      reset(now);
    }
    var t = (now - startTime) % TOTAL;
    if (t < 0) t = 0;

    if (t < 200 && step !== 0) { reset(now); step = 0; moveInstant(60, 540); }

    if (t >= SEQ.cursorToScribe.at && step === 0) {
      moveCursor($('scribeBtn'), SEQ.cursorToScribe.dur); step = 1;
    }
    if (t >= SEQ.clickScribe.at && !clicked.scribe) {
      clicked.scribe = true;
      ripple();
      var b = $('scribeBtn');
      b.classList.add('pressed');
      setTimeout(function(){ b.classList.remove('pressed'); }, 150);
      setTimeout(function(){
        b.classList.add('recording');
        $('scribeLabel').textContent = 'Stop Scribe';
        $('wave').classList.add('live');
      }, 180);
    }

    var rw = SEQ.recordWindow;
    if (t >= rw.from) {
      var e = Math.min(rw.to, t) - rw.from;
      $('timer').textContent = fmt(Math.min(22, Math.floor(e / 1000 * 4)));
      /* Hide placeholder once recording starts. */
      var ph = $('transPh');
      if (ph && !ph.classList.contains('is-hidden')) ph.classList.add('is-hidden');
      /* Stagger-reveal chat bubbles at scheduled times. */
      for (var bi = 0; bi < SEQ.bubbleRevealAt.length; bi++) {
        if (t >= SEQ.bubbleRevealAt[bi]) {
          var bub = document.querySelector('[data-bubble="' + (bi + 1) + '"]');
          if (bub) bub.classList.add('is-on');
        }
      }
    }
    /* Stop the wave + label once the record window ends. */
    if (t >= rw.to && clicked.scribe && step === 1) {
      $('scribeBtn').classList.remove('recording');
      $('scribeLabel').textContent = 'Start Scribe';
      $('wave').classList.remove('live');
      step = 2;
    }

    /* Fill each consult field in one beat (mirrors the Patient Intake
       animation), not character-by-character. Prior feedback flagged the
       typing read as "still filling it out manually" — the AI should
       surface the extracted facts at once, not retype the chat. */
    for (var fi = 0; fi < SEQ.fieldsRevealAt.length; fi++) {
      var fStart = SEQ.fieldsRevealAt[fi];
      if (t < fStart) continue;
      if (filledFlags[fi]) continue;
      var f   = FIELDS[fi]; if (!f) continue;
      var fld = $(f.id);    if (!fld) continue;
      var v   = fld.querySelector('.doc-field-value');
      if (v) v.textContent = f.text;
      filledFlags[fi] = true;
      fld.classList.add('is-filling');
      (function(el){
        setTimeout(function(){
          el.classList.remove('is-filling');
          el.classList.add('is-filled');
        }, FILL_GLOW_MS);
      })(fld);
    }

    /* "Consult completed" popup, pops after the 4th field finishes typing. */
    if (t >= SEQ.popupAt) {
      var dp2 = $('docPopup');
      if (dp2 && !dp2.classList.contains('is-visible')) dp2.classList.add('is-visible');
    }

    /* heroAdvance → Billing once popup has held briefly. Prevents the
       10s rotation timer from cutting off mid-popup. */
    if (t >= SEQ.advanceAt && !docAdvanced) {
      docAdvanced = true;
      if (typeof window.heroAdvance === 'function') window.heroAdvance();
    }

    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
})();

/* ============================================================
   Marquee carousel, duplicate each track's children once so a
   translateX(-50%) loop wraps seamlessly (the second set takes
   the first set's place at the wrap point).
   ============================================================ */
(function(){
  'use strict';
  document.querySelectorAll('[data-marquee]').forEach(function(track){
    var originals = Array.prototype.slice.call(track.children);
    originals.forEach(function(node){
      var clone = node.cloneNode(true);
      clone.setAttribute('aria-hidden', 'true');
      track.appendChild(clone);
    });
  });
})();

/* ============================================================
   Counter animation, ticks numeric values from 0 to their target
   when first scrolled into view. Uses easeOutCubic for a smooth
   settle. Honors prefers-reduced-motion (sets the final value
   directly without animating).
   ============================================================ */
(function(){
  'use strict';
  var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  function format(value, decimals, prefix, suffix){
    if (decimals > 0) {
      return prefix + value.toFixed(decimals) + suffix;
    }
    return prefix + Math.floor(value).toLocaleString('en-US') + suffix;
  }
  function animateCount(el){
    var target   = parseFloat(el.dataset.count);
    var decimals = parseInt(el.dataset.decimals || '0', 10);
    var prefix   = el.dataset.prefix || '';
    var suffix   = el.dataset.suffix || '';
    if (isNaN(target)) return;
    if (reduce) { el.textContent = format(target, decimals, prefix, suffix); return; }

    var duration = 1500;
    var start = performance.now();
    function tick(now){
      var p = Math.min(1, (now - start) / duration);
      var eased = 1 - Math.pow(1 - p, 3); /* easeOutCubic */
      el.textContent = format(target * eased, decimals, prefix, suffix);
      if (p < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  if (!('IntersectionObserver' in window)) {
    document.querySelectorAll('[data-count]').forEach(animateCount);
    return;
  }
  var observer = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting){
        animateCount(e.target);
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.4 });
  document.querySelectorAll('[data-count]').forEach(function(el){ observer.observe(el); });
})();

/* ============================================================
   Scroll reveal, fades + rises elements as they enter the
   viewport. Auto-staggers siblings within grid containers.
   ============================================================ */
(function(){
  'use strict';
  if (!('IntersectionObserver' in window)) return;
  if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  /* Targets: every card/stat that should reveal on scroll. */
  var selectors = [
    '.h-card',
    '.trust__stat',
    '.calc-card',
    '.tile__head'
  ];
  var nodes = document.querySelectorAll(selectors.join(','));

  nodes.forEach(function(node){
    node.classList.add('reveal');
    /* Stagger siblings that share a parent grid/row */
    var parent = node.parentElement;
    if (!parent) return;
    var siblings = Array.prototype.filter.call(parent.children, function(c){
      return c.matches && c.matches(selectors.join(','));
    });
    var idx = siblings.indexOf(node);
    if (idx >= 0 && idx < 6) node.classList.add('is-stagger-' + (idx + 1));
  });

  var observer = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting){
        e.target.classList.add('is-visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });

  document.querySelectorAll('.reveal').forEach(function(el){ observer.observe(el); });
})();

/* ============================================================
   Testimonial slider, auto-rotates every 6s, dot click jumps,
   hover pauses, respects prefers-reduced-motion (no auto-rotate).
   ============================================================ */
(function(){
  'use strict';
  var stage = document.querySelector('[data-testimonials]');
  if (!stage) return;
  var slides = stage.querySelectorAll('.testimonial');
  var dots = stage.querySelectorAll('.testimonials__dots button');
  if (!slides.length) return;
  var idx = 0;
  var timer;
  var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  function go(i){
    idx = (i + slides.length) % slides.length;
    slides.forEach(function(s, j){ s.classList.toggle('testimonial--active', j === idx); });
    dots.forEach(function(d, j){ d.classList.toggle('active', j === idx); });
  }
  function advance(){ go(idx + 1); }
  function play(){ if (!reduce) timer = setInterval(advance, 6000); }
  function pause(){ clearInterval(timer); }

  dots.forEach(function(d, i){
    d.addEventListener('click', function(){ go(i); pause(); play(); });
  });
  stage.addEventListener('mouseenter', pause);
  stage.addEventListener('mouseleave', play);
  play();
})();

/* ============================================================
   Scheduling & Queueing mockup, cursor moves to an empty slot,
   tooltip appears with patient details, slot fills matcha, and a
   new queue entry slides in from the top. ~12-second loop.
   ============================================================ */
(function () {
  'use strict';
  var host = document.getElementById('schedHost');
  var inner = document.getElementById('schedFrame');
  if (!host || !inner) return;

  function fit() {
    var r = host.getBoundingClientRect();
    var s = Math.min(r.width / 1192, r.height / 656);
    if (s > 0) inner.style.transform = 'translate(-50%,-50%) scale(' + s + ')';
  }
  window.addEventListener('resize', fit);
  requestAnimationFrame(function () { requestAnimationFrame(fit); });
  window.addEventListener('load', fit);

  function $(id) { return document.getElementById(id); }
  var TOTAL = 9000;
  var SEQ = {
    cursorToSlot: { at: 400,  dur: 1600 },
    slotHover:    { at: 2000 },
    clickSlot:    { at: 3300 },
    slotBooked:   { at: 3400 },
    zoomIn:       { at: 3700 },     /* grid zooms in on the booked slot */
    advanceToIntake: { at: 5200 },  /* click → intake transition trigger */
    reset:        { at: 7500 }
  };

  function moveCursor(target, dur) {
    dur = dur || 800;
    var cur = $('schCursor');
    var fr = inner.getBoundingClientRect();
    var r = target.getBoundingClientRect();
    var m = new DOMMatrixReadOnly(getComputedStyle(inner).transform);
    var sx = m.a, sy = m.d;
    var fx = (r.left - fr.left) / sx + r.width / sx / 2 - 6;
    var fy = (r.top - fr.top) / sy + r.height / sy / 2 - 4;
    cur.style.transition = 'transform ' + dur + 'ms cubic-bezier(.5,.05,.2,1)';
    cur.style.transform = 'translate(' + fx + 'px,' + fy + 'px)';
  }
  function moveInstant(x, y) {
    var c = $('schCursor');
    c.style.transition = 'none';
    c.style.transform = 'translate(' + x + 'px,' + y + 'px)';
  }
  function ripple() {
    var r = $('schRipple');
    r.classList.remove('go');
    void r.offsetWidth;
    r.classList.add('go');
  }

  var step = -1;
  var clicked = {};
  var wasHidden = true;
  var startTime = 0;

  var advanced = false;

  function reset(now) {
    step = 0;
    clicked = {};
    advanced = false;
    window.__schedZoomed = false;
    startTime = now || performance.now();
    var slot = $('schTargetSlot');
    if (slot) slot.classList.remove('is-hover', 'is-booked');
    var card = host.querySelector('.sched-grid-card');
    if (card) card.classList.remove('is-zooming');
    host.classList.remove('is-zooming');
    var cur = $('schCursor');
    if (cur) { cur.style.transition = ''; cur.style.opacity = '1'; }
    moveInstant(80, 580);
  }

  function tick(now) {
    /* Pane is display:none on inactive tabs, host has zero dimensions
       and DOMMatrixReadOnly would throw parsing 'none'. Skip until the
       host is visible (Scheduling tab is active). */
    var rect = host.getBoundingClientRect();
    if (rect.width === 0) {
      wasHidden = true;
      requestAnimationFrame(tick);
      return;
    }

    if (wasHidden) {
      wasHidden = false;
      reset(now);
    }

    var t = (now - startTime) % TOTAL;
    if (t < 0) t = 0;

    if (t < 200 && step !== 0) reset(now);

    if (t >= SEQ.cursorToSlot.at && step === 0) {
      moveCursor($('schTargetSlot'), SEQ.cursorToSlot.dur);
      step = 1;
    }
    if (t >= SEQ.slotHover.at && step === 1) {
      $('schTargetSlot').classList.add('is-hover');
      step = 2;
    }
    if (t >= SEQ.clickSlot.at && !clicked.slot) {
      clicked.slot = true;
      ripple();
    }
    if (t >= SEQ.slotBooked.at && step === 2) {
      var slot = $('schTargetSlot');
      slot.classList.remove('is-hover');
      slot.classList.add('is-booked');
      step = 3;
    }
    /* Zoom-in: pin transform-origin to the booked slot's center, then
       add the .is-zooming class so the CSS transition kicks in. Cursor
       fades as part of the same beat. */
    if (t >= SEQ.zoomIn.at && step === 3 && !window.__schedZoomed) {
      window.__schedZoomed = true;
      var card = host.querySelector('.sched-grid-card');
      var s = $('schTargetSlot');
      if (card && s) {
        var cRect = card.getBoundingClientRect();
        var sRect = s.getBoundingClientRect();
        if (cRect.width > 0) {
          var ox = ((sRect.left + sRect.width / 2) - cRect.left) / cRect.width * 100;
          var oy = ((sRect.top + sRect.height / 2) - cRect.top) / cRect.height * 100;
          card.style.setProperty('--zoom-x', ox + '%');
          card.style.setProperty('--zoom-y', oy + '%');
          card.classList.add('is-zooming');
          host.classList.add('is-zooming');
        }
      }
    }
    /* Click → intake transition: ~1.5s after the zoom begins, ask the
       rotation system to advance. The pane fades to Intake. */
    if (t >= SEQ.advanceToIntake.at && step === 3 && !advanced) {
      advanced = true;
      if (typeof window.heroAdvance === 'function') {
        window.heroAdvance();
      }
    }
    if (t >= SEQ.reset.at && step === 3) {
      var s2 = $('schTargetSlot');
      if (s2) s2.classList.remove('is-booked');
      var card2 = host.querySelector('.sched-grid-card');
      if (card2) card2.classList.remove('is-zooming');
      host.classList.remove('is-zooming');
      window.__schedZoomed = false;
      step = 4;
    }

    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
})();

/* ============================================================
   Patient Intake motion graphic
   - Types into 7 form fields one at a time
   - Progress bar segment between step 2 (current) and step 3
     fills proportional to typed characters
   - Cursor clicks Continue → step 2 fills, step 3 activates
   - Right-side vertical step list updates too
   - 14-second loop
   ============================================================ */
(function () {
  'use strict';
  var host = document.getElementById('intakeHost');
  var inner = document.getElementById('intakeFrame');
  if (!host || !inner) return;

  function fit() {
    var r = host.getBoundingClientRect();
    var s = Math.min(r.width / 1192, r.height / 656);
    if (s > 0) inner.style.transform = 'translate(-50%,-50%) scale(' + s + ')';
  }
  window.addEventListener('resize', fit);
  requestAnimationFrame(function () { requestAnimationFrame(fit); });
  window.addEventListener('load', fit);

  function $(id) { return document.getElementById(id); }

  /* Abstract placeholder data, conceptual intake, not a real patient.
     "Sophia Ramirez" matches the patient name used in the AI Clinical
     Assistant mockup for narrative continuity across the workflow. */
  var FIELDS = [
    { id: 'fldFirstName', text: 'Sophia Ramirez' },
    { id: 'fldDOB',       text: '1985-04-12' },
    { id: 'fldPhone',     text: '555-555-0100' }
  ];
  /* Field-by-field reveal, replaced the slow char-by-char typing with a
     punchier sequential animation where each field auto-fills + gets a
     brief matcha highlight pulse, then transitions to the CTA pulse,
     then heroAdvance() back to Scheduling. */
  var TOTAL       = 7500;
  var FIELD_REVEAL_AT = [500, 1100, 1700];   /* when each field auto-fills */
  var CTA_PULSE_AT    = 2900;                /* CTA button pulses */
  var ADVANCE_AT      = 4200;                /* heroAdvance back to Scheduling */
  var RESET_AT        = 6800;                /* fade out before loop restart */

  var revealed = [];
  var ctaPulsed = false;
  var advanced = false;
  var wasHidden = true;
  var startTime = 0;

  function reset(now) {
    revealed = [false, false, false];
    ctaPulsed = false;
    advanced = false;
    startTime = now || performance.now();
    FIELDS.forEach(function (f) {
      var fld = $(f.id);
      if (!fld) return;
      fld.classList.remove('is-typing', 'is-filling', 'is-filled');
      var v = fld.querySelector('.intake-field-value');
      if (v) v.textContent = '';
    });
    var cta = $('intakeCta');
    if (cta) cta.classList.remove('is-pulsing');
    var popup = $('intakePopup');
    if (popup) popup.classList.remove('is-visible');
  }

  function fillField(idx) {
    var f = FIELDS[idx];
    if (!f) return;
    var fld = $(f.id);
    if (!fld) return;
    var v = fld.querySelector('.intake-field-value');
    if (v) v.textContent = f.text;
    fld.classList.add('is-filling');
    /* Filling glow lasts 600ms, then settles to filled state. */
    setTimeout(function () {
      fld.classList.remove('is-filling');
      fld.classList.add('is-filled');
    }, 600);
  }

  function pulseCta() {
    var cta = $('intakeCta');
    if (!cta) return;
    cta.classList.add('is-pulsing');
    /* Pop the confirmation popup ~250ms after the CTA pulse begins so
       the eye registers the click first, then the result. */
    setTimeout(function () {
      var popup = $('intakePopup');
      if (popup) popup.classList.add('is-visible');
    }, 250);
  }

  function tick(now) {
    var rect = host.getBoundingClientRect();
    if (rect.width === 0) {
      wasHidden = true;
      requestAnimationFrame(tick);
      return;
    }
    if (wasHidden) {
      wasHidden = false;
      reset(now);
    }
    var t = (now - startTime) % TOTAL;
    if (t < 0) t = 0;
    if (t < 100 && (revealed[0] || revealed[1] || revealed[2])) reset(now);

    /* Reveal each field once when its scheduled time passes. */
    for (var i = 0; i < FIELD_REVEAL_AT.length; i++) {
      if (t >= FIELD_REVEAL_AT[i] && !revealed[i]) {
        revealed[i] = true;
        fillField(i);
      }
    }

    if (t >= CTA_PULSE_AT && !ctaPulsed) {
      ctaPulsed = true;
      pulseCta();
    }

    if (t >= ADVANCE_AT && !advanced) {
      advanced = true;
      if (typeof window.heroAdvance === 'function') {
        window.heroAdvance();
      }
    }

    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
})();

/* ============================================================
   Messaging & Follow-Ups motion graphic
   - 3 phone screens visible side-by-side
   - Phone 2 (SMS) animates: typing indicator → bubble 1 → typing → bubble 2 → reset
   - ~10s loop
   ============================================================ */
(function () {
  'use strict';
  var host = document.getElementById('msgHost');
  var inner = document.getElementById('msgFrame');
  if (!host || !inner) return;

  function fit() {
    var r = host.getBoundingClientRect();
    var s = Math.min(r.width / 1192, r.height / 656);
    if (s > 0) inner.style.transform = 'translate(-50%,-50%) scale(' + s + ')';
  }
  window.addEventListener('resize', fit);
  requestAnimationFrame(function () { requestAnimationFrame(fit); });
  window.addEventListener('load', fit);

  function $(id) { return document.getElementById(id); }

  var TOTAL = 10000;
  var SEQ = {
    typing1On:  500,
    typing1Off: 1700,
    bubble1On:  1800,
    typing2On:  3700,
    typing2Off: 4900,
    bubble2On:  5000,
    reset:      9000
  };

  var step = -1;
  var wasHidden = true;
  var startTime = 0;

  function reset(now) {
    step = 0;
    startTime = now || performance.now();
    var b1 = $('msgBubble1'); if (b1) b1.classList.remove('is-on');
    var b2 = $('msgBubble2'); if (b2) b2.classList.remove('is-on');
    var ty = $('msgTyping');  if (ty) ty.classList.remove('is-on');
  }

  function tick(now) {
    var rect = host.getBoundingClientRect();
    if (rect.width === 0) {
      wasHidden = true;
      requestAnimationFrame(tick);
      return;
    }
    if (wasHidden) {
      wasHidden = false;
      reset(now);
    }
    var t = (now - startTime) % TOTAL;
    if (t < 0) t = 0;
    if (t < 200 && step !== 0) reset(now);

    if (t >= SEQ.typing1On  && step === 0) { $('msgTyping').classList.add('is-on');    step = 1; }
    if (t >= SEQ.typing1Off && step === 1) { $('msgTyping').classList.remove('is-on'); step = 2; }
    if (t >= SEQ.bubble1On  && step === 2) { $('msgBubble1').classList.add('is-on');   step = 3; }
    if (t >= SEQ.typing2On  && step === 3) { $('msgTyping').classList.add('is-on');    step = 4; }
    if (t >= SEQ.typing2Off && step === 4) { $('msgTyping').classList.remove('is-on'); step = 5; }
    if (t >= SEQ.bubble2On  && step === 5) { $('msgBubble2').classList.add('is-on');   step = 6; }
    if (t >= SEQ.reset      && step === 6) {
      $('msgBubble1').classList.remove('is-on');
      $('msgBubble2').classList.remove('is-on');
      step = 7;
    }

    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
})();

/* ============================================================
   Product mockup tabs, swap which mockup-pane is visible.
   Scribe pane re-runs fitMockup() on activation so the inner
   1192×656 frame scales correctly after being display:none.
   ============================================================ */
(function(){
  'use strict';
  // Full 4-pane rotation (Messaging excluded entirely, not part of the
  // schedule → intake → consult → billing → paid workflow narrative).
  var tabs = document.querySelectorAll(
    '.tab[data-tab="scheduling"], .tab[data-tab="intake"], ' +
    '.tab[data-tab="documentation"], .tab[data-tab="billing"]'
  );
  var panes = document.querySelectorAll('.mockup-pane[data-pane]');

  function doSwap(key){
    tabs.forEach(function(t){
      var on = t.getAttribute('data-tab') === key;
      t.classList.toggle('tab--active', on);
      t.setAttribute('aria-selected', on ? 'true' : 'false');
    });

    panes.forEach(function(p){
      p.classList.toggle('mockup-pane--active', p.getAttribute('data-pane') === key);
    });

    /* Re-fit motion-graphic mockups when their pane becomes active.
       While display:none the host had zero dimensions and the inner
       1192×656 frame's scale collapsed. We run the resize SYNCHRONOUSLY
       on the same frame as the class toggle so the new pane lands
       pre-scaled and the user never sees a mid-animation pop. The
       second rAF is a safety net for layout that hasn't settled. */
    function refit(hostId, innerId) {
      var hostEl = document.getElementById(hostId);
      var inner = document.getElementById(innerId);
      if (!hostEl || !inner) return;
      function apply() {
        var r = hostEl.getBoundingClientRect();
        var s = Math.min(r.width / 1192, r.height / 656);
        if (s > 0) inner.style.transform = 'translate(-50%,-50%) scale(' + s + ')';
      }
      apply();
      requestAnimationFrame(apply);
    }
    if (key === 'documentation') refit('mockupHost', 'frame');
    if (key === 'scheduling')    refit('schedHost', 'schedFrame');
    if (key === 'intake')        refit('intakeHost', 'intakeFrame');
    /* billing data-pane was repurposed for the Follow-Ups + Mass
       Comms phone stack on the CA hero; its host + frame ids are
       msgHost and msgFrame, so refit it via those. */
    if (key === 'billing')       refit('msgHost', 'msgFrame');

    /* Global workflow indicator, mark stages as done/active/pending
       based on the active pane's position in the workflow. The 5th
       stage "Get Paid" doesn't have a pane; its active state is set
       by the Billing animation when the popup fires. activate() here
       resets it whenever any pane (other than billing) takes focus. */
    var WF_ORDER = ['scheduling', 'intake', 'documentation', 'billing'];
    var activeIdx = WF_ORDER.indexOf(key);
    if (activeIdx === -1) return;
    var stages = document.querySelectorAll('.hw-stage');
    var arrows = document.querySelectorAll('.hw-arrow');
    stages.forEach(function(stage, i){
      /* Skip the Get Paid stage, its state is managed by the billing
         animation, not by which pane is active. */
      if (stage.getAttribute('data-pane-key') === 'paid') {
        /* When leaving billing for any earlier pane, clear paid state. */
        if (key !== 'billing') stage.classList.remove('is-active', 'is-done');
        return;
      }
      stage.classList.toggle('is-active', i === activeIdx);
      stage.classList.toggle('is-done',   i <  activeIdx);
    });
    arrows.forEach(function(arrow, i){
      /* The last arrow (data-arrow="paid") gets its fill from billing's
         tick(). activate() just resets it when leaving billing. */
      if (arrow.getAttribute('data-arrow') === 'paid') {
        if (key !== 'billing') arrow.style.setProperty('--bill-progress', '0%');
        return;
      }
      arrow.classList.toggle('is-traveled', i < activeIdx);
    });
  }

  /* Directional push transition. Determine workflow direction from the
     pane order, set [data-push-direction] on .visual-wrap so CSS picks
     the right keyframes, mark the outgoing pane as .is-leaving (becomes
     an absolute overlay that slides off + scales down), then doSwap()
     activates the new pane which slides in from the opposite side. */
  /* Must match the longer of the two pane animations (.6s in / .6s out).
     +50ms safety margin guarantees the .is-leaving overlay is removed
     after its fade-out keyframe has fully painted. */
  var PUSH_MS = 650;
  var WF_ORDER = ['scheduling', 'intake', 'documentation', 'billing'];
  function activate(key) {
    var visualWrap = document.querySelector('.visual-wrap');
    var prevActive = document.querySelector('.mockup-pane--active');
    var prevKey = prevActive ? prevActive.getAttribute('data-pane') : null;

    if (!prevActive || prevKey === key) {
      doSwap(key);
      return;
    }

    /* Set direction so CSS uses the right in/out keyframes. */
    var fromIdx = WF_ORDER.indexOf(prevKey);
    var toIdx   = WF_ORDER.indexOf(key);
    var direction = (toIdx > fromIdx || toIdx === -1) ? 'forward' : 'backward';
    if (visualWrap) visualWrap.setAttribute('data-push-direction', direction);

    /* Clear any stale .is-leaving (rapid back-to-back transitions). */
    panes.forEach(function(p){ p.classList.remove('is-leaving'); });

    /* Mark outgoing pane as leaving BEFORE doSwap so it keeps display:block
       via the .is-leaving rule even after losing .mockup-pane--active. */
    prevActive.classList.add('is-leaving');

    doSwap(key);

    setTimeout(function(){
      prevActive.classList.remove('is-leaving');
    }, PUSH_MS);
  }

  /* ----------------------------------------------------------
     Auto-rotate tabs every 10 seconds, with a matcha progress
     bar that fills under the active tab.
     - Only runs while the tab bar is in the viewport.
     - Pauses when the browser tab is hidden.
     - Stops permanently once the user clicks a tab.
     ---------------------------------------------------------- */
  /* Rotation unlocked 2026-05-26, full 4-pane cycle:
     Scheduling → Patient Intake → Consult Complete (Documentation) →
     Follow-Ups & Mass Comms → back to Scheduling. */
  var ROTATE_ENABLED = true;

  var ROTATE_MS    = 10000;
  var rotateTimer  = null;
  var userTouched  = false;
  var inView       = false;
  var tabBar       = document.querySelector('.tab-bar');

  function activeIdx() {
    for (var i = 0; i < tabs.length; i++) {
      if (tabs[i].classList.contains('tab--active')) return i;
    }
    return 0;
  }
  function advance() {
    if (userTouched || !inView || document.hidden) return;
    var next = (activeIdx() + 1) % tabs.length;
    activate(tabs[next].getAttribute('data-tab'));
    /* Restart the CSS progress animation on the new active tab.
       The animation runs on .tab--active::after and is keyed to the
       same 10s as ROTATE_MS, so the bar reaches 100% just as the
       next interval fires. Forcing reflow guarantees a clean restart
       even when the same tab key is somehow re-activated. */
    if (tabBar) {
      tabBar.classList.remove('is-rotating');
      void tabBar.offsetWidth;
      tabBar.classList.add('is-rotating');
    }
  }
  function startRotation() {
    if (!ROTATE_ENABLED) return;
    if (rotateTimer || userTouched) return;
    if (tabBar) tabBar.classList.add('is-rotating');
    rotateTimer = setInterval(advance, ROTATE_MS);
  }
  function stopRotation() {
    if (rotateTimer) { clearInterval(rotateTimer); rotateTimer = null; }
    if (tabBar) tabBar.classList.remove('is-rotating');
  }

  /* Public hook: per-pane animations can call this to advance to the next
     pane "early" (e.g. Scheduling fires this when the user-cursor clicks
     a slot, transitioning to Intake immediately rather than waiting for
     the 10s rotation tick). Resets the rotation timer so the new pane
     gets its full 10s window. */
  window.heroAdvance = function () {
    if (!ROTATE_ENABLED) return;
    if (userTouched || !inView) return;
    if (rotateTimer) { clearInterval(rotateTimer); rotateTimer = null; }
    advance();
    if (inView && !userTouched) {
      rotateTimer = setInterval(advance, ROTATE_MS);
    }
  };

  /* Observe the visible mockup frame (tab bar is now display:none, so
     observing it would never report intersecting). Falls back to the
     tab bar if visual-wrap isn't present. */
  var observerTarget = document.querySelector('.visual-wrap') || tabBar;
  if (observerTarget && 'IntersectionObserver' in window) {
    new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        inView = e.isIntersecting;
        if (inView && !userTouched) startRotation();
        else stopRotation();
      });
    }, { threshold: 0.3 }).observe(observerTarget);
  } else {
    inView = true;
    startRotation();
  }

  document.addEventListener('visibilitychange', function () {
    if (document.hidden) stopRotation();
    else if (inView && !userTouched) startRotation();
  });

  /* Manual click: stop rotation, activate the chosen tab. The active
     tab keeps its full-width matcha underline (no animation), so the
     bar remains a clean static indicator after user interaction. */
  tabs.forEach(function (t) {
    t.addEventListener('click', function () {
      userTouched = true;
      stopRotation();
      activate(t.getAttribute('data-tab'));
    });
  });

  /* Workflow-indicator labels are ALSO clickable, giving the section
     slideshow-style navigation. The "paid" stage is a visual finale
     with no corresponding pane, so we skip it. Default behavior is
     unchanged (rotation starts on Scheduling); clicking pauses the
     rotation just like the hidden tab bar does. */
  var clickableStages = document.querySelectorAll('.hw-stage[data-pane-key]');
  clickableStages.forEach(function (s) {
    var key = s.getAttribute('data-pane-key');
    if (key === 'paid') return;
    s.classList.add('is-clickable');
    s.setAttribute('role', 'button');
    s.setAttribute('tabindex', '0');
    s.setAttribute('aria-label', 'Show ' + (s.querySelector('.hw-label') ? s.querySelector('.hw-label').textContent : key) + ' animation');
    s.addEventListener('click', function () {
      userTouched = true;
      stopRotation();
      activate(key);
    });
    s.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        s.click();
      }
    });
  });
})();

/* ============================================================
   Reimbursement calculator, live update on input change
   ============================================================ */
(function(){
  'use strict';
  document.querySelectorAll('[data-calc-widget]').forEach(function(widget){
    var stores = widget.querySelector('[data-calc-stores]');
    var enc    = widget.querySelector('[data-calc-encounters]');
    var out    = widget.querySelector('[data-calc-result]');
    if (!stores || !enc || !out) return;

    var AVG_PER_ENC = 74;
    var WEEKS = 50;
    var CAPTURE = 0.78;

    function recalc(){
      var s = Math.max(0, parseInt(stores.value, 10) || 0);
      var e = Math.max(0, parseInt(enc.value, 10) || 0);
      var unlock = Math.round(s * e * WEEKS * AVG_PER_ENC * CAPTURE);
      out.textContent = '$' + unlock.toLocaleString('en-US');
    }
    stores.addEventListener('input', recalc);
    enc.addEventListener('input', recalc);
    recalc();
  });
})();`}></script>

---
import BaseLayout from '../../../layouts/BaseLayoutCa.astro';
---
<BaseLayout
  title="White Papers, MedMe Health"
  description="Research and policy briefs for Canadian pharmacy operators. Provincial scope of practice, clinical-service economics, PANS pilot outcomes, and the case studies behind them."
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/resources/white-papers" />
  </Fragment>

<style>

  /* ============================================================
     WHITE PAPERS page. Same template as the blog/events/webinars
     pages. Each card is a single paper with a "cover" gradient
     visual that has the paper title typeset over it like the
     front of a printed brief.
     ============================================================ */

  /* ====== HERO ================================================ */
  .sub-hero {
    background: var(--seashell);
    padding: 3.5rem 1.5rem 3rem;
    position: relative;
    overflow: hidden;
  }
  .sub-hero__inner {
    max-width: var(--container);
    margin: 0 auto;
    padding-inline: var(--tile-pad-x);
  }
  .sub-hero__text { text-align: center; max-width: 820px; margin: 0 auto; }
  .sub-hero h1.h-display {
    font-size: clamp(28px, 4.4vw, 54px);
    line-height: 1.08;
    letter-spacing: -0.028em;
    margin: 0.75rem auto 1rem;
    text-align: center;
    text-wrap: balance;
  }
  .sub-hero__lede {
    font-size: 1.1rem;
    line-height: 1.55;
    color: rgba(6, 62, 84, 0.72);
    margin: 0 auto;
    max-width: 660px;
    text-wrap: pretty;
  }
  .sub-hero__breadcrumb {
    font-size: 13px;
    color: rgba(6, 62, 84, 0.55);
    margin-bottom: 1.25rem;
    text-align: center;
  }
  .sub-hero__breadcrumb a { color: rgba(6, 62, 84, 0.55); text-decoration: none; }
  .sub-hero__breadcrumb a:hover { color: var(--indigo); }
  .sub-hero__breadcrumb .sep { margin: 0 0.5rem; opacity: 0.4; }

  /* ====== FILTER ============================================== */
  .bl-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin: 0 0 2rem;
  }
  .bl-filter__pill {
    background: var(--white);
    border: 1.5px solid rgba(6, 62, 84, 0.12);
    color: var(--indigo);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.85rem;
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease;
    line-height: 1.2;
  }
  .bl-filter__pill:hover {
    border-color: var(--matcha);
    background: rgba(195, 196, 48, 0.08);
  }
  .bl-filter__pill.is-active {
    background: var(--matcha);
    border-color: var(--matcha);
    color: var(--indigo);
  }
  .bl-filter__pill:focus-visible {
    outline: 2px solid var(--matcha);
    outline-offset: 3px;
  }
  .bl-card.is-hidden { display: none; }

  /* ====== WHITE PAPER CARDS =================================== */
  .bl-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }
  @media (max-width: 1000px) { .bl-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .bl-grid { grid-template-columns: 1fr; } }

  .bl-card {
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .bl-card:hover {
    transform: translateY(-3px);
    border-color: rgba(6, 62, 84, 0.18);
    box-shadow: 0 16px 40px rgba(6, 62, 84, 0.08);
  }

  /* Paper "cover" gradient with the paper title set inside. */
  .bl-card__media {
    aspect-ratio: 16 / 10;
    width: 100%;
    background: linear-gradient(135deg, var(--indigo) 0%, rgba(6, 62, 84, 0.78) 100%);
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: flex-end;
    padding: 1.25rem;
    text-decoration: none;
    color: var(--seashell);
  }
  .bl-card__media--matcha {
    background: linear-gradient(135deg, rgba(195, 196, 48, 0.95) 0%, rgba(195, 196, 48, 0.55) 100%);
    color: var(--indigo);
  }
  .bl-card__media--seashell {
    background: linear-gradient(135deg, rgba(195, 196, 48, 0.22) 0%, rgba(6, 62, 84, 0.12) 100%);
    color: var(--indigo);
  }
  .bl-card__media::after {
    /* subtle paper-fold sheen running across the cover */
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 0%, transparent 55%, rgba(250, 249, 245, 0.06) 60%, transparent 70%);
    pointer-events: none;
  }
  .bl-card__cover-title {
    position: relative;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    line-height: 1.15;
    letter-spacing: -0.012em;
    z-index: 1;
    max-width: 86%;
    text-wrap: balance;
  }
  .bl-card__cover-band {
    position: absolute;
    left: 1.25rem;
    top: 1.25rem;
    background: var(--matcha);
    color: var(--indigo);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 10px;
    padding: 4px 10px;
    border-radius: 999px;
    letter-spacing: 0.06em;
  }
  .bl-card__media--matcha .bl-card__cover-band {
    background: var(--indigo);
    color: var(--matcha);
  }
  .bl-card__media--seashell .bl-card__cover-band {
    background: var(--matcha);
    color: var(--indigo);
  }

  .bl-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.75rem;
  }
  .bl-card__tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(195, 196, 48, 0.16);
    color: var(--indigo);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 999px;
    align-self: flex-start;
    letter-spacing: 0.02em;
  }
  .bl-card__tag::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--matcha);
  }
  .bl-card h3 {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--indigo);
    letter-spacing: -0.014em;
    line-height: 1.25;
    text-wrap: balance;
  }
  .bl-card__meta {
    font-size: 0.82rem;
    color: rgba(6, 62, 84, 0.6);
    line-height: 1.4;
  }
  .bl-card__lede {
    margin: 0;
    font-size: 0.92rem;
    color: rgba(6, 62, 84, 0.72);
    line-height: 1.55;
    flex: 1;
  }
  .bl-card__cta { margin-top: auto; padding-top: 0.75rem; }
  .bl-card__cta a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--matcha);
    color: var(--indigo);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.88rem;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    text-decoration: none;
    border: 1.5px solid var(--matcha);
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }
  .bl-card__cta a:hover {
    background: transparent;
    color: var(--indigo);
    transform: translateX(2px);
  }
  .bl-card__cta a .arrow { transition: transform 0.18s ease; }
  .bl-card__cta a:hover .arrow { transform: translateX(2px); }
</style>

<!-- ============= 1. SUB-HERO ============= -->
<section class="sub-hero" aria-label="Hero">
  <div class="sub-hero__inner">
    <div class="sub-hero__text">
      <div class="sub-hero__breadcrumb">
        <a href="/us">Home</a><span class="sep">/</span><a href="/ca/resources">Resources</a><span class="sep">/</span><span>White Papers</span>
      </div>
      <span class="kicker kicker--matcha">White Papers</span>
      <h1 class="h-display">Research and policy briefs<br>for pharmacy operators.</h1>
      <p class="sub-hero__lede">Written for the operator on the floor, not the policy wonk. Provincial scope of practice, clinical-service economics, PANS pilot outcomes, and the case studies behind them.</p>
    </div>
  </div>
</section>

<!-- ============= 2. WHITE PAPER GRID ============= -->
<section class="tile tile--light" aria-label="White papers">
  <div class="tile__inner">
    <div class="bl-filter" role="group" aria-label="Filter white papers">
      <button type="button" class="bl-filter__pill is-active" data-filter="all" aria-pressed="true">All</button>
      <button type="button" class="bl-filter__pill" data-filter="policy" aria-pressed="false">Policy</button>
      <button type="button" class="bl-filter__pill" data-filter="benchmark" aria-pressed="false">Benchmark</button>
      <button type="button" class="bl-filter__pill" data-filter="case-study" aria-pressed="false">Case Study</button>
      <button type="button" class="bl-filter__pill" data-filter="operator-guide" aria-pressed="false">Operator Guide</button>
    </div>

    <div class="bl-grid">

      <article class="bl-card" data-tag="policy">
        <a class="bl-card__media" href="/ca/contact" aria-hidden="true" tabindex="-1">
          <span class="bl-card__cover-band">Policy Brief</span>
          <p class="bl-card__cover-title">The pharmacist's guide to National Pharmacare.</p>
        </a>
        <div class="bl-card__body">
          <span class="bl-card__tag">Policy</span>
          <h3>The pharmacist's guide to Canada's National Pharmacare Act</h3>
          <p class="bl-card__meta">28 pages &middot; 14 min read &middot; Updated May 2026</p>
          <p class="bl-card__lede">Where the National Pharmacare Act sits, what the first listed therapeutic classes mean for community pharmacy operations, and the 90-day operator readiness checklist.</p>
          <div class="bl-card__cta">
            <a href="/ca/contact">Download <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </article>

      <article class="bl-card" data-tag="policy">
        <a class="bl-card__media bl-card__media--matcha" href="/ca/contact" aria-hidden="true" tabindex="-1">
          <span class="bl-card__cover-band">Policy Brief</span>
          <p class="bl-card__cover-title">Province-by-province pharmacy scope of practice.</p>
        </a>
        <div class="bl-card__body">
          <span class="bl-card__tag">Policy</span>
          <h3>Province-by-province pharmacy scope of practice: 2026 edition</h3>
          <p class="bl-card__meta">42 pages &middot; 22 min read &middot; Updated Apr 2026</p>
          <p class="bl-card__lede">A live tracker of provincial pharmacy scope-of-practice authority and provincial billing pathways. Covers all 10 provinces and 3 territories, with specific notes on protocols, fees, and prescribing authority.</p>
          <div class="bl-card__cta">
            <a href="/ca/contact">Download <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </article>

      <article class="bl-card" data-tag="policy">
        <a class="bl-card__media bl-card__media--seashell" href="/ca/contact" aria-hidden="true" tabindex="-1">
          <span class="bl-card__cover-band">Policy Brief</span>
          <p class="bl-card__cover-title">Pharmacist prescribing: 2026 provincial outlook.</p>
        </a>
        <div class="bl-card__body">
          <span class="bl-card__tag">Policy</span>
          <h3>Pharmacist prescribing authority: 2026 provincial outlook</h3>
          <p class="bl-card__meta">18 pages &middot; 9 min read &middot; Updated Mar 2026</p>
          <p class="bl-card__lede">Where each province sits on pharmacist prescribing authority, minor ailments scope, and lab-test ordering. Snapshot by province, plus the operator-level moves to make regardless of how policy moves.</p>
          <div class="bl-card__cta">
            <a href="/ca/contact">Download <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </article>

      <article class="bl-card" data-tag="benchmark">
        <a class="bl-card__media bl-card__media--matcha" href="/ca/contact" aria-hidden="true" tabindex="-1">
          <span class="bl-card__cover-band">Benchmark</span>
          <p class="bl-card__cover-title">2026 pharmacy clinical-service economics.</p>
        </a>
        <div class="bl-card__body">
          <span class="bl-card__tag">Benchmark</span>
          <h3>2026 community pharmacy clinical-service economics</h3>
          <p class="bl-card__meta">32 pages &middot; 16 min read &middot; Published Feb 2026</p>
          <p class="bl-card__lede">Provincial drug plan, private benefits, and cash-pay fee benchmarks by store size, region, and service line. Useful for comparing your network's posture against the field.</p>
          <div class="bl-card__cta">
            <a href="/ca/contact">Download <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </article>

      <article class="bl-card" data-tag="benchmark">
        <a class="bl-card__media" href="/ca/contact" aria-hidden="true" tabindex="-1">
          <span class="bl-card__cover-band">Benchmark</span>
          <p class="bl-card__cover-title">Provincial claim-rejection benchmarks.</p>
        </a>
        <div class="bl-card__body">
          <span class="bl-card__tag">Benchmark</span>
          <h3>Provincial claim-rejection benchmarks by service and plan</h3>
          <p class="bl-card__meta">24 pages &middot; 12 min read &middot; Published Jan 2026</p>
          <p class="bl-card__lede">Median, 90th-percentile, and best-in-class rejection rates for the highest-volume clinical-service codes across provincial plans. Where the field is, where the leaders are, and what they do differently.</p>
          <div class="bl-card__cta">
            <a href="/ca/contact">Download <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </article>

      <article class="bl-card" data-tag="case-study">
        <a class="bl-card__media" href="/ca/customers/heritage-rx" aria-hidden="true" tabindex="-1">
          <span class="bl-card__cover-band">Case Study</span>
          <p class="bl-card__cover-title">Heritage Rx: $1.4M in year one.</p>
        </a>
        <div class="bl-card__body">
          <span class="bl-card__tag">Case Study</span>
          <h3>Heritage Rx: a year-one operator postmortem</h3>
          <p class="bl-card__meta">14 pages &middot; 8 min read &middot; Published Feb 2026</p>
          <p class="bl-card__lede">An 8-store Atlantic Canada independent unlocked $1.4M in clinical-service revenue in its first 12 months on MedMe. The rollout playbook, the staffing model, and the five things they would change.</p>
          <div class="bl-card__cta">
            <a href="/ca/customers/heritage-rx">Read the case study <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </article>

      <article class="bl-card" data-tag="case-study">
        <a class="bl-card__media bl-card__media--seashell" href="/ca/contact" aria-hidden="true" tabindex="-1">
          <span class="bl-card__cover-band">Case Study</span>
          <p class="bl-card__cover-title">PANS Member Pilot: early outcomes.</p>
        </a>
        <div class="bl-card__body">
          <span class="bl-card__tag">Case Study</span>
          <h3>PANS Member Pilot: early outcomes from the first cohort</h3>
          <p class="bl-card__meta">22 pages &middot; 11 min read &middot; Published May 2026</p>
          <p class="bl-card__lede">10 to 15 Nova Scotia pharmacies, three province-wide protocols, a four-month structure. Service utilization, claim performance, and the workflow refinements that landed during optimization.</p>
          <div class="bl-card__cta">
            <a href="/ca/contact">Download <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </article>

      <article class="bl-card" data-tag="operator-guide">
        <a class="bl-card__media bl-card__media--matcha" href="/ca/contact" aria-hidden="true" tabindex="-1">
          <span class="bl-card__cover-band">Operator Guide</span>
          <p class="bl-card__cover-title">The medication-review documentation playbook.</p>
        </a>
        <div class="bl-card__body">
          <span class="bl-card__tag">Operator Guide</span>
          <h3>The medication-review documentation discipline playbook</h3>
          <p class="bl-card__meta">36 pages &middot; 18 min read &middot; Updated Mar 2026</p>
          <p class="bl-card__lede">Drug therapy problem capture, goal-setting discipline, and audit-defensible note structure across provincial medication review programs. The operator-level practice that turns a 30-minute consult into a clean claim.</p>
          <div class="bl-card__cta">
            <a href="/ca/contact">Download <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </article>

      <article class="bl-card" data-tag="operator-guide">
        <a class="bl-card__media" href="/ca/contact" aria-hidden="true" tabindex="-1">
          <span class="bl-card__cover-band">Operator Guide</span>
          <p class="bl-card__cover-title">Provincial billing implementation guide.</p>
        </a>
        <div class="bl-card__body">
          <span class="bl-card__tag">Operator Guide</span>
          <h3>The provincial billing implementation guide for community pharmacy</h3>
          <p class="bl-card__meta">52 pages &middot; 26 min read &middot; Updated Apr 2026</p>
          <p class="bl-card__lede">End-to-end. eClaims enrollment, provincial drug plan setup, claim cycle, rejection triage, and the first ninety days of optimization in operating detail.</p>
          <div class="bl-card__cta">
            <a href="/ca/contact">Download <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </article>

    </div>
  </div>
</section>

<!-- ============= 3. CLOSING CTA (navy) ============= -->
<section class="tile tile--navy tile--prominent" aria-label="Get the briefs">
  <div class="tile__inner tile__inner--narrow">
    <div class="tile__head tile__head--centered">
      <span class="kicker">Get The Briefs</span>
      <h2 class="h-display">Every new brief<br>in your inbox.</h2>
      <p class="lead">A short email when a new brief or operator guide drops. No drip cadence, no marketing sequence dressed up as content.</p>
    </div>
    <div class="pill-cta-row pill-cta-row--center">
      <span class="pulse-rings" aria-hidden="true">
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
      </span>
      <a class="pill pill--solid" href="/ca/contact">Subscribe <span class="arrow">&rarr;</span></a>
    </div>
  </div>
</section>

<script is:inline slot="end-of-body" set:html={`/* White paper category filter, same pattern as blog/events/webinars. */
  (function papersFilter() {
    var pills = document.querySelectorAll('.bl-filter__pill');
    var cards = document.querySelectorAll('.bl-card');
    if (!pills.length || !cards.length) return;
    pills.forEach(function (pill) {
      pill.addEventListener('click', function () {
        var filter = pill.getAttribute('data-filter');
        pills.forEach(function (p) {
          var active = p === pill;
          p.classList.toggle('is-active', active);
          p.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
        cards.forEach(function (card) {
          var match = filter === 'all' || card.getAttribute('data-tag') === filter;
          card.classList.toggle('is-hidden', !match);
        });
      });
    });
  })();`}></script>
</BaseLayout>

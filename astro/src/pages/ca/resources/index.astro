---
import BaseLayout from '../../../layouts/BaseLayoutCa.astro';
---
<BaseLayout
  title="Resources, MedMe Health"
  description="Pharmacy-specific content built for the work you do. Blog, webinars, white papers, events, and the reimbursement calculator."
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en-ca" href="https://medmehealth.com/ca/resources" />
  </Fragment>

<style>

  /* ============================================================
     RESOURCES hub page. Built off the blog template
     (.sub-hero text-only / .bl-card grid / navy CTA) so all five
     pages under Resources share visual language.

     Hub variant: cards represent the five Resource sub-pages
     (Blog, Webinars, White Papers, Events, ROI Calculator) and
     use an icon-on-matcha-gradient hero block instead of a
     photo, so the page reads as navigation, not as a feed.
     ============================================================ */

  /* ====== HERO: text-only, no mockup =========================== */
  .sub-hero {
    background: var(--seashell);
    padding: 3.5rem 1.5rem 3rem;
    position: relative;
    overflow: hidden;
  }
  .sub-hero__inner {
    max-width: var(--container);
    margin: 0 auto;
    padding-inline: var(--tile-pad-x);
    position: relative;
  }
  .sub-hero__text {
    text-align: center;
    max-width: 820px;
    margin: 0 auto;
  }
  .sub-hero h1.h-display {
    font-size: clamp(28px, 4.4vw, 54px);
    line-height: 1.08;
    letter-spacing: -0.028em;
    margin: 0.75rem auto 1rem;
    text-align: center;
    text-wrap: balance;
  }
  .sub-hero__lede {
    font-size: 1.1rem;
    line-height: 1.55;
    color: rgba(6, 62, 84, 0.72);
    margin: 0 auto 0;
    max-width: 660px;
    text-wrap: pretty;
  }
  .sub-hero__breadcrumb {
    font-size: 13px;
    color: rgba(6, 62, 84, 0.55);
    margin-bottom: 1.25rem;
    text-align: center;
  }
  .sub-hero__breadcrumb a { color: rgba(6, 62, 84, 0.55); text-decoration: none; }
  .sub-hero__breadcrumb a:hover { color: var(--indigo); }
  .sub-hero__breadcrumb .sep { margin: 0 0.5rem; opacity: 0.4; }

  /* ====== HUB CARD GRID ======================================== */
  .bl-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }
  @media (max-width: 1000px) { .bl-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .bl-grid { grid-template-columns: 1fr; } }

  .bl-card {
    background: var(--white);
    border: 1px solid rgba(6, 62, 84, 0.08);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .bl-card:hover {
    transform: translateY(-3px);
    border-color: rgba(6, 62, 84, 0.18);
    box-shadow: 0 16px 40px rgba(6, 62, 84, 0.08);
  }

  /* Gradient placeholder media slot, icon-centered. */
  .bl-card__media {
    aspect-ratio: 16 / 9;
    width: 100%;
    background: linear-gradient(135deg, rgba(195, 196, 48, 0.95) 0%, rgba(195, 196, 48, 0.55) 100%);
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--indigo);
    text-decoration: none;
    transition: filter 0.25s ease;
  }
  .bl-card:hover .bl-card__media { filter: brightness(1.04); }
  .bl-card__media svg {
    width: 56px;
    height: 56px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  /* Per-card tint variants to give the hub visual rhythm. */
  .bl-card__media--indigo {
    background: linear-gradient(135deg, var(--indigo) 0%, rgba(6, 62, 84, 0.75) 100%);
    color: var(--matcha);
  }
  .bl-card__media--seashell {
    background: linear-gradient(135deg, rgba(195, 196, 48, 0.22) 0%, rgba(6, 62, 84, 0.08) 100%);
    color: var(--indigo);
  }

  .bl-card__body {
    padding: 1.5rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.75rem;
  }
  .bl-card__tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(195, 196, 48, 0.16);
    color: var(--indigo);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 999px;
    align-self: flex-start;
    letter-spacing: 0.02em;
  }
  .bl-card__tag::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--matcha);
  }
  .bl-card h3 {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--indigo);
    letter-spacing: -0.014em;
    line-height: 1.25;
    text-wrap: balance;
  }
  .bl-card__lede {
    margin: 0;
    font-size: 0.92rem;
    color: rgba(6, 62, 84, 0.72);
    line-height: 1.55;
    flex: 1;
  }
  .bl-card__cta {
    margin-top: auto;
    padding-top: 0.75rem;
  }
  .bl-card__cta a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--matcha);
    color: var(--indigo);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.88rem;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    text-decoration: none;
    border: 1.5px solid var(--matcha);
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }
  .bl-card__cta a:hover {
    background: transparent;
    color: var(--indigo);
    transform: translateX(2px);
  }
  .bl-card__cta a .arrow { transition: transform 0.18s ease; }
  .bl-card__cta a:hover .arrow { transform: translateX(2px); }
</style>

<!-- ============= 1. SUB-HERO (text-only) ============= -->
<section class="sub-hero" aria-label="Hero">
  <div class="sub-hero__inner">
    <div class="sub-hero__text">
      <div class="sub-hero__breadcrumb">
        <a href="/us">Home</a><span class="sep">/</span><span>Resources</span>
      </div>
      <span class="kicker kicker--matcha">Resources</span>
      <h1 class="h-display">Pharmacy-specific content<br>built for the work you do.</h1>
      <p class="sub-hero__lede">Reimbursement calculators, code references, policy briefs, customer stories, and field-tested workflows, written for community pharmacy operators.</p>
    </div>
  </div>
</section>

<!-- ============= 2. RESOURCE CATEGORY CARDS ============= -->
<section class="tile tile--light" aria-label="Resource categories">
  <div class="tile__inner">
    <div class="bl-grid">

      <article class="bl-card">
        <a class="bl-card__media" href="/ca/resources/blog" aria-hidden="true" tabindex="-1">
          <svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
        </a>
        <div class="bl-card__body">
          <span class="bl-card__tag">Blog</span>
          <h3>Stories from the front lines of clinical pharmacy</h3>
          <p class="bl-card__lede">Operator playbooks, code-level deep dives, and policy primers, written by the pharmacists and operators who do the work.</p>
          <div class="bl-card__cta">
            <a href="/ca/resources/blog">Read the blog <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </article>

      <article class="bl-card">
        <a class="bl-card__media bl-card__media--indigo" href="/ca/resources/webinars" aria-hidden="true" tabindex="-1">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor"/></svg>
        </a>
        <div class="bl-card__body">
          <span class="bl-card__tag">Webinars</span>
          <h3>Live and on-demand pharmacy webinars</h3>
          <p class="bl-card__lede">Operator-to-operator sessions on billing CCM, deploying AI scribe, navigating RHTP, and the provider-status legislation moving in 2026.</p>
          <div class="bl-card__cta">
            <a href="/ca/resources/webinars">See the sessions <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </article>

      <article class="bl-card">
        <a class="bl-card__media bl-card__media--seashell" href="/ca/resources/white-papers" aria-hidden="true" tabindex="-1">
          <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>
        </a>
        <div class="bl-card__body">
          <span class="bl-card__tag">White Papers</span>
          <h3>Research and policy briefs for pharmacy operators</h3>
          <p class="bl-card__lede">Written for the operator on the floor, not the policy wonk. State scope of practice, payer-mix benchmarks, RHTP impact, and the case studies behind them.</p>
          <div class="bl-card__cta">
            <a href="/ca/resources/white-papers">Browse the library <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </article>

      <article class="bl-card">
        <a class="bl-card__media" href="/ca/resources/events" aria-hidden="true" tabindex="-1">
          <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </a>
        <div class="bl-card__body">
          <span class="bl-card__tag">Events</span>
          <h3>Where you'll see MedMe in person this year</h3>
          <p class="bl-card__lede">Conference booths, partner dinners, regional roundtables. Pharmacy operators come up to us; we don't run booth bingo.</p>
          <div class="bl-card__cta">
            <a href="/ca/resources/events">See the calendar <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </article>

      <article class="bl-card">
        <a class="bl-card__media bl-card__media--seashell" href="/ca/contact" aria-hidden="true" tabindex="-1">
          <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </a>
        <div class="bl-card__body">
          <span class="bl-card__tag">Newsletter</span>
          <h3>One short email a week</h3>
          <p class="bl-card__lede">The new posts, the new webinar dates, the policy shifts that actually matter. No fluff, no marketing cadence dressed up as content.</p>
          <div class="bl-card__cta">
            <a href="/ca/contact">Subscribe <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </article>

    </div>
  </div>
</section>

<!-- ============= 3. CLOSING CTA (navy) ============= -->
<section class="tile tile--navy tile--prominent" aria-label="Talk to MedMe">
  <div class="tile__inner tile__inner--narrow">
    <div class="tile__head tile__head--centered">
      <span class="kicker">Talk To Our Team</span>
      <h2 class="h-display">See your real number<br>on a 20-minute call.</h2>
      <p class="lead">Send a week of your encounter volume. We will back-of-envelope your annual reimbursement and walk through the codes that move the needle for your service mix.</p>
    </div>
    <div class="pill-cta-row pill-cta-row--center">
      <span class="pulse-rings" aria-hidden="true">
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
        <span class="pulse-ring"></span>
      </span>
      <a class="pill pill--solid" href="/ca/contact">Book a demo <span class="arrow">&rarr;</span></a>
    </div>
  </div>
</section>

</BaseLayout>
